# BSCS Bench Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Required for Benchmarks ──────────────────────────────────

# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# ─── COMP 421 (Rice CLEAR SSH access) ─────────────────────────

# Your Rice Net ID for SSH to CLEAR servers (COMP 421 labs only)
# CLEAR_NETID=your_netid

# ─── COMP 322 HW2 (GitHub API) ────────────────────────────────

# Set MOCK_GITHUB=true to skip real GitHub API calls (recommended)
MOCK_GITHUB=true

# Real GitHub credentials (only if MOCK_GITHUB is not set)
# GITHUB_USERNAME=your_github_username
# GITHUB_TOKEN=ghp_...

