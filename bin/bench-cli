#!/usr/bin/env python3
"""
bench-cli v2 — assignment-attempt runner for BSCS Bench.

Active commands:
    bin/bench-cli run assignment <assignment_id> --model-key <model>
    bin/bench-cli run course <course> --model-key <model>
    bin/bench-cli run corpus --model-key <model>
    bin/bench-cli phase submit-grade <assignment_id> --model-key <model>
    bin/bench-cli phase llm-grade <assignment_id> --model-key <model>
    bin/bench-cli phase code-review <assignment_id> --model-key <model>
    bin/bench-cli summarize model <model_key>
    bin/bench-cli export model <model_key>

Canonical state:
    state/models/<model_key>/assignments/<assignment_id>/
      manifest.json
      attempts/<attempt_id>/
        attempt.json
        agent_output.json
        agent_trace.jsonl
        grade_result.json
        grade_result.txt
        llm_grade_result_<model>.md
        code_review_result_<model>.md
        solution.diff
        solution/
        workspace.bundle
"""

