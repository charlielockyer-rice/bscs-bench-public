    <visibility xmi:id="_1wDiqpaxEey_Oso2woJSWA" label="+"/>
    <attributes xmi:id="_1wDiq5axEey_Oso2woJSWA" defaultValue="new IPaintStrategy() {&#xA;&#x9;&#x9;@Override&#xA;&#x9;&#x9;/**&#xA;&#x9;&#x9; * Paint the ball to the screen.&#xA;&#x9;&#x9; * @param g The graphics to paint.&#xA;&#x9;&#x9; * @param host the host ball&#xA;&#x9;&#x9; */&#xA;&#x9;&#x9;public void paint(Graphics g, IBall host) {&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;@Override&#xA;&#x9;&#x9;/**&#xA;&#x9;&#x9; * @param host -> the host ball.&#xA;&#x9;&#x9; * Initialize the update strategy. This method must be run whenever the ball gets a new strategy.&#xA;&#x9;&#x9; */&#xA;&#x9;&#x9;public void init(IBall host) {&#xA;&#x9;&#x9;}&#xA;&#x9;}" name="NULL_OBJECT" staticAttribute="true">
      <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_FBoEsJaxEey_Oso2woJSWA"/>
      <visibility xmi:id="_1wDirJaxEey_Oso2woJSWA" label="+"/>
      <cardinality xmi:id="_1wDirZaxEey_Oso2woJSWA" label="1" max="1" min="1"/>
      <type xmi:id="_1wDirpaxEey_Oso2woJSWA" name="IPaintStrategy">
        <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_AqPNsZaxEey_Oso2woJSWA"/>
      </type>
    </attributes>
    <attributes xmi:id="_1wDir5axEey_Oso2woJSWA" defaultValue="new IPaintStrategy() {&#xA;&#x9;&#x9;@Override&#xA;&#x9;&#x9;/**&#xA;&#x9;&#x9; * Paint the ball to the screen.&#xA;&#x9;&#x9; * @param g The graphics to paint.&#xA;&#x9;&#x9; * @param host the host ball&#xA;&#x9;&#x9; */&#xA;&#x9;&#x9;public void paint(Graphics g, IBall host) {&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;@Override&#xA;&#x9;&#x9;/**&#xA;&#x9;&#x9; * @param host -> the host ball.&#xA;&#x9;&#x9; * Initialize the update strategy. This method must be run whenever the ball gets a new strategy.&#xA;&#x9;&#x9; */&#xA;&#x9;&#x9;public void init(IBall host) {&#xA;&#x9;&#x9;&#x9;java.awt.Toolkit.getDefaultToolkit().beep();&#xA;&#x9;&#x9;&#x9;System.err.println(&quot;IPaintStrategy.ERROR: beeping!&quot;);&#xA;&#x9;&#x9;}&#xA;&#x9;}" name="ERROR" staticAttribute="true">
