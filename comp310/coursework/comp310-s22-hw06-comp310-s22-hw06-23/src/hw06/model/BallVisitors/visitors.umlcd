  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGEeAJaxEey_Oso2woJSWA" sourceConnectionVisual="_fGEeAZaxEey_Oso2woJSWA" text="Constructs a configuration algorithm with a no-op default case and the given adapter to the model.&#xA;&#x9; * Use this constructor when the default case command needs to reference instance fields and methods of &#xA;&#x9; * the configuration algorithm.   In that scenario, setDefaultCmd() must be explicitly called to &#xA;&#x9; * override the default no-op behavior of the default case.&#xA;&#x9; * @param logger The logger to use&#xA;&#x9; * @param algo2ModelAdpt The adapter to the model." item="_fGG6XJaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQKKZaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGEeApaxEey_Oso2woJSWA" sourceConnectionVisual="_fGEeA5axEey_Oso2woJSWA" text="Constructs a configuration algorithm with a no-op default case and the given adapter to the model.&#xA;&#x9; * Use this constructor when the default case command needs to reference instance fields and methods of &#xA;&#x9; * the configuration algorithm.   In that scenario, setDefaultCmd() must be explicitly called to &#xA;&#x9; * override the default no-op behavior of the default case.&#xA;&#x9; * @param logger The logger to use&#xA;&#x9; * @param name A friendly name for the toString() method to return.&#xA;&#x9; * @param algo2ModelAdpt The adapter to the model." item="_fGG6aJaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQKKpaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGFFEJaxEey_Oso2woJSWA" sourceConnectionVisual="_fGFFEZaxEey_Oso2woJSWA" text="Constructs a configuration algorithm with the given default case and the given adapter to the model.&#xA;&#x9; * @param logger The logger to use&#xA;&#x9; * @param algo2ModelAdpt adapter to the model.&#xA;&#x9; * @param defaultCmd The default case command" item="_fGG6d5axEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQKK5axEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGFFEpaxEey_Oso2woJSWA" sourceConnectionVisual="_fGFFE5axEey_Oso2woJSWA" text="Constructs a configuration algorithm with the given default case and the given adapter to the model.&#xA;&#x9; * @param logger The logger to use&#xA;&#x9; * @param name A friendly name for the toString() method to return.&#xA;&#x9; * @param algo2ModelAdpt adapter to the model.&#xA;&#x9; * @param defaultCmd The default case command" item="_fGG6hpaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQKLJaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGFFFJaxEey_Oso2woJSWA" sourceConnectionVisual="_fGFFFZaxEey_Oso2woJSWA" text="Convenience method to install an update strategy into the given host ball.&#xA;&#x9; * @param host  The host ball to install the given update strategy into&#xA;&#x9; * @param newStrat The update strategy to install into the host ball" item="_fGG6mJaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQxMJaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGFFFpaxEey_Oso2woJSWA" sourceConnectionVisual="_fGFFF5axEey_Oso2woJSWA" text="Convenience method to install a paint strategy into the given host ball.&#xA;&#x9; * @param host  The host ball to install the given paint strategy into&#xA;&#x9; * @param newStrat The paint strategy to install into the host ball" item="_fGG6oZaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQxMZaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGFsIJaxEey_Oso2woJSWA" sourceConnectionVisual="_fGFsIZaxEey_Oso2woJSWA" text="Convenience method to install an interact strategy into the given host ball.&#xA;&#x9; * @param host  The host ball to install the given interact strategy into&#xA;&#x9; * @param newStrat The interact strategy to install into the host ball" item="_fGG6qpaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQxMpaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGKkoJaxEey_Oso2woJSWA" sourceConnectionVisual="_fGKkoZaxEey_Oso2woJSWA" text="A concrete implementation of IBallAlgo based on ABallHostAlgo&#xA;whose host is an IBall.&#xA;@author swong&#xA; *&#xA;@param &lt;R> The return type of this visitor's process&#xA;@param &lt;P> The input parameter type of this visitor's process" item="_fGLLsJaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQxM5axEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGNA4ZaxEey_Oso2woJSWA" sourceConnectionVisual="_fGNn8JaxEey_Oso2woJSWA" text="Configuration algorithm to install a dynamically controllable interact strategy that model a Fish World.&#xA;More in the readme.&#xA;@author Charlie Lockyer and Son Nguyen&#xA; *" item="_fGQEOZaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQxNJaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGNn8ZaxEey_Oso2woJSWA" sourceConnectionVisual="_fGNn8paxEey_Oso2woJSWA" text="Constructs the algo with the given adapter with default, instance-specific friendly name &#xA;&#x9; * @param logger The logger to use&#xA;&#x9; * @param algo2ModelAdpt The adapter to the model" item="_fGQEX5axEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQxNZaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGOPAJaxEey_Oso2woJSWA" sourceConnectionVisual="_fGOPAZaxEey_Oso2woJSWA" text="Constructs the algo with the given adapter with the given friendly name.&#xA;&#x9; * @param logger The logger to use&#xA;&#x9; * @param name The friendly name to display&#xA;&#x9; * @param algo2ModelAdpt The adapter to the model" item="_fGQEa5axEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQxNpaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGOPApaxEey_Oso2woJSWA" sourceConnectionVisual="_fGOPA5axEey_Oso2woJSWA" text="Set the host fish size in accordance to a divMin and divMax scale down factor&#xA;&#x9; * @param host The host fish.&#xA;&#x9; * @param divMin An integer for the denominator of the min size.&#xA;&#x9; * @param divMax An integer for the denominator of the max size." item="_fGQEepaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQxN5axEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGOPBJaxEey_Oso2woJSWA" sourceConnectionVisual="_fGOPBZaxEey_Oso2woJSWA" text="Accelerate the ball by the acceleration&#xA;&#x9; * @param host The host fish." item="_fGQEhpaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQxOJaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGSgcZaxEey_Oso2woJSWA" sourceConnectionVisual="_fGSgcpaxEey_Oso2woJSWA" text="Configuration algorithm to install a dynamically controllable interact strategy that has a certain &#xA;probability of &quot;killing&quot; the target ball.   The dynamically generated control panel can&#xA;modify the kill probability as well as change whether it kills a specific target ball type &#xA;(available types are hard-coded for simplicity) or all ball types or no ball types.&#xA;Individual instances of this configuration algorithm are uniquely numbered for easy &#xA;identification on the GUI.&#xA;@author swong&#xA; *" item="_fGU8s5axEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQxOZaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGTHgZaxEey_Oso2woJSWA" sourceConnectionVisual="_fGTHgpaxEey_Oso2woJSWA" text="Constructs the algo with the given adapter with default, instance-specific friendly name &#xA;&#x9; * @param logger The logger to use&#xA;&#x9; * @param algo2ModelAdpt The adapter to the model" item="_fGVjwJaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQxOpaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGXY8ZaxEey_Oso2woJSWA" sourceConnectionVisual="_fGXY8paxEey_Oso2woJSWA" text="Configuration algorithm to install a dynamically controllable interact strategy that makes&#xA;other ball follows it in different ways depending on what type the current ball is.&#xA;@author Son Nguyen and Charlie Lockyer&#xA; *" item="_fGacQJaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQxPJaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGYAAJaxEey_Oso2woJSWA" sourceConnectionVisual="_fGYAAZaxEey_Oso2woJSWA" text="Constructs the algo with the given adapter with default, instance-specific friendly name &#xA;&#x9; * @param logger The logger to use&#xA;&#x9; * @param algo2ModelAdpt The adapter to the model" item="_fGaca5axEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQxPZaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGc4gpaxEey_Oso2woJSWA" sourceConnectionVisual="_fGc4g5axEey_Oso2woJSWA" text="A ball algo that is designed to process either a single type of ball or all ball types &#xA;using a function provided as the input parameter.&#xA;Input parameter:   Function&lt;IBall, R> a function that takes the ball host and returns a value of type R.  Executing the visitor will &#xA;return either the return value from this function or the return value of the default case command, e.g. null if &#xA;the default case cmd is a no-op. &#xA;This function is run for the currently set processed ball type or the default case, if set.&#xA;To set the default case as the processed ball type, use this instance's getDefaultType() value as the identifier&#xA;for the default case. &#xA;&#xA;IMPORTANT: Any commands added using setCmd() or removed using removeCmd() are NOT controlled by the methods of this &#xA;subclass and are not affected by the methods in this subclass unless that specific ball type was affected by the setType() method!  &#xA;@author swong&#xA; *&#xA;@param &lt;R>   The return type of the input parameter function." item="_fGgi5JaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQxP5axEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGeGoJaxEey_Oso2woJSWA" sourceConnectionVisual="_fGeGoZaxEey_Oso2woJSWA" text="Constructor for the class where the default case is a no-op if it is not the processed ball type.&#xA;&#x9; * @param defaultTypeName The friendly name given to the IBallHostID this instance uses to identify its default case.&#xA;&#x9; * @param isDefaultRunFunc If true, then the default case will be set to running the given function.  &#xA;&#x9; * Otherwise the default case will be a no-op." item="_fGgjDZaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQxQJaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGeGopaxEey_Oso2woJSWA" sourceConnectionVisual="_fGeGo5axEey_Oso2woJSWA" text="Resets the algorithm such the current ball ID being used is for processing is the default ID, i.e. the default command.&#xA;&#x9; * The default case processing depends on the value of isDefaultRunFunc.  If isDefaultRunFunc = false, then the default case cmd &#xA;&#x9; * set by the constructor will be used.  If isDefaultRunFunc = true, then the default case will process all ball types with the given &#xA;&#x9; * input parameter function, returning the function's return value.&#xA;&#x9; * reset(false) can be used to disable this algo if the default case cmd is a no-op.&#xA;&#x9; * @param isDefaultRunFunc If true, the default case is set to run the given input parameter function of the algo.  &#xA;&#x9; * Otherwise, the default case cmd is used." item="_fGgjGZaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQxQpaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGeGpJaxEey_Oso2woJSWA" sourceConnectionVisual="_fGeGpZaxEey_Oso2woJSWA" text="Gets the current processing state of the algo's default case.&#xA;&#x9; * @return true, if the default case is set to run the given input parameter function of the algo.  &#xA;&#x9; * Otherwise, the default case is a no-op." item="_fGgjH5axEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQxQ5axEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGeGppaxEey_Oso2woJSWA" sourceConnectionVisual="_fGeGp5axEey_Oso2woJSWA" text="Constructor for the class where the default case is the given defaultCmd if it is not the processed ball type.&#xA;&#x9; * @param defaultTypeName The friendly name given to the IBallHostID this instance uses to identify its default case.&#xA;&#x9; * @param isDefaultRunFunc If true, then the default case will be set to running the given function.  &#xA;&#x9; * Otherwise the default case will be the given defaultCmd.&#xA;&#x9; * @param defaultCmd The command to use for the default case if it is not the processed type." item="_fGgjJJaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQxQZaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGeGqJaxEey_Oso2woJSWA" sourceConnectionVisual="_fGetsJaxEey_Oso2woJSWA" text="Changes the current ball type to be processed to the given type.&#xA;&#x9; * If the default case is desired, then use getDefaultType() as the ballTypeID value.&#xA;&#x9; * The previous ball type will be configured to run the default case,&#xA;&#x9; * i.e the command associated with that type is removed if it is not the default case.&#xA;&#x9; * If the previous type was the default case, the default case will be set to be a no-op, &#xA;&#x9; * unless the default case is indicated by ballTypeID.&#xA;&#x9; * @param ballTypeID The type of the ball to be set for processing." item="_fGhJ-paxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQxRJaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGk0UpaxEey_Oso2woJSWA" sourceConnectionVisual="_fGk0U5axEey_Oso2woJSWA" text="Algorithm that will return true if the host is the same type as the given input parameter.&#xA;This algorithm will always work, even for dynamically typed balls.&#xA;Parameter: An IBall instance.&#xA;Returns:  True if the host and the parameter are the same type.  False otherwise.&#xA;Usage:  boolean result = host.execute(SameTypeBallAlgo.Singleton, other) &#xA;@author swong&#xA; *" item="_fGmCcJaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQxRZaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGnQkpaxEey_Oso2woJSWA" sourceConnectionVisual="_fGnQk5axEey_Oso2woJSWA" text="Configuration algorithm to install a dynamically controllable interact strategy that model a Fish World.&#xA;More in the readme.&#xA;@author Charlie Lockyer and Son Nguyen&#xA; *" item="_fGqT4JaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyRYQJaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGn3pZaxEey_Oso2woJSWA" sourceConnectionVisual="_fGn3ppaxEey_Oso2woJSWA" text="Constructs the algo with the given adapter with default, instance-specific friendly name &#xA;&#x9; * @param logger The logger to use&#xA;&#x9; * @param algo2ModelAdpt The adapter to the model" item="_fGqUBpaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyRYQZaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGoesJaxEey_Oso2woJSWA" sourceConnectionVisual="_fGoesZaxEey_Oso2woJSWA" text="Constructs the algo with the given adapter with the given friendly name.&#xA;&#x9; * @param logger The logger to use&#xA;&#x9; * @param name The friendly name to display&#xA;&#x9; * @param algo2ModelAdpt The adapter to the model" item="_fGqUEpaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyRYQpaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGoespaxEey_Oso2woJSWA" sourceConnectionVisual="_fGoes5axEey_Oso2woJSWA" text="Set the host fish size in accordance to a divMin and divMax scale down factor&#xA;&#x9; * @param host The host fish.&#xA;&#x9; * @param divMin An integer for the denominator of the min size.&#xA;&#x9; * @param divMax An integer for the denominator of the max size." item="_fGqUIZaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyRYQ5axEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGoetJaxEey_Oso2woJSWA" sourceConnectionVisual="_fGoetZaxEey_Oso2woJSWA" text="Accelerate the ball by the acceleration&#xA;&#x9; * @param host The host fish." item="_fGqULZaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyRYRJaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGtXMpaxEey_Oso2woJSWA" sourceConnectionVisual="_fGtXM5axEey_Oso2woJSWA" text="Configuration algorithm to install a dynamically controllable interact strategy that has a certain &#xA;probability of &quot;killing&quot; the target ball.   The dynamically generated control panel can&#xA;modify the kill probability as well as change whether it kills a specific target ball type &#xA;(available types are hard-coded for simplicity) or all ball types or no ball types.&#xA;Individual instances of this configuration algorithm are uniquely numbered for easy &#xA;identification on the GUI.&#xA;@author Son Nguyen and Charlie Lockyer&#xA; *" item="_fGwagJaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyRYRZaxEey_Oso2woJSWA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGulUJaxEey_Oso2woJSWA" sourceConnectionVisual="_fGulUZaxEey_Oso2woJSWA" text="Constructs the algo with the given adapter with default, instance-specific friendly name &#xA;&#x9; * @param logger The logger to use&#xA;&#x9; * @param algo2ModelAdpt The adapter to the model" item="_fGwaoZaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyRYRpaxEey_Oso2woJSWA"/>
  </nodes>
