  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_fGD28JaxEey_Oso2woJSWA" sourceConnectionVisual="_fGD28ZaxEey_Oso2woJSWA" text="Abstract implementation of a BallAlgo&lt;Void, Void> that holds an adapter to the model.&#xA;@author swong&#xA; *" item="_fGG6SZaxEey_Oso2woJSWA">
    <modelElement href="../../../comp310-s22-hw06-comp310-s22-hw06-23.uml#_eyQKKJaxEey_Oso2woJSWA"/>
