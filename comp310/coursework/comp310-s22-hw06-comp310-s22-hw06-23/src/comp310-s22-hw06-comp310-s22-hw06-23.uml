          <packagedElement xmi:type="uml:Class" xmi:id="_mYKLkJaxEey_Oso2woJSWA" name="TradeColorInteractStrategy">
            <ownedComment xmi:id="_mY7AnZaxEey_Oso2woJSWA">
              <body>Interaction strategy for the context ball and the interacting ball to trade their colors (whenever a given 
interaction criteria is met).

@author Son Nguyen and Smit Viroja</body>
            </ownedComment>
            <interfaceRealization xmi:id="_mY2vIpaxEey_Oso2woJSWA" client="_mYKLkJaxEey_Oso2woJSWA" supplier="_AqN_kZaxEey_Oso2woJSWA" contract="_AqN_kZaxEey_Oso2woJSWA"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_mY7AkpaxEey_Oso2woJSWA" name="interactWithThen" specification="_mY2vI5axEey_Oso2woJSWA">
              <ownedParameter xmi:id="_mY7Ak5axEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mY7AlJaxEey_Oso2woJSWA" name="other" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mY7AlZaxEey_Oso2woJSWA" name="disp" type="_AqSRAZaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mY7AlpaxEey_Oso2woJSWA" type="_AqNYgZaxEey_Oso2woJSWA" direction="return"/>
              <language>java</language>
              <body>Color contextColor = context.getColor();
		Color otherColor = other.getColor();
		
		return new IBallCmd() {
			@Override
			public void apply(IBall context, IDispatcher&lt;IBallCmd> disp) {
				context.setColor(otherColor);
				other.setColor(contextColor);
			}
			
		};
	</body>
            </ownedBehavior>
