          <packagedElement xmi:type="uml:Class" xmi:id="_1Q9y4JaxEey_Oso2woJSWA" name="ShapePaintStrategy">
            <ownedComment xmi:id="_1S6TpJaxEey_Oso2woJSWA">
              <body>Concrete class that defines invariant painting behaviors to paint Shape objects for all its subclasses.
@author phuso
 *</body>
            </ownedComment>
            <generalization xmi:id="_1SeOwJaxEey_Oso2woJSWA" general="_1Q5hcJaxEey_Oso2woJSWA"/>
            <ownedAttribute xmi:id="_1Szl8JaxEey_Oso2woJSWA" name="prototypeShape" visibility="private" type="_1SdnsZaxEey_Oso2woJSWA" association="_1S_MI5axEey_Oso2woJSWA">
