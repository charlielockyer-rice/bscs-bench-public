            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_eyNG4paxEey_Oso2woJSWA" name="installUpdateStrategy" specification="_exc445axEey_Oso2woJSWA">
              <ownedParameter xmi:id="_eyNG45axEey_Oso2woJSWA" name="host" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_eyNG5JaxEey_Oso2woJSWA" name="newStrat" type="_AqQb0ZaxEey_Oso2woJSWA"/>
              <language>java</language>
              <body>// Make composite with existing strategy
		host.setUpdateStrategy(new IUpdateStrategy() {
			IUpdateStrategy strat1 = host.getUpdateStrategy();
			IUpdateStrategy strat2 = newStrat;
			@Override
			public void init(IBall host) {
				strat1.init(host);
				strat2.init(host);
			}

			@Override
			public void updateState(IBall context, IDispatcher&lt;IBallCmd> disp) {
				strat1.updateState(context, disp);
				strat2.updateState(context, disp);
				
			}	
		});
	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_eyNt4JaxEey_Oso2woJSWA" name="installPaintStrategy" specification="_exdf8paxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_eyNt4ZaxEey_Oso2woJSWA" name="host" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_eyNt4paxEey_Oso2woJSWA" name="newStrat" type="_AqPNsZaxEey_Oso2woJSWA"/>
              <language>java</language>
              <body>// Make composite with existing strategy
		host.setPaintStrategy(new IPaintStrategy() {
			IPaintStrategy strat1 = host.getPaintStrategy();
			IPaintStrategy strat2 = newStrat;
			
			@Override
			public void init(IBall host) {
				strat1.init(host);
				strat2.init(host);
			}

			@Override
			public void paint(Graphics g, IBall host) {
				strat1.paint(g, host);
				strat2.paint(g, host);
				
			}
		});
	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_eyNt45axEey_Oso2woJSWA" name="installInteractStrategy" specification="_exdf9ZaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_eyNt5JaxEey_Oso2woJSWA" name="host" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_eyNt5ZaxEey_Oso2woJSWA" name="newStrat" type="_AqN_kZaxEey_Oso2woJSWA"/>
              <language>java</language>
              <body>// Make composite with existing strategy
		host.setInteractStrategy(new IInteractStrategy() {
			IInteractStrategy strat1 = host.getInteractStrategy();
			IInteractStrategy strat2 = newStrat;
			
			@Override
			public void init(IBall host) {
				strat1.init(host);
				strat2.init(host);
			}

			@Override
			public IBallCmd interactWithThen(IBall context, IBall other, IDispatcher&lt;IBallCmd> disp) {
				IBallCmd cmd1 = strat1.interactWithThen(host, other, disp);
				IBallCmd cmd2 = strat2.interactWithThen(host, other, disp);
				return new IBallCmd() {
					@Override
					public void apply(IBall host, IDispatcher&lt;IBallCmd> disp) {
						cmd1.apply(host, disp);
						cmd2.apply(host, disp);
					}
				};		
			}
	
		});
	</body>
            </ownedBehavior>
