            <packagedElement xmi:type="uml:Class" xmi:id="_1RJZEJaxEey_Oso2woJSWA" name="SquarePaintStrategy">
              <ownedComment xmi:id="_1S66s5axEey_Oso2woJSWA">
                <body>Paint strategy that paints a filled square with the Ball's radius.
@author Son Nguyen and Cole Rabson</body>
              </ownedComment>
              <interfaceRealization xmi:id="_1SjuUZaxEey_Oso2woJSWA" client="_1RJZEJaxEey_Oso2woJSWA" supplier="_AqPNsZaxEey_Oso2woJSWA" contract="_AqPNsZaxEey_Oso2woJSWA"/>
              <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_1S5FgpaxEey_Oso2woJSWA" name="paint" specification="_1SjuUpaxEey_Oso2woJSWA">
                <ownedParameter xmi:id="_1S5Fg5axEey_Oso2woJSWA" name="g" type="_AqLjUZaxEey_Oso2woJSWA"/>
                <ownedParameter xmi:id="_1S5FhJaxEey_Oso2woJSWA" name="host" type="_Apm7kJaxEey_Oso2woJSWA"/>
                <language>java</language>
                <body>int halfSide = host.getRadius();
		g.setColor(host.getColor());
		g.fillRect(host.getLocation().x - halfSide, host.getLocation().y - halfSide, 2 * halfSide, 2 * halfSide);
	</body>
              </ownedBehavior>
              <ownedOperation xmi:id="_1RJZEZaxEey_Oso2woJSWA" name="SquarePaintStrategy">
                <eAnnotations xmi:id="_1RJZEpaxEey_Oso2woJSWA" source="http://www.eclipse.org/uml2/2.0.0/UML">
                  <details xmi:id="_1RJZE5axEey_Oso2woJSWA" key="create"/>
                </eAnnotations>
                <ownedParameter xmi:id="_1RJZFZaxEey_Oso2woJSWA" type="_1RJZEJaxEey_Oso2woJSWA" direction="return"/>
              </ownedOperation>
              <ownedOperation xmi:id="_1SjuUpaxEey_Oso2woJSWA" name="paint" method="_1S5FgpaxEey_Oso2woJSWA">
                <ownedParameter xmi:id="_1SjuU5axEey_Oso2woJSWA" name="g" type="_AqLjUZaxEey_Oso2woJSWA"/>
                <ownedParameter xmi:id="_1SjuVJaxEey_Oso2woJSWA" name="host" type="_Apm7kJaxEey_Oso2woJSWA"/>
              </ownedOperation>
              <ownedOperation xmi:id="_1SjuVZaxEey_Oso2woJSWA" name="init">
                <ownedParameter xmi:id="_1SjuVpaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              </ownedOperation>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_1RKAIJaxEey_Oso2woJSWA" name="StarPaintStrategy">
              <ownedComment xmi:id="_1S66tJaxEey_Oso2woJSWA">
                <body>Paint strategy that paints a filled StarPaintStrategy.
@author Son Nguyen and Cole Rabson</body>
              </ownedComment>
              <interfaceRealization xmi:id="_1SkVYZaxEey_Oso2woJSWA" client="_1RKAIJaxEey_Oso2woJSWA" supplier="_AqPNsZaxEey_Oso2woJSWA" contract="_AqPNsZaxEey_Oso2woJSWA"/>
              <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_1S5FhZaxEey_Oso2woJSWA" name="paint" specification="_1SkVYpaxEey_Oso2woJSWA">
                <ownedParameter xmi:id="_1S5FhpaxEey_Oso2woJSWA" name="g" type="_AqLjUZaxEey_Oso2woJSWA"/>
                <ownedParameter xmi:id="_1S5Fh5axEey_Oso2woJSWA" name="host" type="_Apm7kJaxEey_Oso2woJSWA"/>
                <language>java</language>
                <body>int halfSide = host.getRadius();
		g.setColor(host.getColor());
		int[] xCoords = new int[] {host.getLocation().x -halfSide, host.getLocation().x -halfSide/4,
				 host.getLocation().x, host.getLocation().x + halfSide/4, host.getLocation().x +halfSide,
				 host.getLocation().x +halfSide/4,host.getLocation().x, host.getLocation().x -halfSide/4};
		int[] yCoords = new int[] {host.getLocation().y, host.getLocation().y -halfSide/4,
				 host.getLocation().y - halfSide, host.getLocation().y -halfSide/4, host.getLocation().y,
				 host.getLocation().y +halfSide/4,host.getLocation().y + halfSide, host.getLocation().y+halfSide/4};
		g.fillPolygon(xCoords, yCoords, 8);
	</body>
              </ownedBehavior>
              <ownedOperation xmi:id="_1RKAIZaxEey_Oso2woJSWA" name="StarPaintStrategy">
                <eAnnotations xmi:id="_1RKAIpaxEey_Oso2woJSWA" source="http://www.eclipse.org/uml2/2.0.0/UML">
