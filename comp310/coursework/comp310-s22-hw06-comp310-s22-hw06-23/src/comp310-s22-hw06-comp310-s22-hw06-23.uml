          <packagedElement xmi:type="uml:Class" xmi:id="_Hsw1QZaxEey_Oso2woJSWA" name="MultiInteractStrategy">
            <ownedComment xmi:id="_mY7AnJaxEey_Oso2woJSWA">
              <body>Strategy that compose two IInteractStrategy strategies together properly.
(Not an actual interaction strategy to be initiated)

@author Son Nguyen and Smit Viroja</body>
            </ownedComment>
            <ownedAttribute xmi:id="_mY4kUpaxEey_Oso2woJSWA" name="strat1" visibility="package" type="_AqN_kZaxEey_Oso2woJSWA" association="_mY8OsJaxEey_Oso2woJSWA">
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_mY4kU5axEey_Oso2woJSWA" value="IInteractStrategy.NULL_OBJECT"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_mY5LYZaxEey_Oso2woJSWA" name="strat2" visibility="package" type="_AqN_kZaxEey_Oso2woJSWA" association="_mY8Os5axEey_Oso2woJSWA">
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_mY5LYpaxEey_Oso2woJSWA" value="IInteractStrategy.NULL_OBJECT"/>
            </ownedAttribute>
            <interfaceRealization xmi:id="_mY059ZaxEey_Oso2woJSWA" client="_Hsw1QZaxEey_Oso2woJSWA" supplier="_AqN_kZaxEey_Oso2woJSWA" contract="_AqN_kZaxEey_Oso2woJSWA"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_mY6Zk5axEey_Oso2woJSWA" name="MultiInteractStrategy" specification="_mY1hAJaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_mY6ZlJaxEey_Oso2woJSWA" name="strat1" type="_AqN_kZaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mY6ZlZaxEey_Oso2woJSWA" name="strat2" type="_AqN_kZaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mY6ZlpaxEey_Oso2woJSWA" type="_Hsw1QZaxEey_Oso2woJSWA" direction="return"/>
              <language>java</language>
              <body>this.strat1 = strat1;
		this.strat2 = strat2;
	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_mY6Zl5axEey_Oso2woJSWA" name="interactWithThen" specification="_mY1hBpaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_mY6ZmJaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mY6ZmZaxEey_Oso2woJSWA" name="other" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mY6ZmpaxEey_Oso2woJSWA" name="disp" type="_AqSRAZaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mY6Zm5axEey_Oso2woJSWA" type="_AqNYgZaxEey_Oso2woJSWA" direction="return"/>
              <language>java</language>
              <body>IBallCmd cmd1 = this.strat1.interactWithThen(context, other, disp);
		
		IBallCmd cmd2 = this.strat2.interactWithThen(context, other, disp);
		
		return new IBallCmd() {
			
			@Override
			public void apply(IBall context, IDispatcher&lt;IBallCmd> disp) {
				context.update(disp, cmd1);
				context.update(disp, cmd2);
			}
			
		};
	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_mY7AkJaxEey_Oso2woJSWA" name="init" specification="_mY2IE5axEey_Oso2woJSWA">
              <ownedParameter xmi:id="_mY7AkZaxEey_Oso2woJSWA" name="host" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <language>java</language>
              <body>this.strat1.init(host);
		this.strat2.init(host);
	</body>
            </ownedBehavior>
            <ownedOperation xmi:id="_mY1hAJaxEey_Oso2woJSWA" name="MultiInteractStrategy" method="_mY6Zk5axEey_Oso2woJSWA">
              <eAnnotations xmi:id="_mY1hA5axEey_Oso2woJSWA" source="http://www.eclipse.org/uml2/2.0.0/UML">
                <details xmi:id="_mY1hBJaxEey_Oso2woJSWA" key="create"/>
              </eAnnotations>
