            <ownedAttribute xmi:id="_FBoEsJaxEey_Oso2woJSWA" name="NULL_OBJECT" isLeaf="true" isStatic="true" type="_AqPNsZaxEey_Oso2woJSWA" isReadOnly="true" association="_FBvZcZaxEey_Oso2woJSWA">
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_FBorwJaxEey_Oso2woJSWA" value="new IPaintStrategy() {&#xA;&#x9;&#x9;@Override&#xA;&#x9;&#x9;/**&#xA;&#x9;&#x9; * Paint the ball to the screen.&#xA;&#x9;&#x9; * @param g The graphics to paint.&#xA;&#x9;&#x9; * @param host the host ball&#xA;&#x9;&#x9; */&#xA;&#x9;&#x9;public void paint(Graphics g, IBall host) {&#xA;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;@Override&#xA;&#x9;&#x9;/**&#xA;&#x9;&#x9; * @param host -> the host ball.&#xA;&#x9;&#x9; * Initialize the update strategy. This method must be run whenever the ball gets a new strategy.&#xA;&#x9;&#x9; */&#xA;&#x9;&#x9;public void init(IBall host) {&#xA;&#x9;&#x9;}&#xA;&#x9;}"/>
            </ownedAttribute>
