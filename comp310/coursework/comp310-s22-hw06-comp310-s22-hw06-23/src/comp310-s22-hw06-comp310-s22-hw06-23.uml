          <packagedElement xmi:type="uml:Class" xmi:id="_exiYcZaxEey_Oso2woJSWA" name="OverlapUpdateStrategy">
            <ownedComment xmi:id="_9EbIJJaxEey_Oso2woJSWA">
              <body>Strategy that defines an interaction criteria in which the &quot;context&quot; ball and &quot;other&quot; ball have overlapping
radii.

@author Son Nguyen and Smit Viroja
 *</body>
            </ownedComment>
            <interfaceRealization xmi:id="_9EI0Q5axEey_Oso2woJSWA" client="_exiYcZaxEey_Oso2woJSWA" supplier="_AqQb0ZaxEey_Oso2woJSWA" contract="_AqQb0ZaxEey_Oso2woJSWA"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_9EZ6AJaxEey_Oso2woJSWA" name="updateState" specification="_9EI0RJaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9EZ6AZaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9EZ6ApaxEey_Oso2woJSWA" name="dispatcher" type="_AqSRAZaxEey_Oso2woJSWA"/>
              <language>java</language>
              <body>dispatcher.updateAll(new IBallCmd() {
			public void apply(IBall other, IDispatcher&lt;IBallCmd> disp) {
				if (!other.equals(context) &amp;&amp; context.getRadius() + other.getRadius() > (int) context.getLocation().distance(other.getLocation())) {   // check for overlapping radii
			        
					// Save the commands that were generated.   Note that each ball is doing its own interaction behavior/calculations.
					IBallCmd contextPostInteractCmd = context.interactWith(other, disp);
					IBallCmd otherPostInteractCmd = other.interactWith(context, disp);
			        
					// Run the saved commands now that both balls' interaction behaviors are complete.
					context.update(disp, contextPostInteractCmd);
					other.update(disp, otherPostInteractCmd);
				}
			}
		});
	</body>
            </ownedBehavior>
            <ownedOperation xmi:id="_9EI0RJaxEey_Oso2woJSWA" name="updateState" method="_9EZ6AJaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9EI0RZaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9EI0RpaxEey_Oso2woJSWA" name="dispatcher" type="_AqSRAZaxEey_Oso2woJSWA"/>
            </ownedOperation>
            <ownedOperation xmi:id="_9EJbVJaxEey_Oso2woJSWA" name="init">
              <ownedParameter xmi:id="_9EJbVZaxEey_Oso2woJSWA" name="host" type="_Apm7kJaxEey_Oso2woJSWA"/>
            </ownedOperation>
          </packagedElement>
