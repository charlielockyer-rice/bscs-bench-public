            </ownedOperation>
            <ownedOperation xmi:id="_mYuzVJaxEey_Oso2woJSWA" name="calcUnitVec" visibility="package" method="_mY5yeZaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_mYuzVZaxEey_Oso2woJSWA" name="lSource" type="_AqMxcJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mYuzVpaxEey_Oso2woJSWA" name="lTarget" type="_AqMxcJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mYuzV5axEey_Oso2woJSWA" name="distance">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
              </ownedParameter>
              <ownedParameter xmi:id="_mYvaYJaxEey_Oso2woJSWA" type="_mYuzUpaxEey_Oso2woJSWA" direction="return"/>
            </ownedOperation>
            <ownedOperation xmi:id="_mYvaYZaxEey_Oso2woJSWA" name="impulse" visibility="protected" method="_mY5yfpaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_mYvaYpaxEey_Oso2woJSWA" name="normalVec" type="_mYuzUpaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mYvaY5axEey_Oso2woJSWA" name="vSource" type="_AqMxcJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mYvaZJaxEey_Oso2woJSWA" name="vTarget" type="_AqMxcJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mYvaZZaxEey_Oso2woJSWA" name="reducedMass">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
              </ownedParameter>
              <ownedParameter xmi:id="_mYvaZpaxEey_Oso2woJSWA" type="_mYuzUpaxEey_Oso2woJSWA" direction="return"/>
            </ownedOperation>
            <ownedOperation xmi:id="_mYvaZ5axEey_Oso2woJSWA" name="calcNudgeVec" visibility="package" method="_mY5yhJaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_mYvaaJaxEey_Oso2woJSWA" name="normalVec" type="_mYuzUpaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mYvaaZaxEey_Oso2woJSWA" name="minSeparation">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
              </ownedParameter>
              <ownedParameter xmi:id="_mYvaapaxEey_Oso2woJSWA" name="distance">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
              </ownedParameter>
              <ownedParameter xmi:id="_mYvaa5axEey_Oso2woJSWA" type="_AqMxcJaxEey_Oso2woJSWA" direction="return"/>
            </ownedOperation>
            <ownedOperation xmi:id="_mYwBcJaxEey_Oso2woJSWA" name="updateVelocity" visibility="protected" method="_mY5yiZaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_mYwBcZaxEey_Oso2woJSWA" name="aBall" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mYwBcpaxEey_Oso2woJSWA" name="mass">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
              </ownedParameter>
              <ownedParameter xmi:id="_mYwBc5axEey_Oso2woJSWA" name="impulseVec" type="_mYuzUpaxEey_Oso2woJSWA"/>
            </ownedOperation>
            <ownedOperation xmi:id="_mYwBdJaxEey_Oso2woJSWA" name="init">
              <ownedParameter xmi:id="_mYwBdZaxEey_Oso2woJSWA" name="host" type="_Apm7kJaxEey_Oso2woJSWA"/>
            </ownedOperation>
