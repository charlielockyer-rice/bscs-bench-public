              <body>super(at);
		this.pstrats = pstrats;
	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_1S2pRZaxEey_Oso2woJSWA" name="MultiPaintStrategy" specification="_1SbygJaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_1S2pRpaxEey_Oso2woJSWA" name="pstrats" type="_1Q5hcJaxEey_Oso2woJSWA">
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_1S2pR5axEey_Oso2woJSWA" value="*"/>
              </ownedParameter>
              <ownedParameter xmi:id="_1S2pSJaxEey_Oso2woJSWA" type="_1Q8kwJaxEey_Oso2woJSWA" direction="return"/>
              <language>java</language>
              <body>super(new AffineTransform());
		this.pstrats = pstrats;
	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_1S2pSZaxEey_Oso2woJSWA" name="init" specification="_1ScZlJaxEey_Oso2woJSWA">
