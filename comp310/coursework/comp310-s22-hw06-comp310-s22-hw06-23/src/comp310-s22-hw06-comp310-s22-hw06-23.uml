                </ownedParameter>
                <ownedParameter xmi:id="_GZrnYZayEey_Oso2woJSWA" type="_GZeL8JayEey_Oso2woJSWA" direction="return"/>
                <language>java</language>
                <body>return &quot;This is the result from HostA with the text field reading &quot;+(String)params[1];
