            <packagedElement xmi:type="uml:Class" xmi:id="_exswgJaxEey_Oso2woJSWA" name="EarthPaintStrategy">
              <ownedComment xmi:id="_1S6TrZaxEey_Oso2woJSWA">
                <body>A class to paint the custom image contained by the Earth.png file. 
@author Son Nguyen and Cole Rabson
 *</body>
              </ownedComment>
              <generalization xmi:id="_1SigNpaxEey_Oso2woJSWA" general="_1Q6vkJaxEey_Oso2woJSWA"/>
              <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_1S33dZaxEey_Oso2woJSWA" name="EarthPaintStrategy" specification="_1RGVwJaxEey_Oso2woJSWA">
                <ownedParameter xmi:id="_1S33dpaxEey_Oso2woJSWA" type="_exswgJaxEey_Oso2woJSWA" direction="return"/>
                <language>java</language>
                <body>super(new AffineTransform(), &quot;images/Earth.png&quot;, 1);
