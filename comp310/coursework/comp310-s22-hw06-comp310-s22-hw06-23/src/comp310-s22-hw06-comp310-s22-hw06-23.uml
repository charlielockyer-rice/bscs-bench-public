                <ownedParameter xmi:id="_GZrnXpayEey_Oso2woJSWA" name="host" type="_GZXeQpayEey_Oso2woJSWA"/>
                <ownedParameter xmi:id="_GZrnX5ayEey_Oso2woJSWA" name="params" type="_GZeL8JayEey_Oso2woJSWA">
