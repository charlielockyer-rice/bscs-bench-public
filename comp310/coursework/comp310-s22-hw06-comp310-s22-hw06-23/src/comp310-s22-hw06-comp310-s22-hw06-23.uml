            <packagedElement xmi:type="uml:Class" xmi:id="_Lzin8JayEey_Oso2woJSWA" name="RemoveSmallestRevAlgo">
              <ownedComment xmi:id="_L1AnoJayEey_Oso2woJSWA">
                <body>Return a list with the smallest element from the list removed.   
Do this with a single pass through the the list!
The input parameter is not used (&quot;nu&quot;).
@author Son Nguyen and Charlie Lockyer</body>
              </ownedComment>
              <interfaceRealization xmi:id="_L0pbNpayEey_Oso2woJSWA" client="_Lzin8JayEey_Oso2woJSWA" supplier="_L0VSIJayEey_Oso2woJSWA" contract="_L0VSIJayEey_Oso2woJSWA"/>
              <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_L0556ZayEey_Oso2woJSWA" name="emptyCase" specification="_L0qCQJayEey_Oso2woJSWA">
                <ownedParameter xmi:id="_L0556payEey_Oso2woJSWA" name="host" type="_L0V5MJayEey_Oso2woJSWA"/>
                <ownedParameter xmi:id="_L05565ayEey_Oso2woJSWA" name="nu" type="_GZeL8JayEey_Oso2woJSWA">
                  <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_L0557JayEey_Oso2woJSWA" value="*"/>
                </ownedParameter>
                <ownedParameter xmi:id="_L0557ZayEey_Oso2woJSWA" type="_GZeL8JayEey_Oso2woJSWA" direction="return"/>
                <language>java</language>
                <body>return MTList.Singleton;
	</body>
              </ownedBehavior>
              <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_L0557payEey_Oso2woJSWA" name="nonEmptyCase" specification="_L0qCR5ayEey_Oso2woJSWA">
                <ownedParameter xmi:id="_L05575ayEey_Oso2woJSWA" name="host" type="_L0V5MpayEey_Oso2woJSWA"/>
                <ownedParameter xmi:id="_L0558JayEey_Oso2woJSWA" name="nu" type="_GZeL8JayEey_Oso2woJSWA">
                  <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_L0558ZayEey_Oso2woJSWA" value="*"/>
                </ownedParameter>
                <ownedParameter xmi:id="_L0558payEey_Oso2woJSWA" type="_GZeL8JayEey_Oso2woJSWA" direction="return"/>
                <language>java</language>
                <body>if((int)host.getFirst() &lt; getMin(host.getRest())) {
			if (host.getRest().equals( MTList.Singleton))
				return MTList.Singleton;
			return new NEList(((NEList) (host.getRest())).getFirst() , 
					((NEList) (host.getRest())).getRest());
		}else 
			return new NEList(host.getFirst(),(IList)host.getRest().execute(this));

	</body>
              </ownedBehavior>
              <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_L05585ayEey_Oso2woJSWA" name="getMin" specification="_L0qpVJayEey_Oso2woJSWA">
                <ownedParameter xmi:id="_L0559JayEey_Oso2woJSWA" name="host" type="_L0UrEJayEey_Oso2woJSWA"/>
                <ownedParameter xmi:id="_L0559ZayEey_Oso2woJSWA" direction="return">
                  <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
                </ownedParameter>
                <language>java</language>
                <body>if(host == MTList.Singleton)
			return Integer.MAX_VALUE;
		if (((NEList)host).getRest() == MTList.Singleton)
			return (int) ((NEList)host).getFirst();
		else
			return Math.min((int)((NEList)host).getFirst(), getMin(((NEList)host).getRest()));
	</body>
              </ownedBehavior>
