          <packagedElement xmi:type="uml:Class" xmi:id="_9DFEUJaxEey_Oso2woJSWA" name="SameColorUpdateStrategy">
            <ownedComment xmi:id="_9EbIJZaxEey_Oso2woJSWA">
              <body>Strategy that defines an interaction criteria in which in which two balls have similar colors.

@author Son Nguyen and Smit Viroja</body>
            </ownedComment>
            <ownedAttribute xmi:id="_9EXdxJaxEey_Oso2woJSWA" name="threshhold" visibility="private" isLeaf="true" isStatic="true" isReadOnly="true">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_9EXdxZaxEey_Oso2woJSWA" value="100"/>
            </ownedAttribute>
            <interfaceRealization xmi:id="_9EKCYpaxEey_Oso2woJSWA" client="_9DFEUJaxEey_Oso2woJSWA" supplier="_AqQb0ZaxEey_Oso2woJSWA" contract="_AqQb0ZaxEey_Oso2woJSWA"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_9EZ6A5axEey_Oso2woJSWA" name="updateState" specification="_9EKCY5axEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9EZ6BJaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9EZ6BZaxEey_Oso2woJSWA" name="dispatcher" type="_AqSRAZaxEey_Oso2woJSWA"/>
              <language>java</language>
              <body>dispatcher.updateAll(new IBallCmd() {
			public void apply(IBall other, IDispatcher&lt;IBallCmd> disp) {
				if (!other.equals(context) &amp;&amp; colorDistance(context.getColor(),other.getColor()) &lt; threshhold) {   // whatever the interaction criteria is
			        
					// Save the commands that were generated.   Note that each ball is doing its own interaction behavior/calculations.
					IBallCmd contextPostInteractCmd = context.interactWith(other, disp);
					IBallCmd otherPostInteractCmd = other.interactWith(context, disp);
			        
					// Run the saved commands now that both balls' interaction behaviors are complete.
					context.update(disp, contextPostInteractCmd);
					other.update(disp, otherPostInteractCmd);
				}
			}
		});
	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_9EZ6BpaxEey_Oso2woJSWA" name="colorDistance" specification="_9EKpeJaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9EZ6B5axEey_Oso2woJSWA" name="color1" type="_AqJHEJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9EZ6CJaxEey_Oso2woJSWA" name="color2" type="_AqJHEJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9EZ6CZaxEey_Oso2woJSWA" direction="return">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
              </ownedParameter>
              <language>java</language>
              <body>double cDist = Math.sqrt(Math.pow(color1.getRed()-color2.getRed(), 2)+
             Math.pow(color1.getGreen()-color2.getGreen(), 2)+
             Math.pow(color1.getBlue()-color2.getBlue(), 2));
     return cDist;
 </body>
            </ownedBehavior>
            <ownedOperation xmi:id="_9EKCY5axEey_Oso2woJSWA" name="updateState" method="_9EZ6A5axEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9EKCZJaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9EKCZZaxEey_Oso2woJSWA" name="dispatcher" type="_AqSRAZaxEey_Oso2woJSWA"/>
            </ownedOperation>
            <ownedOperation xmi:id="_9EKpc5axEey_Oso2woJSWA" name="init">
              <ownedParameter xmi:id="_9EKpdJaxEey_Oso2woJSWA" name="host" type="_Apm7kJaxEey_Oso2woJSWA"/>
            </ownedOperation>
            <ownedOperation xmi:id="_9EKpeJaxEey_Oso2woJSWA" name="colorDistance" visibility="private" method="_9EZ6BpaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9ELQgJaxEey_Oso2woJSWA" name="color1" type="_AqJHEJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9ELQgZaxEey_Oso2woJSWA" name="color2" type="_AqJHEJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9ELQgpaxEey_Oso2woJSWA" direction="return">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
              </ownedParameter>
            </ownedOperation>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_9DFrYJaxEey_Oso2woJSWA" name="SameSizeUpdateStrategy">
            <ownedComment xmi:id="_9EbIJpaxEey_Oso2woJSWA">
              <body>Strategy that defines an interaction criteria in which in which two balls have similar sizes.

@author Son Nguyen and Smit Viroja</body>
            </ownedComment>
            <ownedAttribute xmi:id="_9EXdxpaxEey_Oso2woJSWA" name="threshhold" visibility="private" isLeaf="true" isStatic="true" isReadOnly="true">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_9EXdx5axEey_Oso2woJSWA" value="5"/>
            </ownedAttribute>
            <interfaceRealization xmi:id="_9ELQg5axEey_Oso2woJSWA" client="_9DFrYJaxEey_Oso2woJSWA" supplier="_AqQb0ZaxEey_Oso2woJSWA" contract="_AqQb0ZaxEey_Oso2woJSWA"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_9EZ6CpaxEey_Oso2woJSWA" name="updateState" specification="_9ELQhJaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9EZ6C5axEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9EZ6DJaxEey_Oso2woJSWA" name="dispatcher" type="_AqSRAZaxEey_Oso2woJSWA"/>
              <language>java</language>
              <body>dispatcher.updateAll(new IBallCmd() {
			public void apply(IBall other, IDispatcher&lt;IBallCmd> disp) {
				if (!other.equals(context) &amp;&amp; Math.abs(context.getRadius()-other.getRadius()) &lt; threshhold) {   // check size difference below threshold
			        // Save the commands that were generated.   Note that each ball is doing its own interaction behavior/calculations.
					IBallCmd contextPostInteractCmd = context.interactWith(other, disp);
					IBallCmd otherPostInteractCmd = other.interactWith(context, disp);
			        
					// Run the saved commands now that both balls' interaction behaviors are complete.
					context.update(disp, contextPostInteractCmd);
					other.update(disp, otherPostInteractCmd);
				}
			}
		});
	</body>
            </ownedBehavior>
            <ownedOperation xmi:id="_9ELQhJaxEey_Oso2woJSWA" name="updateState" method="_9EZ6CpaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9ELQhZaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9ELQhpaxEey_Oso2woJSWA" name="dispatcher" type="_AqSRAZaxEey_Oso2woJSWA"/>
            </ownedOperation>
            <ownedOperation xmi:id="_9EL3k5axEey_Oso2woJSWA" name="init">
              <ownedParameter xmi:id="_9EL3lJaxEey_Oso2woJSWA" name="host" type="_Apm7kJaxEey_Oso2woJSWA"/>
            </ownedOperation>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_9DG5gJaxEey_Oso2woJSWA" name="SameSpeedUpdateStrategy">
            <ownedComment xmi:id="_9EbIJ5axEey_Oso2woJSWA">
              <body>Strategy that defines an interaction criteria in which in which two balls have similar speeds.

@author Son Nguyen and Smit Viroja</body>
            </ownedComment>
            <ownedAttribute xmi:id="_9EYE0JaxEey_Oso2woJSWA" name="threshhold" visibility="private" isLeaf="true" isStatic="true" isReadOnly="true">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_9EYE0ZaxEey_Oso2woJSWA" value="2"/>
            </ownedAttribute>
            <interfaceRealization xmi:id="_9EMeopaxEey_Oso2woJSWA" client="_9DG5gJaxEey_Oso2woJSWA" supplier="_AqQb0ZaxEey_Oso2woJSWA" contract="_AqQb0ZaxEey_Oso2woJSWA"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_9EZ6DZaxEey_Oso2woJSWA" name="updateState" specification="_9EMeo5axEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9EZ6DpaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9EZ6D5axEey_Oso2woJSWA" name="dispatcher" type="_AqSRAZaxEey_Oso2woJSWA"/>
              <language>java</language>
              <body>dispatcher.updateAll(new IBallCmd() {
			public void apply(IBall other, IDispatcher&lt;IBallCmd> disp) {
				double speed1 = context.getVelocity().distance(0,0);
				double speed2 = other.getVelocity().distance(0,0);
				
				if (!other.equals(context) &amp;&amp;  Math.abs(speed1 - speed2) &lt; threshhold) {   // check speed difference below threshold
			        
					// Save the commands that were generated.   Note that each ball is doing its own interaction behavior/calculations.
					IBallCmd contextPostInteractCmd = context.interactWith(other, disp);
					IBallCmd otherPostInteractCmd = other.interactWith(context, disp);
			        
					// Run the saved commands now that both balls' interaction behaviors are complete.
					context.update(disp, contextPostInteractCmd);
					other.update(disp, otherPostInteractCmd);
				}
			}
		});
	</body>
            </ownedBehavior>
            <ownedOperation xmi:id="_9EMeo5axEey_Oso2woJSWA" name="updateState" method="_9EZ6DZaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9EMepJaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9EMepZaxEey_Oso2woJSWA" name="dispatcher" type="_AqSRAZaxEey_Oso2woJSWA"/>
            </ownedOperation>
            <ownedOperation xmi:id="_9ENFs5axEey_Oso2woJSWA" name="init">
              <ownedParameter xmi:id="_9ENFtJaxEey_Oso2woJSWA" name="host" type="_Apm7kJaxEey_Oso2woJSWA"/>
            </ownedOperation>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_9DHgkJaxEey_Oso2woJSWA" name="SameVelocityUpdateStrategy">
            <ownedComment xmi:id="_9EbIKJaxEey_Oso2woJSWA">
              <body>Strategy that defines an interaction criteria in which in which two balls have similar velocities.

@author Son Nguyen and Smit Viroja</body>
            </ownedComment>
            <ownedAttribute xmi:id="_9EYE0paxEey_Oso2woJSWA" name="threshhold" visibility="private" isLeaf="true" isStatic="true" isReadOnly="true">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_9EYE05axEey_Oso2woJSWA" value="5"/>
            </ownedAttribute>
            <interfaceRealization xmi:id="_9ENswpaxEey_Oso2woJSWA" client="_9DHgkJaxEey_Oso2woJSWA" supplier="_AqQb0ZaxEey_Oso2woJSWA" contract="_AqQb0ZaxEey_Oso2woJSWA"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_9EZ6EJaxEey_Oso2woJSWA" name="updateState" specification="_9ENsw5axEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9EZ6EZaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9EZ6EpaxEey_Oso2woJSWA" name="dispatcher" type="_AqSRAZaxEey_Oso2woJSWA"/>
              <language>java</language>
              <body>dispatcher.updateAll(new IBallCmd() {
			public void apply(IBall other, IDispatcher&lt;IBallCmd> disp) {
				if (!other.equals(context) &amp;&amp; context.getVelocity().distance(other.getVelocity()) &lt; threshhold) {   // whatever the interaction criteria is
			        // Save the commands that were generated.   Note that each ball is doing its own interaction behavior/calculations.
					IBallCmd contextPostInteractCmd = context.interactWith(other, disp);
					IBallCmd otherPostInteractCmd = other.interactWith(context, disp);
			        
					// Run the saved commands now that both balls' interaction behaviors are complete.
					context.update(disp, contextPostInteractCmd);
					other.update(disp, otherPostInteractCmd);
				}
			}
		});
	</body>
            </ownedBehavior>
            <ownedOperation xmi:id="_9ENsw5axEey_Oso2woJSWA" name="updateState" method="_9EZ6EJaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9ENsxJaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9ENsxZaxEey_Oso2woJSWA" name="dispatcher" type="_AqSRAZaxEey_Oso2woJSWA"/>
            </ownedOperation>
            <ownedOperation xmi:id="_9EOT05axEey_Oso2woJSWA" name="init">
              <ownedParameter xmi:id="_9EOT1JaxEey_Oso2woJSWA" name="host" type="_Apm7kJaxEey_Oso2woJSWA"/>
            </ownedOperation>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_9DIHoJaxEey_Oso2woJSWA" name="ShrinkingUpdateStrategy">
            <ownedComment xmi:id="_9EbIKZaxEey_Oso2woJSWA">
              <body>Strategy to shrink the ball whenever it hits the wall.
@author Megan Xiao, Son Nguyen</body>
            </ownedComment>
            <ownedAttribute xmi:id="_9EYE1JaxEey_Oso2woJSWA" name="rand" visibility="private" type="_9EO64JaxEey_Oso2woJSWA" association="_9Ec9VJaxEey_Oso2woJSWA">
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_9EYE1ZaxEey_Oso2woJSWA" value="new Random()"/>
            </ownedAttribute>
            <interfaceRealization xmi:id="_9EO64paxEey_Oso2woJSWA" client="_9DIHoJaxEey_Oso2woJSWA" supplier="_AqQb0ZaxEey_Oso2woJSWA" contract="_AqQb0ZaxEey_Oso2woJSWA"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_9EZ6E5axEey_Oso2woJSWA" name="updateState" specification="_9EPh8JaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9EZ6FJaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9EZ6FZaxEey_Oso2woJSWA" name="disp" type="_AqSRAZaxEey_Oso2woJSWA"/>
              <language>java</language>
              <body>if (context.getRadius() &lt;= 5) {
			disp.removeObserver(context);
		}

		// shrink by a random amount (1-10) every time the ball hits a wall
		if (context.hitLeftWall() || context.hitTopWall() || context.hitRightWall() || context.hitBottomWall()) {
			context.setRadius(context.getRadius() - (rand.nextInt(10) + 1));
		}

	</body>
            </ownedBehavior>
            <ownedOperation xmi:id="_9EPh8JaxEey_Oso2woJSWA" name="updateState" method="_9EZ6E5axEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9EPh8ZaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9EPh8paxEey_Oso2woJSWA" name="disp" type="_AqSRAZaxEey_Oso2woJSWA"/>
            </ownedOperation>
            <ownedOperation xmi:id="_9EPh95axEey_Oso2woJSWA" name="init">
              <ownedParameter xmi:id="_9EQJAJaxEey_Oso2woJSWA" name="host" type="_Apm7kJaxEey_Oso2woJSWA"/>
            </ownedOperation>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_9DIusJaxEey_Oso2woJSWA" name="SplittingUpdateStrategy">
            <ownedComment xmi:id="_9EbIKpaxEey_Oso2woJSWA">
              <body>Strategy for the balls to split in half periodically.
@author Megan Xiao, Son Nguyen</body>
            </ownedComment>
            <interfaceRealization xmi:id="_9EQJBJaxEey_Oso2woJSWA" client="_9DIusJaxEey_Oso2woJSWA" supplier="_AqQb0ZaxEey_Oso2woJSWA" contract="_AqQb0ZaxEey_Oso2woJSWA"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_9EahEJaxEey_Oso2woJSWA" name="updateState" specification="_9EQwEJaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9EahEZaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9EahEpaxEey_Oso2woJSWA" name="disp" type="_AqSRAZaxEey_Oso2woJSWA"/>
              <language>java</language>
              <body>if (context.getCount() % 60 == 0) {
			String classname = context.getClass().toString().substring(6);
			IObjectLoader&lt;IObserver&lt;IBallCmd>> maker = new ObjectLoader&lt;IObserver&lt;IBallCmd>>(null);
			IObserver&lt;IBallCmd> child = maker.loadInstance(classname, context.getLocation(), context.getRadius() / 2,
					new Point(-context.getVelocity().x, -context.getVelocity().y), context.getRandGen().randomColor(),
					context.getContainer(), 
					new AConfigBallAlgo(ILoggerControl.getSharedLogger(), &quot;Splitting Strategy&quot;, IBallAlgo2ModelAdapter.NULL, new ABallAlgoCmd&lt;>() {
						/**
						 * Auto generated serial
						 */
						private static final long serialVersionUID = -7707661235581724657L;
						@Override
						public Void apply(IBallHostID index, IBall host, Void... params) {
							host.setPaintStrategy(context.getPaintStrategy());
							host.setUpdateStrategy(context.getUpdateStrategy());
							host.setInteractStrategy(context.getInteractStrategy());
							return null;
						}
					}) {
						/**
						 * Auto generated serial
						 */
						private static final long serialVersionUID = 1L;
						
					});
			context.setColor(context.getRandGen().randomColor());
			context.setRadius(context.getRadius() / 2);
			disp.addObserver(child);
		}
		if (context.getRadius() &lt;= 5) {
			disp.removeObserver(context);
		}
	</body>
            </ownedBehavior>
            <ownedOperation xmi:id="_9EQwEJaxEey_Oso2woJSWA" name="updateState" method="_9EahEJaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9EQwEZaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9EQwEpaxEey_Oso2woJSWA" name="disp" type="_AqSRAZaxEey_Oso2woJSWA"/>
            </ownedOperation>
            <ownedOperation xmi:id="_9EQwF5axEey_Oso2woJSWA" name="init">
              <ownedParameter xmi:id="_9ERXIJaxEey_Oso2woJSWA" name="host" type="_Apm7kJaxEey_Oso2woJSWA"/>
            </ownedOperation>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_9DLK8JaxEey_Oso2woJSWA" name="TeleportUpdateStrategy">
            <ownedComment xmi:id="_9EbIL5axEey_Oso2woJSWA">
              <body>Strategy for the balls to teleport to a new random location when it hits the wall.
@author Cole Rabson, Son Nguyen</body>
            </ownedComment>
            <interfaceRealization xmi:id="_9ETzYpaxEey_Oso2woJSWA" client="_9DLK8JaxEey_Oso2woJSWA" supplier="_AqQb0ZaxEey_Oso2woJSWA" contract="_AqQb0ZaxEey_Oso2woJSWA"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_9EahGpaxEey_Oso2woJSWA" name="updateState" specification="_9ETzY5axEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9EahG5axEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9EahHJaxEey_Oso2woJSWA" name="disp" type="_AqSRAZaxEey_Oso2woJSWA"/>
              <language>java</language>
              <body>if (context.hitLeftWall() || context.hitTopWall() || context.hitRightWall() || context.hitBottomWall()) {
			//Randomize Velocity and Spawn at center of the canvas
			Point center = new Point(context.getContainer().getWidth() / 2, context.getContainer().getHeight() / 2);
			Point velocity = context.getRandGen().randomVel(new Rectangle(20, 20));
			context.setLocation(center);
			context.setVelocity(velocity);
		}

	</body>
            </ownedBehavior>
            <ownedOperation xmi:id="_9ETzY5axEey_Oso2woJSWA" name="updateState" method="_9EahGpaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9ETzZJaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9ETzZZaxEey_Oso2woJSWA" name="disp" type="_AqSRAZaxEey_Oso2woJSWA"/>
            </ownedOperation>
            <ownedOperation xmi:id="_9EUac5axEey_Oso2woJSWA" name="init">
              <ownedParameter xmi:id="_9EUadJaxEey_Oso2woJSWA" name="host" type="_Apm7kJaxEey_Oso2woJSWA"/>
            </ownedOperation>
          </packagedElement>
