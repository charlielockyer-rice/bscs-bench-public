              <ownedComment xmi:id="_GZs1fJayEey_Oso2woJSWA">
                <body>A visitor that returns a String that says &quot;This is the result from HostX,
where HostX is the type of the IHost object executing this visitor. 
@author swong
 *</body>
              </ownedComment>
              <interfaceRealization xmi:id="_GZezAJayEey_Oso2woJSWA" client="_GYy2gJayEey_Oso2woJSWA" supplier="_GZYFU5ayEey_Oso2woJSWA" contract="_GZYFU5ayEey_Oso2woJSWA"/>
