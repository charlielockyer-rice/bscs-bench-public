            <ownedAttribute xmi:id="_1Sy-4ZaxEey_Oso2woJSWA" name="pstrats" visibility="private" type="_1Q5hcJaxEey_Oso2woJSWA" association="_1S_MIJaxEey_Oso2woJSWA">
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_1Sy-4paxEey_Oso2woJSWA" value="*"/>
            </ownedAttribute>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_1S2pQJaxEey_Oso2woJSWA" name="MultiPaintStrategy" specification="_1Sp08JaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_1S2pQZaxEey_Oso2woJSWA" name="at" type="_1SUdwJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_1S2pQpaxEey_Oso2woJSWA" name="pstrats" type="_1Q5hcJaxEey_Oso2woJSWA">
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_1S2pQ5axEey_Oso2woJSWA" value="*"/>
              </ownedParameter>
              <ownedParameter xmi:id="_1S2pRJaxEey_Oso2woJSWA" type="_1Q8kwJaxEey_Oso2woJSWA" direction="return"/>
