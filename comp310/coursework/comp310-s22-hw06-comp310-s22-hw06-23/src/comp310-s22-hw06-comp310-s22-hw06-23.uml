          <packagedElement xmi:type="uml:Class" xmi:id="_9DBZ8JaxEey_Oso2woJSWA" name="GravityUpdateStrategy">
            <ownedComment xmi:id="_9EbIIZaxEey_Oso2woJSWA">
              <body>Strategy for the ball to bounce like how it would if down is the ground.
@author Cole Rabson, Son Nguyen</body>
            </ownedComment>
            <interfaceRealization xmi:id="_9EFJ45axEey_Oso2woJSWA" client="_9DBZ8JaxEey_Oso2woJSWA" supplier="_AqQb0ZaxEey_Oso2woJSWA" contract="_AqQb0ZaxEey_Oso2woJSWA"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_9EZS85axEey_Oso2woJSWA" name="updateState" specification="_9EFJ5JaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9EZS9JaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9EZS9ZaxEey_Oso2woJSWA" name="disp" type="_AqSRAZaxEey_Oso2woJSWA"/>
              <language>java</language>
              <body>if (!(context.hitLeftWall() || context.hitTopWall() || context.hitRightWall() || context.hitBottomWall()))
			context.setVelocity(new Point(context.getVelocity().x, context.getVelocity().y + 9));

	</body>
            </ownedBehavior>
            <ownedOperation xmi:id="_9EFJ5JaxEey_Oso2woJSWA" name="updateState" method="_9EZS85axEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9EFJ5ZaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9EFJ5paxEey_Oso2woJSWA" name="disp" type="_AqSRAZaxEey_Oso2woJSWA"/>
            </ownedOperation>
            <ownedOperation xmi:id="_9EFw85axEey_Oso2woJSWA" name="init">
              <ownedParameter xmi:id="_9EFw9JaxEey_Oso2woJSWA" name="host" type="_Apm7kJaxEey_Oso2woJSWA"/>
            </ownedOperation>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_9DCBAJaxEey_Oso2woJSWA" name="JitteryUpdateStrategy">
            <ownedComment xmi:id="_9EbIIpaxEey_Oso2woJSWA">
              <body>Strategy for the ball to jitter horizontally
@author Megan Xiao, Son Nguyen
 *</body>
            </ownedComment>
            <interfaceRealization xmi:id="_9EGYAJaxEey_Oso2woJSWA" client="_9DCBAJaxEey_Oso2woJSWA" supplier="_AqQb0ZaxEey_Oso2woJSWA" contract="_AqQb0ZaxEey_Oso2woJSWA"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_9EZS9paxEey_Oso2woJSWA" name="updateState" specification="_9EGYAZaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9EZS95axEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9EZS-JaxEey_Oso2woJSWA" name="disp" type="_AqSRAZaxEey_Oso2woJSWA"/>
              <language>java</language>
              <body>context.setVelocity(new Point(-context.getVelocity().x, context.getVelocity().y)); // constantly flips direction of velocity
	</body>
            </ownedBehavior>
            <ownedOperation xmi:id="_9EGYAZaxEey_Oso2woJSWA" name="updateState" method="_9EZS9paxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9EGYApaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9EGYA5axEey_Oso2woJSWA" name="disp" type="_AqSRAZaxEey_Oso2woJSWA"/>
