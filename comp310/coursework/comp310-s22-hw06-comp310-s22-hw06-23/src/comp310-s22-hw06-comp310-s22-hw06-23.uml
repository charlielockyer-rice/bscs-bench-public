            <body>comboBoxMake.insertItemAt(o, 0);
		comboBoxMake.setSelectedIndex(0);
		comboBoxCombine.insertItemAt(o, 0);
		comboBoxCombine.setSelectedIndex(0);
	</body>
          </ownedBehavior>
