            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_1S3QYJaxEey_Oso2woJSWA" name="paintCfg" specification="_1Se115axEey_Oso2woJSWA">
              <ownedParameter xmi:id="_1S3QYZaxEey_Oso2woJSWA" name="g" type="_AqLjUZaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_1S3QYpaxEey_Oso2woJSWA" name="host" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <language>java</language>
              <body>super.paintCfg(g, host);
		if (Math.abs(Math.atan2(host.getVelocity().y, host.getVelocity().x)) > Math.PI / 2.0) {
			at.scale(1.0, -1.0);
		}
	</body>
            </ownedBehavior>
