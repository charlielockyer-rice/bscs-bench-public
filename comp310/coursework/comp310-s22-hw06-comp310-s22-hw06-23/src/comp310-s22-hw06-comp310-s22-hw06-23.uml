          <packagedElement xmi:type="uml:Class" xmi:id="_exlbwJaxEey_Oso2woJSWA" name="AInteractStrategy" isAbstract="true">
            <ownedComment xmi:id="_mY7Al5axEey_Oso2woJSWA">
              <body>@author phuso
 *</body>
            </ownedComment>
            <interfaceRealization xmi:id="_mYrwAJaxEey_Oso2woJSWA" client="_exlbwJaxEey_Oso2woJSWA" supplier="_AqN_kZaxEey_Oso2woJSWA" contract="_AqN_kZaxEey_Oso2woJSWA"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_mY5LZJaxEey_Oso2woJSWA" name="interactWithThen" specification="_mYsXEJaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_mY5LZZaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mY5LZpaxEey_Oso2woJSWA" name="other" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mY5LZ5axEey_Oso2woJSWA" name="disp" type="_AqSRAZaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mY5LaJaxEey_Oso2woJSWA" type="_AqNYgZaxEey_Oso2woJSWA" direction="return"/>
              <language>java</language>
              <body>interact(context, other, disp);
		return new IBallCmd() {
			@Override
			public void apply(IBall context, IDispatcher&lt;IBallCmd> disp) {
			}
		};
	</body>
            </ownedBehavior>
            <ownedOperation xmi:id="_mYsXEJaxEey_Oso2woJSWA" name="interactWithThen" method="_mY5LZJaxEey_Oso2woJSWA">
