@author Cole Rabson and Son Nguyen.</body>
            </ownedComment>
            <interfaceRealization xmi:id="_9ED7wJaxEey_Oso2woJSWA" client="_exhxY5axEey_Oso2woJSWA" supplier="_AqQb0ZaxEey_Oso2woJSWA" contract="_AqQb0ZaxEey_Oso2woJSWA"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_9EZS8JaxEey_Oso2woJSWA" name="updateState" specification="_9ED7wZaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9EZS8ZaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9EZS8paxEey_Oso2woJSWA" name="disp" type="_AqSRAZaxEey_Oso2woJSWA"/>
