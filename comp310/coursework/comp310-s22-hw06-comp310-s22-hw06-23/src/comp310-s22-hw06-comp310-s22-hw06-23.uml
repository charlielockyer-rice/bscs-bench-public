            <ownedOperation xmi:id="_9ED7wZaxEey_Oso2woJSWA" name="updateState" method="_9EZS8JaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9ED7wpaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
