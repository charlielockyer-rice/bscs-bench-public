        <packagedElement xmi:type="uml:Package" xmi:id="_ApNS8JaxEey_Oso2woJSWA" name="paint">
          <packagedElement xmi:type="uml:Package" xmi:id="_HrRAcJaxEey_Oso2woJSWA" name="strategy">
            <packagedElement xmi:type="uml:Class" xmi:id="_HsxcUJaxEey_Oso2woJSWA" name="BallPaintStrategy">
              <ownedComment xmi:id="_1S6TrJaxEey_Oso2woJSWA">
                <body>Paint strategy that paints a filled Ball with the Ball's radius.
@author Son Nguyen and Cole Rabson</body>
              </ownedComment>
              <interfaceRealization xmi:id="_1Sh5IpaxEey_Oso2woJSWA" client="_HsxcUJaxEey_Oso2woJSWA" supplier="_AqPNsZaxEey_Oso2woJSWA" contract="_AqPNsZaxEey_Oso2woJSWA"/>
              <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_1S33cpaxEey_Oso2woJSWA" name="paint" specification="_1SigMJaxEey_Oso2woJSWA">
                <ownedParameter xmi:id="_1S33c5axEey_Oso2woJSWA" name="g" type="_AqLjUZaxEey_Oso2woJSWA"/>
                <ownedParameter xmi:id="_1S33dJaxEey_Oso2woJSWA" name="host" type="_Apm7kJaxEey_Oso2woJSWA"/>
                <language>java</language>
                <body>int halfSide = host.getRadius();
		g.setColor(host.getColor());
		g.fillOval(host.getLocation().x - halfSide, host.getLocation().y - halfSide, 2 * halfSide, 2 * halfSide);
	</body>
              </ownedBehavior>
