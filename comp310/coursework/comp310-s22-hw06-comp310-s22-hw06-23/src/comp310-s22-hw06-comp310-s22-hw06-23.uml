            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_GZrAQpayEey_Oso2woJSWA" name="VisitorDemoApp" specification="_GYvMJJayEey_Oso2woJSWA">
              <ownedParameter xmi:id="_GZrAQ5ayEey_Oso2woJSWA" name="closeAction">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
              </ownedParameter>
              <ownedParameter xmi:id="_GZrARJayEey_Oso2woJSWA" type="_GYulEJayEey_Oso2woJSWA" direction="return"/>
              <language>java</language>
              <body>view = new DemoFrame&lt;IHost>(closeAction, new IModelAdapter&lt;IHost>() {

			@Override
			public IHost[] getHosts() {
				return model.getHosts();
			}

			@Override
			public String run(IHost host, String visitorClassname, String input_param) {
				return (String) model.run(host, visitorClassname, input_param);
			}

			@Override
			public void paint(Graphics g) {
				model.paint(g);
			}
			
		});
		
		model = new VisitorDemoModel(new IViewAdapter() {

			@Override
			public void repaint() {
				view.repaint();			
			}

			
		});
	</body>
            </ownedBehavior>
