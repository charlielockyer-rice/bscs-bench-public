              <body>Strategy for the balls to changes it velocity randomly.
@author Megan Xiao, Son Nguyen</body>
            </ownedComment>
            <interfaceRealization xmi:id="_9EVBgJaxEey_Oso2woJSWA" client="_exiYc5axEey_Oso2woJSWA" supplier="_AqQb0ZaxEey_Oso2woJSWA" contract="_AqQb0ZaxEey_Oso2woJSWA"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_9EahHZaxEey_Oso2woJSWA" name="updateState" specification="_9EVBgZaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_9EahHpaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_9EahH5axEey_Oso2woJSWA" name="disp" type="_AqSRAZaxEey_Oso2woJSWA"/>
              <language>java</language>
              <body>if (context.getCount() % 30 == 0 )
			context.setVelocity(context.getRandGen().randomVel(new Rectangle(15, 15)));

	</body>
            </ownedBehavior>
            <ownedOperation xmi:id="_9EVBgZaxEey_Oso2woJSWA" name="updateState" method="_9EahHZaxEey_Oso2woJSWA">
