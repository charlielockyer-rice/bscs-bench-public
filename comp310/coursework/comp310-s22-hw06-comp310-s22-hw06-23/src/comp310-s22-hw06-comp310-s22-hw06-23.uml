          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_HtSZsJaxEey_Oso2woJSWA" name="update" specification="_Hs2U0ZaxEey_Oso2woJSWA">
            <ownedParameter xmi:id="_HtSZsZaxEey_Oso2woJSWA" name="cmd" type="_AqNYgZaxEey_Oso2woJSWA"/>
            <language>java</language>
            <body>myDispatcher.updateAll(cmd); // The Graphics object is being given to all the sprites (Observers)
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_HtSZspaxEey_Oso2woJSWA" name="makeBall" specification="_Hs274ZaxEey_Oso2woJSWA">
            <ownedParameter xmi:id="_HtSZs5axEey_Oso2woJSWA" name="algo" type="_Cx4PoJaxEey_Oso2woJSWA"/>
            <ownedParameter xmi:id="_HtSZtJaxEey_Oso2woJSWA" name="classname">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
            </ownedParameter>
            <language>java</language>
            <body>//Randomizing the initialization
		this.className = &quot;hw06.model.BallHosts.&quot;+classname+&quot;Ball&quot;;
		int canvas_height = viewCtrlAdpt.getCanvas().getHeight();
		int canvas_width = viewCtrlAdpt.getCanvas().getWidth();
		int radius = rand.randomInt(30, Math.min(Math.min(canvas_height / 4, canvas_width / 4),50));
		Point center = rand.randomLoc(new Rectangle(radius * 5 / 4, radius * 5 / 4, canvas_width - radius * 5 / 2,
				canvas_height - radius * 5 / 2));
		Point velocity = rand.randomVel(new Rectangle(20, 20));
		Color color = rand.randomColor();
		//Make the ball on screen by a maker Object loader.
		IObjectLoader&lt;IObserver&lt;IBallCmd>> maker = new ObjectLoader&lt;IObserver&lt;IBallCmd>>(null);
		IObserver&lt;IBallCmd> ball = maker.loadInstance(this.className, center, radius, velocity, color,
				viewCtrlAdpt.getCanvas(), algo);
		myDispatcher.addObserver(ball);
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_HtSZtZaxEey_Oso2woJSWA" name="clearBalls" specification="_HruTcJaxEey_Oso2woJSWA">
            <language>java</language>
            <body>myDispatcher.removeAllObservers();
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_HtTAwJaxEey_Oso2woJSWA" name="makeUpdateStrategyAlgo" specification="_Hru6gJaxEey_Oso2woJSWA">
            <ownedParameter xmi:id="_HtTAwZaxEey_Oso2woJSWA" name="classname">
              <eAnnotations xmi:id="_HtTAwpaxEey_Oso2woJSWA" source="http://www.eclipse.org/uml2/2.0.0/UML">
                <details xmi:id="_HtTAw5axEey_Oso2woJSWA" key="final"/>
              </eAnnotations>
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
            </ownedParameter>
            <ownedParameter xmi:id="_HtTAxJaxEey_Oso2woJSWA" type="_Cx4PoJaxEey_Oso2woJSWA" direction="return"/>
            <language>java</language>
            <body>return new AConfigBallAlgo(logger, classname, algo2ModelAdpt, new ABallAlgoCmd&lt;Void, Void>() {
			
		    /**
			 * Auto-generate the serialVersionUID field and its unique value 
			 */
			private static final long serialVersionUID = 1L;				
			@Override
			public Void apply(IBallHostID index, IBall host, Void... params) {
				host.setUpdateStrategy(
						new MultiUpdateStrategy(host.getUpdateStrategy(), loadUpdateStrategy(classname)));
				return null; // Must return null
			}

		}) {
			/**
			 * Auto-generate the serialVersionUID field and its unique value 
			 */
			private static final long serialVersionUID = 1L;
			
		};
				
				
//				new IBallAlgo() {
//
//			public void caseDefault(IBall host) {
//				// Create composite with existing strategy.  
//				// A named composite class is used here but an anonymous inner class would work too.
//				// loadUpdateStrategy() expands the shortened name and uses an IObjectLoader to load it.
//
//				// Should be different to deal with composites? look at example code where it is MultiUpdateStrategy.
//				host.setUpdateStrategy(
//						new MultiUpdateStrategy(host.getUpdateStrategy(), loadUpdateStrategy(classname)));
//			}
//
//			/**
//			 * Return the given class name string
//			 */
//			public String toString() {
//				return classname;
//			}
//
//		};
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_HtTAxZaxEey_Oso2woJSWA" name="loadUpdateStrategy" specification="_HrwIoJaxEey_Oso2woJSWA">
            <ownedParameter xmi:id="_HtTAxpaxEey_Oso2woJSWA" name="classname">
              <eAnnotations xmi:id="_HtTAx5axEey_Oso2woJSWA" source="http://www.eclipse.org/uml2/2.0.0/UML">
                <details xmi:id="_HtTAyJaxEey_Oso2woJSWA" key="final"/>
              </eAnnotations>
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
            </ownedParameter>
            <ownedParameter xmi:id="_HtTAyZaxEey_Oso2woJSWA" type="_AqQb0ZaxEey_Oso2woJSWA" direction="return"/>
            <language>java</language>
            <body>String className = &quot;hw06.model.updateStrategy.&quot; + classname + &quot;UpdateStrategy&quot;;
		//Make the ball on screen by a maker Object loader.
		IObjectLoader&lt;IUpdateStrategy> maker = new ObjectLoader&lt;IUpdateStrategy>((params) -> IUpdateStrategy.ERROR);
		IUpdateStrategy updateStrategy = maker.loadInstance(className);
		return updateStrategy;
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_HtTAypaxEey_Oso2woJSWA" name="loadPaintStrategy" specification="_HrwvsJaxEey_Oso2woJSWA">
