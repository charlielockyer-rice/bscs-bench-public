          <packagedElement xmi:type="uml:Class" xmi:id="_exhKUJaxEey_Oso2woJSWA" name="CollideInteractStrategy">
            <ownedComment xmi:id="_mY7AmJaxEey_Oso2woJSWA">
              <body>Interaction strategy for the ball to elastically collide with another ball (once a given interaction criteria is met between the balls).
A &quot;nudge&quot; factor is added to allow a realistic collision in a discrete-time environment.

@author Son Nguyen and Smit Viroja</body>
            </ownedComment>
            <ownedAttribute xmi:id="_mY4kUJaxEey_Oso2woJSWA" name="NudgeFactor" visibility="private" isLeaf="true" isStatic="true" isReadOnly="true">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_mY4kUZaxEey_Oso2woJSWA" value="1.4"/>
            </ownedAttribute>
            <interfaceRealization xmi:id="_mYtlM5axEey_Oso2woJSWA" client="_exhKUJaxEey_Oso2woJSWA" supplier="_AqN_kZaxEey_Oso2woJSWA" contract="_AqN_kZaxEey_Oso2woJSWA"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_mY5ycJaxEey_Oso2woJSWA" name="interactWithThen" specification="_mYuMQJaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_mY5ycZaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mY5ycpaxEey_Oso2woJSWA" name="other" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mY5yc5axEey_Oso2woJSWA" name="disp" type="_AqSRAZaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mY5ydJaxEey_Oso2woJSWA" type="_AqNYgZaxEey_Oso2woJSWA" direction="return"/>
              <language>java</language>
              <body>Point nudge = calcNudgeVec(calcUnitVec(context.getLocation(), other.getLocation(), context.getLocation().distance(other.getLocation())),
				context.getRadius() + other.getRadius(), context.getLocation().distance(other.getLocation()));
		
		// calculate reduced mass
		double reduceMass = reducedMass(Math.pow(context.getRadius(), 2), Math.pow(other.getRadius(), 2));
		
		// shift the context ball by the nudge factor
		context.setLocation(new Point(context.getLocation().x + nudge.x, context.getLocation().y + nudge.y));
		
		// calculate the impulse of the collision
		Point2D.Double impulse = impulse(
			calcUnitVec(context.getLocation() , other.getLocation(), context.getLocation().distance(other.getLocation())),
			context.getVelocity(),
			other.getVelocity(),
			reduceMass);
		
		// change the context ball's velocity, given the impulse vector
		return new IBallCmd() {
			@Override
			public void apply(IBall context, IDispatcher&lt;IBallCmd> disp) {
				updateVelocity(context, Math.pow(context.getRadius(), 2), impulse);
			}
			
		};
	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_mY5ydZaxEey_Oso2woJSWA" name="reducedMass" specification="_mYDd4JaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_mY5ydpaxEey_Oso2woJSWA" name="mSource">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
              </ownedParameter>
              <ownedParameter xmi:id="_mY5yd5axEey_Oso2woJSWA" name="mTarget">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
              </ownedParameter>
              <ownedParameter xmi:id="_mY5yeJaxEey_Oso2woJSWA" direction="return">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
              </ownedParameter>
              <language>java</language>
              <body>if (mSource == Double.POSITIVE_INFINITY)
			return mTarget;
		if (mTarget == Double.POSITIVE_INFINITY)
			return mSource;
		else
			return (mSource * mTarget) / (mSource + mTarget);
	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_mY5yeZaxEey_Oso2woJSWA" name="calcUnitVec" specification="_mYuzVJaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_mY5yepaxEey_Oso2woJSWA" name="lSource" type="_AqMxcJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mY5ye5axEey_Oso2woJSWA" name="lTarget" type="_AqMxcJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mY5yfJaxEey_Oso2woJSWA" name="distance">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
              </ownedParameter>
              <ownedParameter xmi:id="_mY5yfZaxEey_Oso2woJSWA" type="_mYuzUpaxEey_Oso2woJSWA" direction="return"/>
              <language>java</language>
              <body>// Calculate the normalized vector, from source to target
		double nx = ((double) (lTarget.x - lSource.x)) / distance;
		double ny = ((double) (lTarget.y - lSource.y)) / distance;	
		
		return new Point2D.Double(nx, ny);
	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_mY5yfpaxEey_Oso2woJSWA" name="impulse" specification="_mYvaYZaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_mY5yf5axEey_Oso2woJSWA" name="normalVec" type="_mYuzUpaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mY5ygJaxEey_Oso2woJSWA" name="vSource" type="_AqMxcJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mY5ygZaxEey_Oso2woJSWA" name="vTarget" type="_AqMxcJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mY5ygpaxEey_Oso2woJSWA" name="reducedMass">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
              </ownedParameter>
              <ownedParameter xmi:id="_mY5yg5axEey_Oso2woJSWA" type="_mYuzUpaxEey_Oso2woJSWA" direction="return"/>
              <language>java</language>
              <body>// Get the coordinates of the unit vector from source to target
		double nx = normalVec.getX(); //((double) (lTarget.x - lSource.x)) / distance;
		double ny = normalVec.getY();  //((double) (lTarget.y - lSource.y)) / distance;
	
		// delta velocity (speed, actually) in normal direction (perpendicular to the plane of interaction, 
		// i.e. in the direction from the source location to the target location
		double dvn = (vTarget.x - vSource.x) * nx + (vTarget.y - vSource.y)* ny;
	
		// Impulse is the change in speed times twice the reduced mass in the normal direction
		return new Point2D.Double(2.0 * reducedMass * dvn * nx, 2.0
				* reducedMass * dvn * ny);
	
	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_mY5yhJaxEey_Oso2woJSWA" name="calcNudgeVec" specification="_mYvaZ5axEey_Oso2woJSWA">
              <ownedParameter xmi:id="_mY5yhZaxEey_Oso2woJSWA" name="normalVec" type="_mYuzUpaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mY5yhpaxEey_Oso2woJSWA" name="minSeparation">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
              </ownedParameter>
              <ownedParameter xmi:id="_mY5yh5axEey_Oso2woJSWA" name="distance">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
              </ownedParameter>
              <ownedParameter xmi:id="_mY5yiJaxEey_Oso2woJSWA" type="_AqMxcJaxEey_Oso2woJSWA" direction="return"/>
              <language>java</language>
              <body>// The minimum allowed separation(sum of the ball radii) minus the actual separation(distance between ball centers). Should be a
		// positive value.  This is the amount of overlap of the balls as measured along the line between their centers.
		double deltaR =  minSeparation - distance;	
		
		// Calc the amount to move the source ball beyond collision range of the target ball, along
		// the normal direction.
		return new Point((int) Math.ceil(-normalVec.getX() * deltaR * NudgeFactor),
				(int) Math.ceil(-normalVec.getY() * deltaR * NudgeFactor));
	
	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_mY5yiZaxEey_Oso2woJSWA" name="updateVelocity" specification="_mYwBcJaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_mY5yipaxEey_Oso2woJSWA" name="aBall" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mY5yi5axEey_Oso2woJSWA" name="mass">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
              </ownedParameter>
              <ownedParameter xmi:id="_mY5yjJaxEey_Oso2woJSWA" name="impulseVec" type="_mYuzUpaxEey_Oso2woJSWA"/>
              <language>java</language>
              <body>aBall.getVelocity().translate((int) Math.round(impulseVec.getX() / mass),(int) Math.round(impulseVec.getY() / mass));
	</body>
            </ownedBehavior>
            <ownedOperation xmi:id="_mYDd4JaxEey_Oso2woJSWA" name="reducedMass" visibility="protected" method="_mY5ydZaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_mYDd4ZaxEey_Oso2woJSWA" name="mSource">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
              </ownedParameter>
              <ownedParameter xmi:id="_mYDd4paxEey_Oso2woJSWA" name="mTarget">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
              </ownedParameter>
              <ownedParameter xmi:id="_mYDd45axEey_Oso2woJSWA" direction="return">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
              </ownedParameter>
            </ownedOperation>
            <ownedOperation xmi:id="_mYuMQJaxEey_Oso2woJSWA" name="interactWithThen" method="_mY5ycJaxEey_Oso2woJSWA">
              <ownedParameter xmi:id="_mYuMQZaxEey_Oso2woJSWA" name="context" type="_Apm7kJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_mYuMQpaxEey_Oso2woJSWA" name="other" type="_Apm7kJaxEey_Oso2woJSWA"/>
