          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_HtTn35axEey_Oso2woJSWA" name="combineStrategyAlgos" specification="_Hs4KBZaxEey_Oso2woJSWA">
            <ownedParameter xmi:id="_HtUO4JaxEey_Oso2woJSWA" name="algo1" type="_Cx4PoJaxEey_Oso2woJSWA">
              <eAnnotations xmi:id="_HtUO4ZaxEey_Oso2woJSWA" source="http://www.eclipse.org/uml2/2.0.0/UML">
                <details xmi:id="_HtUO4paxEey_Oso2woJSWA" key="final"/>
              </eAnnotations>
            </ownedParameter>
            <ownedParameter xmi:id="_HtUO45axEey_Oso2woJSWA" name="algo2" type="_Cx4PoJaxEey_Oso2woJSWA">
              <eAnnotations xmi:id="_HtUO5JaxEey_Oso2woJSWA" source="http://www.eclipse.org/uml2/2.0.0/UML">
                <details xmi:id="_HtUO5ZaxEey_Oso2woJSWA" key="final"/>
              </eAnnotations>
            </ownedParameter>
            <ownedParameter xmi:id="_HtUO5paxEey_Oso2woJSWA" type="_Cx4PoJaxEey_Oso2woJSWA" direction="return"/>
            <language>java</language>
            <body>return new AConfigBallAlgo(logger, algo1.toString() + &quot;-&quot; + algo2.toString(), algo2ModelAdpt, new ABallAlgoCmd&lt;>() {
			
		    // Let Eclipse Quick Fix auto-generate the serialVersionUID field and its unique value 
						
			/**
			 * 
			 */
			private static final long serialVersionUID = 1L;
			@Override
			public Void apply(IBallHostID index, IBall host, Void... params) {
				host.execute(algo1);
				host.execute(algo2);
				return null; // Must return null
			}
		}) {

			/**
			 * 
			 */
			private static final long serialVersionUID = 1L;
			
		};
		
