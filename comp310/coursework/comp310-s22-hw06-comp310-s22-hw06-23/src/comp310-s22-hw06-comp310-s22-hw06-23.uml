              <ownedParameter xmi:id="_WpcP-JaxEey_Oso2woJSWA" name="color" type="_AqJHEJaxEey_Oso2woJSWA"/>
              <ownedParameter xmi:id="_WpcP-ZaxEey_Oso2woJSWA" name="container" type="_AqK8QJaxEey_Oso2woJSWA"/>
