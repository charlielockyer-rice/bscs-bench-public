            <packagedElement xmi:type="uml:Class" xmi:id="_rEcZhIfUEeyL0OpKiOLIMQ" name="PolygonFac">
              <ownedComment xmi:id="_rE66pIfUEeyL0OpKiOLIMQ">
                <body>A polygon factory that creates polygons with affine transforms
@author charlielockyer
 *</body>
              </ownedComment>
              <ownedAttribute xmi:id="_rE4eYYfUEeyL0OpKiOLIMQ" name="poly" visibility="private" type="_rEy-0IfUEeyL0OpKiOLIMQ" association="_rE8v1IfUEeyL0OpKiOLIMQ">
                <defaultValue xmi:type="uml:LiteralString" xmi:id="_rE4eYofUEeyL0OpKiOLIMQ" value="new Polygon()"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_rE4eZIfUEeyL0OpKiOLIMQ" name="at" visibility="private" type="_rEwikofUEeyL0OpKiOLIMQ" association="_rE9W4YfUEeyL0OpKiOLIMQ"/>
              <ownedAttribute xmi:id="_rE5FcIfUEeyL0OpKiOLIMQ" name="scaleFactor" visibility="package">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
                <defaultValue xmi:type="uml:LiteralString" xmi:id="_rE5FcYfUEeyL0OpKiOLIMQ" value="1.0"/>
              </ownedAttribute>
              <interfaceRealization xmi:id="_rEy-0ofUEeyL0OpKiOLIMQ" client="_rEcZhIfUEeyL0OpKiOLIMQ" supplier="_rEbLYIfUEeyL0OpKiOLIMQ" contract="_rEbLYIfUEeyL0OpKiOLIMQ"/>
              <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_rE6TkIfUEeyL0OpKiOLIMQ" name="PolygonFac" specification="_rE2CIIfUEeyL0OpKiOLIMQ">
                <ownedParameter xmi:id="_rE6TkYfUEeyL0OpKiOLIMQ" name="at" type="_rEwikofUEeyL0OpKiOLIMQ"/>
                <ownedParameter xmi:id="_rE6TkofUEeyL0OpKiOLIMQ" name="scaleFactor">
                  <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
                </ownedParameter>
                <ownedParameter xmi:id="_rE6Tk4fUEeyL0OpKiOLIMQ" name="points" type="_rEwikIfUEeyL0OpKiOLIMQ">
                  <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_rE6TlIfUEeyL0OpKiOLIMQ" value="*"/>
                </ownedParameter>
                <ownedParameter xmi:id="_rE6TlYfUEeyL0OpKiOLIMQ" type="_rEcZhIfUEeyL0OpKiOLIMQ" direction="return"/>
                <language>java</language>
                <body>this.at = at;
		this.scaleFactor = scaleFactor;
		for (Point pt : points) {
			poly.addPoint(pt.x, pt.y);
		}
	</body>
              </ownedBehavior>
              <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_rE6TlofUEeyL0OpKiOLIMQ" name="makeShape" specification="_rEdnoIfUEeyL0OpKiOLIMQ">
                <ownedParameter xmi:id="_rE6Tl4fUEeyL0OpKiOLIMQ" name="x">
                  <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
                </ownedParameter>
                <ownedParameter xmi:id="_rE6TmIfUEeyL0OpKiOLIMQ" name="y">
                  <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
                </ownedParameter>
                <ownedParameter xmi:id="_rE6TmYfUEeyL0OpKiOLIMQ" name="width">
                  <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
                </ownedParameter>
                <ownedParameter xmi:id="_rE6TmofUEeyL0OpKiOLIMQ" name="height">
                  <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
                </ownedParameter>
                <ownedParameter xmi:id="_rE6Tm4fUEeyL0OpKiOLIMQ" type="_rExJoofUEeyL0OpKiOLIMQ" direction="return"/>
                <language>java</language>
                <body>at.setToTranslation(x,  y);
		at.scale(width * scaleFactor, height * scaleFactor);
		return at.createTransformedShape(poly);
	</body>
              </ownedBehavior>
