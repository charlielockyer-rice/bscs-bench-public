              <ownedAttribute xmi:id="_rE33VIfUEeyL0OpKiOLIMQ" name="Singleton" isStatic="true" type="_rEbycIfUEeyL0OpKiOLIMQ" association="_rE8v0YfUEeyL0OpKiOLIMQ">
