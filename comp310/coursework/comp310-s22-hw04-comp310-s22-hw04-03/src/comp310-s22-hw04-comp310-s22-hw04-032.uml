            <packagedElement xmi:type="uml:Class" xmi:id="_rEbycIfUEeyL0OpKiOLIMQ" name="PentanglePolygonFac">
              <ownedComment xmi:id="_rE66o4fUEeyL0OpKiOLIMQ">
