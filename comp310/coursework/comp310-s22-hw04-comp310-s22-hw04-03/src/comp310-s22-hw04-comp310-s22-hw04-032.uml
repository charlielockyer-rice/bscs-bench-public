              </ownedAttribute>
              <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_rE5siIfUEeyL0OpKiOLIMQ" name="PentanglePolygonFac" specification="_rEcZgIfUEeyL0OpKiOLIMQ">
                <ownedParameter xmi:id="_rE5siYfUEeyL0OpKiOLIMQ" type="_rEbycIfUEeyL0OpKiOLIMQ" direction="return"/>
                <language>java</language>
                <body>super(new AffineTransform(), 1.0 / 4, new Point(-1, 2), new Point(0,5), new Point(1,2),
				new Point(4,2), new Point(2,0), new Point(3, -3), new Point(0, -1), new Point(-3, -3),
				new Point(-2, 0), new Point(-4, 2));
	</body>
              </ownedBehavior>
