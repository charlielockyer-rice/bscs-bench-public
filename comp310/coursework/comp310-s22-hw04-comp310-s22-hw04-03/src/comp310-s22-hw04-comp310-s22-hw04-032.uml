              <ownedComment xmi:id="_rE66oIfUEeyL0OpKiOLIMQ">
                <body>Makes a dolphin shape
@author charlielockyer
 *</body>
              </ownedComment>
              <generalization xmi:id="_rExJoYfUEeyL0OpKiOLIMQ" general="_rEcZhIfUEeyL0OpKiOLIMQ"/>
