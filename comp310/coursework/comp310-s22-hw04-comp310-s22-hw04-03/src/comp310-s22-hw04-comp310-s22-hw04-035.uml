          <ownedOperation xmi:id="_Aqn3wIfVEeyL0OpKiOLIMQ" name="Ball" method="_Aq6LoIfVEeyL0OpKiOLIMQ">
            <eAnnotations xmi:id="_Aqn3yIfVEeyL0OpKiOLIMQ" source="http://www.eclipse.org/uml2/2.0.0/UML">
              <details xmi:id="_Aqn3yYfVEeyL0OpKiOLIMQ" key="create"/>
            </eAnnotations>
            <ownedComment xmi:id="_Aq9O8YfVEeyL0OpKiOLIMQ">
              <body>@param location is the location of the ball
	 * @param velocity is how fast the ball is going in x and y location
	 * @param color is the set color for the ball
	 * @param radius is the size of the ball
	 * @param dimension the size of the canvas
	 * @param algo the ball algorithm</body>
            </ownedComment>
            <ownedParameter xmi:id="_Aqn3wYfVEeyL0OpKiOLIMQ" name="location" type="_AqWyA4fVEeyL0OpKiOLIMQ"/>
            <ownedParameter xmi:id="_Aqn3wofVEeyL0OpKiOLIMQ" name="velocity" type="_AqWyA4fVEeyL0OpKiOLIMQ"/>
            <ownedParameter xmi:id="_Aqn3w4fVEeyL0OpKiOLIMQ" name="color" type="_AqWK8IfVEeyL0OpKiOLIMQ"/>
            <ownedParameter xmi:id="_Aqn3xIfVEeyL0OpKiOLIMQ" name="radius">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
            </ownedParameter>
            <ownedParameter xmi:id="_Aqn3xYfVEeyL0OpKiOLIMQ" name="dimension" type="_AqYAIYfVEeyL0OpKiOLIMQ"/>
            <ownedParameter xmi:id="_Aqn3xofVEeyL0OpKiOLIMQ" name="canvas" type="_AqXZEYfVEeyL0OpKiOLIMQ"/>
            <ownedParameter xmi:id="_Aqn3x4fVEeyL0OpKiOLIMQ" name="algo" type="_ApvG8IfVEeyL0OpKiOLIMQ"/>
            <ownedParameter xmi:id="_Aqn3yofVEeyL0OpKiOLIMQ" type="_Apf2YIfVEeyL0OpKiOLIMQ" direction="return"/>
          </ownedOperation>
          <ownedOperation xmi:id="_Aqn3y4fVEeyL0OpKiOLIMQ" name="update" method="_Aq6ys4fVEeyL0OpKiOLIMQ">
            <ownedParameter xmi:id="_Aqn3zIfVEeyL0OpKiOLIMQ" name="disp" type="_AqXZE4fVEeyL0OpKiOLIMQ"/>
            <ownedParameter xmi:id="_Aqoe0IfVEeyL0OpKiOLIMQ" name="cmd" type="_ApvuAIfVEeyL0OpKiOLIMQ"/>
          </ownedOperation>
          <ownedOperation xmi:id="_Aqoe1YfVEeyL0OpKiOLIMQ" name="updateState" method="_Aq6ytofVEeyL0OpKiOLIMQ">
            <ownedComment xmi:id="_Aq9O8ofVEeyL0OpKiOLIMQ">
              <body>update the state for the balls
	 * @param disp is the inputed dispatcher display</body>
            </ownedComment>
