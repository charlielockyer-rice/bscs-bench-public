          </ownedAttribute>
          <ownedAttribute xmi:id="_Aq3vaofVEeyL0OpKiOLIMQ" name="maxVelocity" visibility="private" type="_AqeGwIfVEeyL0OpKiOLIMQ" association="_ArG_9IfVEeyL0OpKiOLIMQ">
            <defaultValue xmi:type="uml:LiteralString" xmi:id="_Aq3va4fVEeyL0OpKiOLIMQ" value="new Rectangle(maxSpeed, maxSpeed, maxSpeed, maxSpeed)"/>
          </ownedAttribute>
