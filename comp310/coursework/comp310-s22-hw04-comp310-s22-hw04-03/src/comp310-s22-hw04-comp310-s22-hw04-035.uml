            <defaultValue xmi:type="uml:LiteralString" xmi:id="_Aq4WeIfVEeyL0OpKiOLIMQ" value="new Timer(timeSlice, new ActionListener() {&#xA;&#x9;&#x9;public void actionPerformed(ActionEvent e) {&#xA;&#x9;&#x9;&#x9;viewAdapter.update();&#xA;&#x9;&#x9;}&#xA;&#x9;})"/>
          </ownedAttribute>
          <ownedAttribute xmi:id="_Aq4WeofVEeyL0OpKiOLIMQ" name="switcherDummyBall" visibility="private" type="_AprckIfVEeyL0OpKiOLIMQ" association="_ArHnBIfVEeyL0OpKiOLIMQ"/>
          <ownedAttribute xmi:id="_Aq49gYfVEeyL0OpKiOLIMQ" name="switcherUpdateStrategy" visibility="private" type="_ApxjMIfVEeyL0OpKiOLIMQ" association="_ArHnB4fVEeyL0OpKiOLIMQ">
            <defaultValue xmi:type="uml:LiteralString" xmi:id="_Aq49gofVEeyL0OpKiOLIMQ" value="new IUpdateStrategy() {&#xA;&#x9;&#x9;@Override&#xA;&#x9;&#x9;public void updateState(IBall context, IDispatcher&lt;IBallCmd> disp) {&#xA;&#x9;&#x9;&#x9;switcherDummyBall.getUpdateStrategy().updateState(context, disp);&#xA;&#x9;&#x9;}&#xA;&#x9;&#x9;&#xA;&#x9;&#x9;@Override&#xA;&#x9;&#x9;public void init(IBall context) {&#xA;&#x9;&#x9;&#x9;switcherDummyBall.getUpdateStrategy().init(context);&#xA;&#x9;&#x9;}&#xA;&#x9;}"/>
          </ownedAttribute>
