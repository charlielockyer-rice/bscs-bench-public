          <ownedAttribute xmi:id="_Aq0sE4fVEeyL0OpKiOLIMQ" name="updateStrategy" isReadOnly="true"/>
          <interfaceRealization xmi:id="_AqmpoIfVEeyL0OpKiOLIMQ" client="_Apf2YIfVEeyL0OpKiOLIMQ" supplier="_AqXZFYfVEeyL0OpKiOLIMQ" contract="_AqXZFYfVEeyL0OpKiOLIMQ"/>
          <interfaceRealization xmi:id="_AqYnM4fVEeyL0OpKiOLIMQ" client="_Apf2YIfVEeyL0OpKiOLIMQ" supplier="_AprckIfVEeyL0OpKiOLIMQ" contract="_AprckIfVEeyL0OpKiOLIMQ"/>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_Aq6LoIfVEeyL0OpKiOLIMQ" name="Ball" specification="_Aqn3wIfVEeyL0OpKiOLIMQ">
            <ownedParameter xmi:id="_Aq6LoYfVEeyL0OpKiOLIMQ" name="location" type="_AqWyA4fVEeyL0OpKiOLIMQ"/>
            <ownedParameter xmi:id="_Aq6LoofVEeyL0OpKiOLIMQ" name="velocity" type="_AqWyA4fVEeyL0OpKiOLIMQ"/>
            <ownedParameter xmi:id="_Aq6Lo4fVEeyL0OpKiOLIMQ" name="color" type="_AqWK8IfVEeyL0OpKiOLIMQ"/>
            <ownedParameter xmi:id="_Aq6LpIfVEeyL0OpKiOLIMQ" name="radius">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
            </ownedParameter>
            <ownedParameter xmi:id="_Aq6LpYfVEeyL0OpKiOLIMQ" name="dimension" type="_AqYAIYfVEeyL0OpKiOLIMQ"/>
            <ownedParameter xmi:id="_Aq6LpofVEeyL0OpKiOLIMQ" name="canvas" type="_AqXZEYfVEeyL0OpKiOLIMQ"/>
            <ownedParameter xmi:id="_Aq6Lp4fVEeyL0OpKiOLIMQ" name="algo" type="_ApvG8IfVEeyL0OpKiOLIMQ"/>
            <ownedParameter xmi:id="_Aq6LqIfVEeyL0OpKiOLIMQ" type="_Apf2YIfVEeyL0OpKiOLIMQ" direction="return"/>
            <language>java</language>
            <body>this.location = location;
		this.velocity = velocity;
		this.color = color;
		this.radius = radius;
		this.dimension = dimension;
		this.canvas = canvas;
		this.execute(algo);
		
		this.paintStrategy.init(this);
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_Aq6LqYfVEeyL0OpKiOLIMQ" name="move" specification="_AphrkIfVEeyL0OpKiOLIMQ">
            <language>java</language>
            <body>this.location.translate(velocity.x, velocity.y);
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_Aq6ysIfVEeyL0OpKiOLIMQ" name="execute" specification="_AqZOQIfVEeyL0OpKiOLIMQ">
            <ownedParameter xmi:id="_Aq6ysYfVEeyL0OpKiOLIMQ" name="algo" type="_ApvG8IfVEeyL0OpKiOLIMQ"/>
            <language>java</language>
            <body>algo.caseDefault(this);
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_Aq6ysofVEeyL0OpKiOLIMQ" name="bounce" specification="_AphrlIfVEeyL0OpKiOLIMQ">
            <language>java</language>
            <body>if (this.location.x+this.radius >= this.dimension.getWidth() || this.location.x-this.radius &lt;= 0) {
			this.velocity.x = -this.velocity.x;
			bounced[0] = true;
		}
		
		if (this.location.y+this.radius >= this.dimension.getHeight() || this.location.y-this.radius &lt;= 0) {
			this.velocity.y = -this.velocity.y;
			bounced[1] = true;
		}
		// set the new location
		location.setLocation(this.location);
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_Aq6ys4fVEeyL0OpKiOLIMQ" name="update" specification="_Aqn3y4fVEeyL0OpKiOLIMQ">
            <ownedParameter xmi:id="_Aq6ytIfVEeyL0OpKiOLIMQ" name="disp" type="_AqXZE4fVEeyL0OpKiOLIMQ"/>
            <ownedParameter xmi:id="_Aq6ytYfVEeyL0OpKiOLIMQ" name="cmd" type="_ApvuAIfVEeyL0OpKiOLIMQ"/>
            <language>java</language>
            <body>cmd.apply(this, disp);
 </body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_Aq6ytofVEeyL0OpKiOLIMQ" name="updateState" specification="_Aqoe1YfVEeyL0OpKiOLIMQ">
            <ownedParameter xmi:id="_Aq6yt4fVEeyL0OpKiOLIMQ" name="disp" type="_AqXZE4fVEeyL0OpKiOLIMQ"/>
            <language>java</language>
            <body>this.strategy.updateState(this, disp);
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_Aq6yuIfVEeyL0OpKiOLIMQ" name="paint" specification="_AqpF4YfVEeyL0OpKiOLIMQ">
            <ownedParameter xmi:id="_Aq6yuYfVEeyL0OpKiOLIMQ" name="g" type="_AqWyAYfVEeyL0OpKiOLIMQ"/>
            <language>java</language>
            <body>this.paintStrategy.paint(g, this);
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_Aq7Zx4fVEeyL0OpKiOLIMQ" name="setUpdateStrategy" specification="_AqacYIfVEeyL0OpKiOLIMQ">
            <ownedParameter xmi:id="_Aq7ZyIfVEeyL0OpKiOLIMQ" name="updateStrategy" type="_ApxjMIfVEeyL0OpKiOLIMQ"/>
            <language>java</language>
            <body>this.strategy = updateStrategy;
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_Aq7Zz4fVEeyL0OpKiOLIMQ" name="hasBounced" specification="_Api5sIfVEeyL0OpKiOLIMQ">
            <ownedParameter xmi:id="_Aq7Z0IfVEeyL0OpKiOLIMQ" direction="return">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#boolean"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_Aq7Z0YfVEeyL0OpKiOLIMQ" value="*"/>
            </ownedParameter>
            <language>java</language>
            <body>return this.bounced;
	</body>
          </ownedBehavior>
