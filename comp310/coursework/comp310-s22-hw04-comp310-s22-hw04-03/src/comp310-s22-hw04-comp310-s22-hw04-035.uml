*%0A%09 * move method to call move for balls%0A%09 */%0A&#xA; %09@Override%0A%09&#xA;@@ -2028,16 +2028,100 @@&#xA; y.y);%0A%09%7D&#xA;+;%0A%09%0A%09/**%0A%09 * %7B@inheritDoc%7D%0A%09 * %3Cbr%3E%0A%09 * Runs the default case of the algorithm%0A%09 */%0A&#xA; %09@Overri&#xA;@@ -2737,834 +2737,2609 @@&#xA; ;%0A%09%7D&#xA;-    @Override%0A%09public void update(IDispatcher%3CIBallCmd%3E disp, IBallCmd cmd) %7B %0A    %09cmd.apply(this, disp);%0A    %7D%09%09%0A%09/**%0A%09 * update the state for the balls%0A%09 * @param disp is the inputed dispatcher display %0A%09 */%0A%09public void updateState(IDispatcher%3CIBallCmd%3E disp) %7B%0A%09%09this.strategy.updateState(this, disp);%0A%09%7D%0A%0A%09/**%0A%09 * The paint method to fill in the ball%0A%09 * @param g inputed graphics%0A%09 */%0A%09@Override%0A%09public void paint(Graphics g) %7B%0A%09%09this.paintStrategy.paint(g, this);%0A%09%7D%0A%09%0A%09/**%0A%09 * A set location method, mostly used for trails and teleporting%0A%09 * @param location%0A%09 */%0A%09%0A%09/**%0A%09 * A setter for the ball's update strategy%0A%09 */%0A%09public void setUpdateStrategy(IUpdateStrategy updateStrategy) %7B%0A%09%09this.strategy = updateStrategy;%0A%09%7D%0A%09%0A%09/**%0A%09 * A getter for the ball's update strategy%0A%09 * @return the ball's update strategy%0A%09 */&#xA;+;%0A%09%0A%09/**%0A%09 * The update method that the dispatcher's updateAll method will call.%0A%09 * @param disp The calling dispatcher%0A%09 * @param g The input parameter given to the dispatcher's updateAll() method, here a Graphics object.%0A%09 */%0A    @Override%0A%09public void update(IDispatcher%3CIBallCmd%3E disp, IBallCmd cmd) %7B %0A    %09cmd.apply(this, disp);%0A    %7D;%0A%09%09%0A%09/**%0A%09 * update the state for the balls%0A%09 * @param disp is the inputed dispatcher display %0A%09 */%0A%09public void updateState(IDispatcher%3CIBallCmd%3E disp) %7B%0A%09%09this.strategy.updateState(this, disp);%0A%09%7D%0A%0A%09/**%0A%09 * The paint method to fill in the ball%0A%09 * @param g inputed graphics%0A%09 */%0A%09@Override%0A%09public void paint(Graphics g) %7B%0A%09%09this.paintStrategy.paint(g, this);%0A%09%7D%0A%09%0A%09/**%0A%09 * A set location method, mostly used for trails and teleporting%0A%09 * @param location%0A%09 */%0A%09@Override%0A%09public void setLocation(Point location) %7B%0A%09%09this.location = location;%0A%09%7D%0A%09%0A%09/**%0A%09 * A getter for location%0A%09 * @return the ball's location%0A%09 */%0A%09@Override%0A%09public Point getLocation() %7B%0A%09%09return this.location;%0A%09%7D%0A%09%0A%09/**%0A%09 * @param velocity the balls velocity to set%0A%09 */%0A%09@Override%0A%09public void setVelocity(Point velocity) %7B%0A%09%09this.velocity = velocity;%0A%09%7D%0A%09%0A%09/**%0A%09 * @return the balls velocity to get%0A%09 */%0A%09@Override%0A%09public Point getVelocity() %7B%0A%09%09return this.velocity;%0A%09%7D%0A%09%0A%09/**%0A%09 * @param radius the balls radius to set%0A%09 */%0A%09@Override%0A%09public void setRadius(int radius) %7B%0A%09%09this.radius = radius;%0A%09%7D%0A%09%0A%09/**%0A%09 * @return the balls radius to get%0A%09 */%0A%09@Override%0A%09public int getRadius() %7B%0A%09%09return this.radius;%0A%09%7D%0A%09%0A%09/**%0A%09 * @param color the balls velocity to set%0A%09 */%0A%09@Override%0A%09public void setColor(Color color) %7B%0A%09%09this.color = color;%0A%09%7D%0A%09%0A%09/**%0A%09 * @return the balls velocity to get%0A%09 */%0A%09@Override%0A%09public Color getColor() %7B%0A%09%09return this.color;%0A%09%7D%0A%09%0A%09/**%0A%09 * A getter for dimension in order to make teleport work%0A%09 * @return dimensions of the screen%0A%09 */%0A%09@Override%0A%09public IDimension getDimension() %7B%0A%09%09return this.dimension;%0A%09%7D%0A%09%0A%09/**%0A%09 * A setter for the ball's update strategy%0A%09 */%0A%09public void setUpdateStrategy(IUpdateStrategy updateStrategy) %7B%0A%09%09this.strategy = updateStrategy;%0A%09%7D%0A%09%0A%09/**%0A%09 * A getter for the ball's update strategy%0A%09 * @return the ball's update strategy%0A%09 */%0A%09public IUpdateStrategy getUpdateStrategy() %7B%0A%09%09return this.strategy;%0A%09%7D%0A%09%0A%09/**%0A%09 * A setter for the ball's paint strategy%0A%09 */%0A%09public void setPaintStrategy(IPaintStrategy paintStrategy) %7B%0A%09%09this.paintStrategy = paintStrategy;%0A%09%7D%0A%09%0A%09/**%0A%09 * A getter for the ball's paint strategy%0A%09 * @return the ball's paint strategy%0A%09 */%0A%09public IPaintStrategy getPaintStrategy() %7B%0A%09%09return this.paintStrategy;%0A%09%7D&#xA; %0A%09%0A%09&#xA;@@ -5590,10 +5590,67 @@&#xA; as%0A%09 */%0A&#xA;+%09public Container getCanvas() %7B%0A%09%09return this.canvas;%0A%09%7D%0A&#xA; %7D%0A&#xA;" conflicting="false"/>
