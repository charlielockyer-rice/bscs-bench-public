          <packagedElement xmi:type="uml:Class" xmi:id="_dMkqwIfUEeyL0OpKiOLIMQ" name="ZigZagStrategy">
            <ownedComment xmi:id="_dN2dKIfUEeyL0OpKiOLIMQ">
              <body>A ZigZag strategy is a strategy that changes direction and color of the ball
at certain time intervals while also maintaining the bounce properties
of a straight ball
@author akashkaranam
 *</body>
            </ownedComment>
            <ownedAttribute xmi:id="_dNzZ0ofUEeyL0OpKiOLIMQ" name="steps" visibility="private">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_dNzZ04fUEeyL0OpKiOLIMQ" value="0"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_dN0A4IfUEeyL0OpKiOLIMQ" name="rand" visibility="private" type="_dNVfwYfUEeyL0OpKiOLIMQ" association="_dN6HgYfUEeyL0OpKiOLIMQ">
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_dN0A4YfUEeyL0OpKiOLIMQ" value="Randomizer.Singleton"/>
            </ownedAttribute>
            <interfaceRealization xmi:id="_dNt6QIfUEeyL0OpKiOLIMQ" client="_dMkqwIfUEeyL0OpKiOLIMQ" supplier="_dNROUIfUEeyL0OpKiOLIMQ" contract="_dNROUIfUEeyL0OpKiOLIMQ"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_dN12FYfUEeyL0OpKiOLIMQ" name="updateState" specification="_dNt6QYfUEeyL0OpKiOLIMQ">
              <ownedParameter xmi:id="_dN12FofUEeyL0OpKiOLIMQ" name="context" type="_dNSccYfUEeyL0OpKiOLIMQ"/>
              <ownedParameter xmi:id="_dN12F4fUEeyL0OpKiOLIMQ" name="disp" type="_dNTDgYfUEeyL0OpKiOLIMQ"/>
              <language>java</language>
              <body>int modSteps = this.steps % 30;
		
		if(modSteps == 10)
		{
			context.setVelocity(new Point(-context.getVelocity().x, context.getVelocity().y));
			context.setColor(rand.randomColor());
			
		}
		
		this.steps++;
	</body>
            </ownedBehavior>
