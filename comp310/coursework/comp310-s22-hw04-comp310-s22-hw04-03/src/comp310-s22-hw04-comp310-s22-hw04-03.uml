            <ownedAttribute xmi:id="_dNyywofUEeyL0OpKiOLIMQ" name="secondStrategy" visibility="private" type="_dNROUIfUEeyL0OpKiOLIMQ" association="_dN5gcYfUEeyL0OpKiOLIMQ"/>
            <interfaceRealization xmi:id="_dNoasIfUEeyL0OpKiOLIMQ" client="_dMhAYIfUEeyL0OpKiOLIMQ" supplier="_dNROUIfUEeyL0OpKiOLIMQ" contract="_dNROUIfUEeyL0OpKiOLIMQ"/>
