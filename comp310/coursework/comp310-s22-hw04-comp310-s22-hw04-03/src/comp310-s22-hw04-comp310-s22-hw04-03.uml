          <packagedElement xmi:type="uml:Class" xmi:id="_dMfLMIfUEeyL0OpKiOLIMQ" name="GravityStrategy">
            <ownedComment xmi:id="_dN2dIofUEeyL0OpKiOLIMQ">
              <body>An update strategy that makes the ball &quot;fall&quot; towards the ground.</body>
            </ownedComment>
            <interfaceRealization xmi:id="_dNkwUIfUEeyL0OpKiOLIMQ" client="_dMfLMIfUEeyL0OpKiOLIMQ" supplier="_dNROUIfUEeyL0OpKiOLIMQ" contract="_dNROUIfUEeyL0OpKiOLIMQ"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_dN1PAIfUEeyL0OpKiOLIMQ" name="updateState" specification="_dNkwUYfUEeyL0OpKiOLIMQ">
              <ownedParameter xmi:id="_dN1PAYfUEeyL0OpKiOLIMQ" name="context" type="_dNSccYfUEeyL0OpKiOLIMQ"/>
              <ownedParameter xmi:id="_dN1PAofUEeyL0OpKiOLIMQ" name="disp" type="_dNTDgYfUEeyL0OpKiOLIMQ"/>
              <language>java</language>
              <body>context.getVelocity().y += 1;
	</body>
            </ownedBehavior>
