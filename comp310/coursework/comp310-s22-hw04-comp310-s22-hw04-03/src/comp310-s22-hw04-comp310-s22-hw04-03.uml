              <ownedParameter xmi:id="_dN1PCYfUEeyL0OpKiOLIMQ" type="_dMhAYIfUEeyL0OpKiOLIMQ" direction="return"/>
              <language>java</language>
              <body>this.firstStrategy = firstStrategy;
		this.secondStrategy = secondStrategy;
	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_dN1PCofUEeyL0OpKiOLIMQ" name="updateState" specification="_dNpBwIfUEeyL0OpKiOLIMQ">
              <ownedParameter xmi:id="_dN1PC4fUEeyL0OpKiOLIMQ" name="context" type="_dNSccYfUEeyL0OpKiOLIMQ"/>
