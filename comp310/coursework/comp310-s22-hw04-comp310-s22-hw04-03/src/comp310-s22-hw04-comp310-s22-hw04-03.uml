          <packagedElement xmi:type="uml:Class" xmi:id="_dMjcoIfUEeyL0OpKiOLIMQ" name="SwitcherStrategy">
            <ownedComment xmi:id="_dN2dJ4fUEeyL0OpKiOLIMQ">
