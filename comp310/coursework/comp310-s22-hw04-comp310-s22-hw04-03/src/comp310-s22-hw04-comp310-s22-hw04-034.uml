              <ownedAttribute xmi:id="_45y_wYfUEeyL0OpKiOLIMQ" name="ERROR" isLeaf="true" isStatic="true" type="_45yYsIfUEeyL0OpKiOLIMQ" isReadOnly="true" association="_47RmcYfUEeyL0OpKiOLIMQ">
                <defaultValue xmi:type="uml:LiteralString" xmi:id="_45y_wofUEeyL0OpKiOLIMQ" value="new IPaintStrategy() {&#xA;&#x9;&#x9;private int count = 100;&#xA;&#x9;&#x9;&#xA;&#x9;&#x9;public void init(IBall context) {&#xA;&#x9;&#x9;&#x9;&#xA;&#x9;&#x9;}&#xA;&#x9;&#x9;&#xA;&#x9;&#x9;public void paint(Graphics g, IBall host) {&#xA;&#x9;&#x9;&#x9;host.setColor(Color.WHITE);&#xA;&#x9;&#x9;&#x9;host.setVelocity(new Point(0, 0));&#xA;&#x9;&#x9;&#x9;host.setRadius(0);&#xA;&#x9;&#x9;&#x9;host.setLocation(new Point(0, 0));&#xA;&#x9;&#x9;&#x9;&#xA;&#x9;&#x9;&#x9;if(count >= 0 &amp;&amp; 0 == (count--) % 25) {&#xA;&#x9;&#x9;&#x9;&#x9;java.awt.Toolkit.getDefaultToolkit().beep();&#xA;&#x9;&#x9;&#x9;&#x9;System.err.println(&quot;IUpdateStrategy.ERROR: beep!&quot;);&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;}&#xA;&#x9;}"/>
              </ownedAttribute>
