            <packagedElement xmi:type="uml:Class" xmi:id="_45sSEIfUEeyL0OpKiOLIMQ" name="APaintStrategy" isAbstract="true">
              <ownedComment xmi:id="_47PKPIfUEeyL0OpKiOLIMQ">
                <body>An abstract paint strategy
@author charlielockyer
 *</body>
              </ownedComment>
              <ownedAttribute xmi:id="_47JDkIfUEeyL0OpKiOLIMQ" name="at" visibility="protected" type="_46otQIfUEeyL0OpKiOLIMQ" association="_47RmdIfUEeyL0OpKiOLIMQ"/>
              <interfaceRealization xmi:id="_46p7YYfUEeyL0OpKiOLIMQ" client="_45sSEIfUEeyL0OpKiOLIMQ" supplier="_45yYsIfUEeyL0OpKiOLIMQ" contract="_45yYsIfUEeyL0OpKiOLIMQ"/>
              <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_47Mt8IfUEeyL0OpKiOLIMQ" name="APaintStrategy" specification="_467BIIfUEeyL0OpKiOLIMQ">
                <ownedParameter xmi:id="_47Mt8YfUEeyL0OpKiOLIMQ" name="at" type="_46otQIfUEeyL0OpKiOLIMQ"/>
                <ownedParameter xmi:id="_47Mt8ofUEeyL0OpKiOLIMQ" type="_45sSEIfUEeyL0OpKiOLIMQ" direction="return"/>
                <language>java</language>
                <body>this.at = at;
	</body>
              </ownedBehavior>
              <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_47Mt84fUEeyL0OpKiOLIMQ" name="paint" specification="_467oMYfUEeyL0OpKiOLIMQ">
                <ownedParameter xmi:id="_47Mt9IfUEeyL0OpKiOLIMQ" name="g" type="_46pUUYfUEeyL0OpKiOLIMQ"/>
                <ownedParameter xmi:id="_47Mt9YfUEeyL0OpKiOLIMQ" name="ball" type="_46otQofUEeyL0OpKiOLIMQ"/>
                <language>java</language>
                <body>double radius = ball.getRadius();
		at.setToTranslation(ball.getLocation().x, ball.getLocation().y);
		at.scale(radius, radius);
		at.rotate(Math.atan2(ball.getVelocity().y, ball.getVelocity().x));
		g.setColor(ball.getColor());
		paintCfg(g, ball);
		paintXfrm(g, ball, at);
	</body>
              </ownedBehavior>
              <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_47Mt9ofUEeyL0OpKiOLIMQ" name="getAT" specification="_469dZIfUEeyL0OpKiOLIMQ">
                <ownedParameter xmi:id="_47Mt94fUEeyL0OpKiOLIMQ" name="at" type="_46otQIfUEeyL0OpKiOLIMQ"/>
                <ownedParameter xmi:id="_47Mt-IfUEeyL0OpKiOLIMQ" type="_46otQIfUEeyL0OpKiOLIMQ" direction="return"/>
                <language>java</language>
                <body>return this.at;
	</body>
              </ownedBehavior>
