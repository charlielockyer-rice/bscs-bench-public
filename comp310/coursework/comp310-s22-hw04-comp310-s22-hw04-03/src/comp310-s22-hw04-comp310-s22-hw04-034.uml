              <interfaceRealization xmi:id="_464k4YfUEeyL0OpKiOLIMQ" client="_454fUIfUEeyL0OpKiOLIMQ" supplier="_45yYsIfUEeyL0OpKiOLIMQ" contract="_45yYsIfUEeyL0OpKiOLIMQ"/>
