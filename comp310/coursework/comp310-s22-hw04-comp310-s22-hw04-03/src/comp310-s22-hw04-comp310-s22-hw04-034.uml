              <ownedComment xmi:id="_47PxQYfUEeyL0OpKiOLIMQ">
                <body>Paints an ellipse win pentangles that is done with multi strategies
@author charlielockyer
 *</body>
              </ownedComment>
              <generalization xmi:id="_46va8IfUEeyL0OpKiOLIMQ" general="_45008IfUEeyL0OpKiOLIMQ"/>
              <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_47NVGYfUEeyL0OpKiOLIMQ" name="EllipsePentanglePaintStrategy" specification="_45xKkYfUEeyL0OpKiOLIMQ">
                <ownedParameter xmi:id="_47NVGofUEeyL0OpKiOLIMQ" type="_45xKkIfUEeyL0OpKiOLIMQ" direction="return"/>
