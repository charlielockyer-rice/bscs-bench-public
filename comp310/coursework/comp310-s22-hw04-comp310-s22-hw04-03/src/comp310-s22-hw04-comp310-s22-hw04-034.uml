            <packagedElement xmi:type="uml:Class" xmi:id="_45uHQIfUEeyL0OpKiOLIMQ" name="BallPaintStrategy">
              <ownedComment xmi:id="_47PKPYfUEeyL0OpKiOLIMQ">
                <body>Ball painting strategy
@author charlielockyer
 *</body>
              </ownedComment>
              <interfaceRealization xmi:id="_46rwkIfUEeyL0OpKiOLIMQ" client="_45uHQIfUEeyL0OpKiOLIMQ" supplier="_45yYsIfUEeyL0OpKiOLIMQ" contract="_45yYsIfUEeyL0OpKiOLIMQ"/>
              <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_47Mt-YfUEeyL0OpKiOLIMQ" name="init" specification="_46-EcIfUEeyL0OpKiOLIMQ">
                <ownedParameter xmi:id="_47Mt-ofUEeyL0OpKiOLIMQ" name="ball" type="_46otQofUEeyL0OpKiOLIMQ"/>
                <language>java</language>
                <body>System.out.println(&quot;Init for ball paint strategy entered&quot;);
	</body>
              </ownedBehavior>
              <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_47Mt-4fUEeyL0OpKiOLIMQ" name="paint" specification="_46-rgofUEeyL0OpKiOLIMQ">
                <ownedParameter xmi:id="_47Mt_IfUEeyL0OpKiOLIMQ" name="g" type="_46pUUYfUEeyL0OpKiOLIMQ"/>
                <ownedParameter xmi:id="_47Mt_YfUEeyL0OpKiOLIMQ" name="ball" type="_46otQofUEeyL0OpKiOLIMQ"/>
                <language>java</language>
                <body>g.setColor(ball.getColor());
		g.fillOval(ball.getLocation().x - ball.getRadius(), ball.getLocation().y - ball.getRadius(),
				2 * ball.getRadius(), 2 * ball.getRadius());
	</body>
              </ownedBehavior>
              <ownedOperation xmi:id="_46-EcIfUEeyL0OpKiOLIMQ" name="init" method="_47Mt-YfUEeyL0OpKiOLIMQ">
                <ownedParameter xmi:id="_46-EcYfUEeyL0OpKiOLIMQ" name="ball" type="_46otQofUEeyL0OpKiOLIMQ"/>
              </ownedOperation>
              <ownedOperation xmi:id="_46-rgofUEeyL0OpKiOLIMQ" name="paint" method="_47Mt-4fUEeyL0OpKiOLIMQ">
                <ownedParameter xmi:id="_46-rg4fUEeyL0OpKiOLIMQ" name="g" type="_46pUUYfUEeyL0OpKiOLIMQ"/>
                <ownedParameter xmi:id="_46-rhIfUEeyL0OpKiOLIMQ" name="ball" type="_46otQofUEeyL0OpKiOLIMQ"/>
              </ownedOperation>
