                <body>this(new AffineTransform());
	</body>
              </ownedBehavior>
              <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_47NVG4fUEeyL0OpKiOLIMQ" name="EllipsePentanglePaintStrategy" specification="_47BHwIfUEeyL0OpKiOLIMQ">
                <ownedParameter xmi:id="_47NVHIfUEeyL0OpKiOLIMQ" name="at" type="_46otQIfUEeyL0OpKiOLIMQ"/>
                <ownedParameter xmi:id="_47NVHYfUEeyL0OpKiOLIMQ" type="_45xKkIfUEeyL0OpKiOLIMQ" direction="return"/>
                <language>java</language>
                <body>this(at, new PentanglePaintStrategy(at, 0.0, 0.0, 3.0, 3.0), new EllipsePaintStrategy(at, -1.5, 2.0, 5.0, 1.0));
	</body>
              </ownedBehavior>
              <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_47N8EIfUEeyL0OpKiOLIMQ" name="EllipsePentanglePaintStrategy" specification="_47BHxYfUEeyL0OpKiOLIMQ">
                <ownedParameter xmi:id="_47N8EYfUEeyL0OpKiOLIMQ" name="at" type="_46otQIfUEeyL0OpKiOLIMQ"/>
                <ownedParameter xmi:id="_47N8EofUEeyL0OpKiOLIMQ" name="paintStrategies" type="_45sSEIfUEeyL0OpKiOLIMQ">
                  <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_47N8E4fUEeyL0OpKiOLIMQ" value="*"/>
                </ownedParameter>
                <ownedParameter xmi:id="_47N8FIfUEeyL0OpKiOLIMQ" type="_45xKkIfUEeyL0OpKiOLIMQ" direction="return"/>
                <language>java</language>
                <body>super(at, paintStrategies);
	</body>
              </ownedBehavior>
              <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_47N8FYfUEeyL0OpKiOLIMQ" name="paintCfg" specification="_47Bu1IfUEeyL0OpKiOLIMQ">
                <ownedParameter xmi:id="_47N8FofUEeyL0OpKiOLIMQ" name="g" type="_46pUUYfUEeyL0OpKiOLIMQ"/>
                <ownedParameter xmi:id="_47N8F4fUEeyL0OpKiOLIMQ" name="ball" type="_46otQofUEeyL0OpKiOLIMQ"/>
                <language>java</language>
                <body>if(Math.abs(Math.atan2(ball.getVelocity().y, ball.getVelocity().x)) > Math.PI / 2.0) {
			at.scale(1, -1);
		}
	</body>
              </ownedBehavior>
