c Point getLocation() %7B%0A%09%09return this.location;%0A%09%7D%0A%09%0A%09/**%0A%09 * @param velocity the balls velocity to set%0A%09 */%0A%09@Override%0A%09public void setVelocity(Point velocity) %7B%0A%09%09this.velocity = velocity;%0A%09%7D%0A%09%0A%09/**%0A%09 * @return the balls velocity to get%0A%09 */%0A%09@Override%0A%09public Point getVelocity() %7B%0A%09%09return this.velocity;%0A%09%7D%0A%09%0A%09/**%0A%09 * @param radius the balls radius to set%0A%09 */%0A%09@Override%0A%09public void setRadius(int radius) %7B%0A%09%09this.radius = radius;%0A%09%7D%0A%09%0A%09/**%0A%09 * @return the balls radius to get%0A%09 */%0A%09@Override%0A%09public int getRadius() %7B%0A%09%09return this.radius;%0A%09%7D%0A%09%0A%09/**%0A%09 * @param color the balls velocity to set%0A%09 */%0A%09@Override%0A%09public void setColor(Color color) %7B%0A%09%09this.color = color;%0A%09%7D%0A%09%0A%09/**%0A%09 * @return the balls velocity to get%0A%09 */%0A%09@Override%0A%09public Color getColor() %7B%0A%09%09return this.color;%0A%09%7D%0A%09%0A%09/**%0A%09 * A getter for dimension in order to make teleport work%0A%09 * @return dimensions of the screen%0A%09 */%0A%09@Override%0A%09public IDimension getDimension() %7B%0A%09%09return this.dimension;%0A%09%7D%0A%09%0A%09/**%0A%09 * A setter for the ball's update strategy%0A%09 */%0A%09public void setUpdateStrategy(IUpdateStrategy updateStrategy) %7B%0A%09%09this.strategy = updateStrategy;%0A%09%7D%0A%09%0A%09/**%0A%09 * A getter for the ball's update strategy%0A%09 * @return the ball's update strategy%0A%09 */%0A%09public IUpdateStrategy getUpdateStrategy() %7B%0A%09%09return this.strategy;%0A%09%7D%0A%09%0A%09/**%0A%09 * A setter for the ball's paint strategy%0A%09 */%0A%09public void setPaintStrategy(IPaintStrategy paintStrategy) %7B%0A%09%09this.paintStrategy = paintStrategy;%0A%09%7D%0A%09%0A%09/**%0A%09 * A getter for the ball's paint strategy%0A%09 * @return the ball's paint strategy%0A%09 */%0A%09public IPaintStrategy getPaintStrategy() %7B%0A%09%09return this.paintStrategy;%0A%09%7D%0A%09%0A%09/**%0A%09 * Used for exploding strategy, this is whether or not the ball bounced%0A%09 * @return whether or not the ball has bounced%0A%09 */%0A%09public boolean%5B%5D hasBounced() %7B%0A%09%09return this.bounced;%0A%09%7D%0A%09%0A%09/**%0A%09 * A getter for the canvas%0A%09 * @return the canvas%0A%09 */%0A%09public Container getCanvas() %7B%0A%09%09return this.canvas;%0A%09%7D%0A%09%0A%09public void setInteractStrategy(IInteractStrategy interact)%7B%0A%09%09this.interactStrategy = interact;%0A%09%7D%0A%09%0A%09public IInteractStrategy getInteractStrategy()%7B%0A%09%09return this.interactStrategy;%0A%09%7D&#xA; %0A%09%0A%09&#xA;" conflicting="false"/>
