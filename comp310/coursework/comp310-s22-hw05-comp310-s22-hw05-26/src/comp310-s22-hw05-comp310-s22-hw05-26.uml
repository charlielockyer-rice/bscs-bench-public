            <ownedOperation xmi:id="_LCSy0Y7_EeyggvAY1gH3cA" name="calcUnitVec" visibility="package" method="_LFLHvo7_EeyggvAY1gH3cA">
              <ownedParameter xmi:id="_LCSy0o7_EeyggvAY1gH3cA" name="lSource" type="_LAbxoI7_EeyggvAY1gH3cA"/>
              <ownedParameter xmi:id="_LCSy047_EeyggvAY1gH3cA" name="lTarget" type="_LAbxoI7_EeyggvAY1gH3cA"/>
