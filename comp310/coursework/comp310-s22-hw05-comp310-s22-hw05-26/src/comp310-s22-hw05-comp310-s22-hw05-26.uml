            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_LFJ5k47_EeyggvAY1gH3cA" name="updateState" specification="_LCK3AI7_EeyggvAY1gH3cA">
              <ownedParameter xmi:id="_LFJ5lI7_EeyggvAY1gH3cA" name="ball" type="_K7yiMI7_EeyggvAY1gH3cA"/>
