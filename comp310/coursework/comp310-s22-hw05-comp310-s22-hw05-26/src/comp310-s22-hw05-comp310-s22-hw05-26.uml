          <packagedElement xmi:type="uml:Class" xmi:id="_K5_ycI7_EeyggvAY1gH3cA" name="ZigZagStrategy">
            <ownedComment xmi:id="_YuJpYI8AEeyggvAY1gH3cA">
              <body>A ZigZag strategy is a strategy that changes direction and color of the ball
at certain time intervals while also maintaining the bounce properties
of a straight ball
@author akashkaranam
 *</body>
            </ownedComment>
            <ownedAttribute xmi:id="_LDr58I7_EeyggvAY1gH3cA" name="steps" visibility="private">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_LDr58Y7_EeyggvAY1gH3cA" value="0"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_LDr5847_EeyggvAY1gH3cA" name="rand" visibility="private" type="_LAcYsY7_EeyggvAY1gH3cA" association="_LGFGoY7_EeyggvAY1gH3cA">
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_LDshAI7_EeyggvAY1gH3cA" value="Randomizer.Singleton"/>
            </ownedAttribute>
            <interfaceRealization xmi:id="_Yt5xwI8AEeyggvAY1gH3cA" client="_K5_ycI7_EeyggvAY1gH3cA" supplier="_YskVAI8AEeyggvAY1gH3cA" contract="_YskVAI8AEeyggvAY1gH3cA"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_LFJ5kI7_EeyggvAY1gH3cA" name="updateState" specification="_LCJB0I7_EeyggvAY1gH3cA">
              <ownedParameter xmi:id="_LFJ5kY7_EeyggvAY1gH3cA" name="context" type="_K7yiMI7_EeyggvAY1gH3cA"/>
              <ownedParameter xmi:id="_LFJ5ko7_EeyggvAY1gH3cA" name="disp" type="_LAeN4I7_EeyggvAY1gH3cA"/>
              <language>java</language>
              <body>int modSteps = this.steps % 30;
		
		if(modSteps == 10)
		{
			context.setVelocity(new Point(-context.getVelocity().x, context.getVelocity().y));
			context.setColor(rand.randomColor());
			
		}
		
		this.steps++;
	</body>
            </ownedBehavior>
