Switcher strategy to change</body>
            </ownedComment>
            <ownedAttribute xmi:id="_LD8YoI7_EeyggvAY1gH3cA" name="strategy" type="_YskVAI8AEeyggvAY1gH3cA" isReadOnly="true" association="_LGFtsY7_EeyggvAY1gH3cA">
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_LD8YoY7_EeyggvAY1gH3cA" value="new StraightStrategy()"/>
