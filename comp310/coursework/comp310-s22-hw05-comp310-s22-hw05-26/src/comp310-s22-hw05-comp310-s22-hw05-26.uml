            <ownedParameter xmi:id="_LFZxP47_EeyggvAY1gH3cA" name="cmd" type="_K6L_sI7_EeyggvAY1gH3cA"/>
            <language>java</language>
            <body>cmd.apply(this, disp);
 </body>
          </ownedBehavior>
