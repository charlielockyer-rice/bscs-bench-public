            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_LFTqk47_EeyggvAY1gH3cA" name="updateState" specification="_LC2zgI7_EeyggvAY1gH3cA">
              <ownedParameter xmi:id="_LFTqlI7_EeyggvAY1gH3cA" name="source" type="_K7yiMI7_EeyggvAY1gH3cA">
                <eAnnotations xmi:id="_LFTqlY7_EeyggvAY1gH3cA" source="http://www.eclipse.org/uml2/2.0.0/UML">
                  <details xmi:id="_LFTqlo7_EeyggvAY1gH3cA" key="final"/>
                </eAnnotations>
              </ownedParameter>
              <ownedParameter xmi:id="_LFTql47_EeyggvAY1gH3cA" name="dispatcher" type="_LAeN4I7_EeyggvAY1gH3cA"/>
              <language>java</language>
              <body>dispatcher.updateAll(new IBallCmd() {
			
			@Override
			public void apply(IBall target, IDispatcher&lt;IBallCmd> disp) {
				if (target == source) {
					return;
				}
				int rSource = source.getRadius();
				int rTarget = target.getRadius();
				Point locSource = source.getLocation();
				Point locTarget = target.getLocation();
				double distance = locSource.distance(locTarget);
				double minDistance = rSource+rTarget;
			
				if (rSource+rTarget > distance) {// whatever the interaction criteria is
				        // Save the commands that were generated.   Note that each ball is doing its own interaction behavior/calculations.
						IBallCmd contextPostInteractCmd = source.interactWithThen(target, disp);
						IBallCmd otherPostInteractCmd = target.interactWithThen(source, disp);
				        
						// Run the saved commands now that both balls' interaction behaviors are complete.
						source.update(disp, contextPostInteractCmd);
						target.update(disp, otherPostInteractCmd);
					}
			}
		}
	);

	</body>
            </ownedBehavior>
