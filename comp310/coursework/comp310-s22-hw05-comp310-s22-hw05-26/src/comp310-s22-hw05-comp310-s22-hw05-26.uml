        <packagedElement xmi:type="uml:Association" xmi:id="_LGgkcY7_EeyggvAY1gH3cA" name="" memberEnd="_LGgkco7_EeyggvAY1gH3cA _LEzUQY7_EeyggvAY1gH3cA">
          <ownedEnd xmi:id="_LGgkco7_EeyggvAY1gH3cA" name="" type="_K8UtsI7_EeyggvAY1gH3cA" association="_LGgkcY7_EeyggvAY1gH3cA"/>
