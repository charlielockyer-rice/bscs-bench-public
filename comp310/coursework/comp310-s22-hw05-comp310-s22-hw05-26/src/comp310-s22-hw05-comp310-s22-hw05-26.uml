              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_LEB4MY7_EeyggvAY1gH3cA" value="1.0"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_LEB4M47_EeyggvAY1gH3cA" name="preAT" visibility="protected" type="_LA3PcI7_EeyggvAY1gH3cA" association="_LGG7047_EeyggvAY1gH3cA">
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_LEB4NI7_EeyggvAY1gH3cA" value="new AffineTransform()"/>
            </ownedAttribute>
