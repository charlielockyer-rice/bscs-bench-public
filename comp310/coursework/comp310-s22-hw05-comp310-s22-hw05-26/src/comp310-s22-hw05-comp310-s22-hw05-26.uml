          <packagedElement xmi:type="uml:Class" xmi:id="_K6Y0AI7_EeyggvAY1gH3cA" name="CloneTraitsStrategy">
            <ownedComment xmi:id="_LFfQx47_EeyggvAY1gH3cA">
              <body>If the criteria is met, the balls will be set to have the same inherent traits (radius and color)
Unlike the infect strategy, the ball that passes its traits is arbitrary, so you get to see an
evolution of sorts within the population, like if smaller balls or larger balls are more likely to
pass traits based on average number of interactions.
@author charlielockyer
 *</body>
            </ownedComment>
            <interfaceRealization xmi:id="_LAsQUY7_EeyggvAY1gH3cA" client="_K6Y0AI7_EeyggvAY1gH3cA" supplier="_K6lBQI7_EeyggvAY1gH3cA" contract="_K6lBQI7_EeyggvAY1gH3cA"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_LFLHsI7_EeyggvAY1gH3cA" name="interactWith" specification="_LCPvgI7_EeyggvAY1gH3cA">
              <ownedParameter xmi:id="_LFLHsY7_EeyggvAY1gH3cA" name="context" type="_K7yiMI7_EeyggvAY1gH3cA"/>
              <ownedParameter xmi:id="_LFLHso7_EeyggvAY1gH3cA" name="target" type="_K7yiMI7_EeyggvAY1gH3cA"/>
              <ownedParameter xmi:id="_LFLHs47_EeyggvAY1gH3cA" name="disp" type="_LAeN4I7_EeyggvAY1gH3cA"/>
              <ownedParameter xmi:id="_LFLHtI7_EeyggvAY1gH3cA" type="_K6L_sI7_EeyggvAY1gH3cA" direction="return"/>
              <language>java</language>
              <body>return new IBallCmd() {
			public void apply(IBall ball, IDispatcher&lt;IBallCmd> disp) {
				ball.setRadius(target.getRadius());
				ball.setColor(target.getColor());
				
			}
		};
	</body>
            </ownedBehavior>
            <ownedOperation xmi:id="_LAs3YI7_EeyggvAY1gH3cA" name="init">
              <ownedParameter xmi:id="_LAs3YY7_EeyggvAY1gH3cA" name="context" type="_K7yiMI7_EeyggvAY1gH3cA"/>
            </ownedOperation>
