            </ownedOperation>
            <ownedOperation xmi:id="_LAwhxI7_EeyggvAY1gH3cA" name="init">
              <ownedParameter xmi:id="_LAwhxY7_EeyggvAY1gH3cA" name="context" type="_K7yiMI7_EeyggvAY1gH3cA"/>
            </ownedOperation>
            <ownedOperation xmi:id="_LCQ9oI7_EeyggvAY1gH3cA" name="interactWith" method="_LFLHtY7_EeyggvAY1gH3cA">
              <ownedParameter xmi:id="_LCQ9oY7_EeyggvAY1gH3cA" name="source" type="_K7yiMI7_EeyggvAY1gH3cA"/>
              <ownedParameter xmi:id="_LCQ9oo7_EeyggvAY1gH3cA" name="target" type="_K7yiMI7_EeyggvAY1gH3cA"/>
              <ownedParameter xmi:id="_LCQ9o47_EeyggvAY1gH3cA" name="disp" type="_LAeN4I7_EeyggvAY1gH3cA"/>
