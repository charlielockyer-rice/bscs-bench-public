            <ownedAttribute xmi:id="_LEcu8Y7_EeyggvAY1gH3cA" name="firstStrategy" visibility="private" type="_YskVAI8AEeyggvAY1gH3cA" association="_LGNphI7_EeyggvAY1gH3cA"/>
            <ownedAttribute xmi:id="_LEcu847_EeyggvAY1gH3cA" name="secondStrategy" visibility="private" type="_YskVAI8AEeyggvAY1gH3cA" association="_LGOQkY7_EeyggvAY1gH3cA"/>
            <interfaceRealization xmi:id="_Yt8OAo8AEeyggvAY1gH3cA" client="_K7lG0I7_EeyggvAY1gH3cA" supplier="_YskVAI8AEeyggvAY1gH3cA" contract="_YskVAI8AEeyggvAY1gH3cA"/>
