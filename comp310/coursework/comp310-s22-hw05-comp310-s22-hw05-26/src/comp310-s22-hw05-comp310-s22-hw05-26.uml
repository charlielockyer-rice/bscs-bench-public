        <packagedElement xmi:type="uml:Package" xmi:id="_K3tTcI7_EeyggvAY1gH3cA" name="interactStrategies">
          <packagedElement xmi:type="uml:Class" xmi:id="_K6VwsI7_EeyggvAY1gH3cA" name="AttractStrategy">
            <ownedComment xmi:id="_LFfQxo7_EeyggvAY1gH3cA">
              <body>A strategy in which balls that interact are attracted to one another in a way that appears magnetic
@author charlielockyer
 *</body>
            </ownedComment>
            <ownedAttribute xmi:id="_LD8_sI7_EeyggvAY1gH3cA" name="attractNudge" visibility="package" isLeaf="true" isStatic="true" isReadOnly="true">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#double"/>
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_LD8_sY7_EeyggvAY1gH3cA" value="0.0025"/>
            </ownedAttribute>
            <interfaceRealization xmi:id="_LAqbIY7_EeyggvAY1gH3cA" client="_K6VwsI7_EeyggvAY1gH3cA" supplier="_K6lBQI7_EeyggvAY1gH3cA" contract="_K6lBQI7_EeyggvAY1gH3cA"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_LFKgoo7_EeyggvAY1gH3cA" name="interactWith" specification="_LCOhYI7_EeyggvAY1gH3cA">
              <ownedParameter xmi:id="_LFKgo47_EeyggvAY1gH3cA" name="source" type="_K7yiMI7_EeyggvAY1gH3cA"/>
              <ownedParameter xmi:id="_LFKgpI7_EeyggvAY1gH3cA" name="target" type="_K7yiMI7_EeyggvAY1gH3cA"/>
              <ownedParameter xmi:id="_LFKgpY7_EeyggvAY1gH3cA" name="disp" type="_LAeN4I7_EeyggvAY1gH3cA"/>
              <ownedParameter xmi:id="_LFKgpo7_EeyggvAY1gH3cA" type="_K6L_sI7_EeyggvAY1gH3cA" direction="return"/>
              <language>java</language>
              <body>// &quot;source&quot; ball is the &quot;context&quot; of the strategy.  The &quot;target&quot; ball is the ball receiving the command from the source ball's strategy.
		
		return new IBallCmd() {
			
			public void apply(IBall ball, IDispatcher&lt;IBallCmd> disp) {
				Point attractVector = new Point((int)((target.getLocation().x - source.getLocation().x) * attractNudge), (int)((target.getLocation().y - source.getLocation().y) * attractNudge));
				ball.setVelocity(new Point(ball.getVelocity().x + attractVector.x, ball.getVelocity().y + attractVector.y));

			}
		};
	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_LFKgp47_EeyggvAY1gH3cA" name="init" specification="_LArCMI7_EeyggvAY1gH3cA">
              <ownedParameter xmi:id="_LFKgqI7_EeyggvAY1gH3cA" name="context" type="_K7yiMI7_EeyggvAY1gH3cA"/>
              <language>java</language>
              <body>// TODO Auto-generated method stub
		
	</body>
            </ownedBehavior>
            <ownedOperation xmi:id="_LArCMI7_EeyggvAY1gH3cA" name="init" method="_LFKgp47_EeyggvAY1gH3cA">
              <ownedParameter xmi:id="_LArCMY7_EeyggvAY1gH3cA" name="context" type="_K7yiMI7_EeyggvAY1gH3cA"/>
            </ownedOperation>
            <ownedOperation xmi:id="_LCOhYI7_EeyggvAY1gH3cA" name="interactWith" method="_LFKgoo7_EeyggvAY1gH3cA">
              <ownedParameter xmi:id="_LCOhYY7_EeyggvAY1gH3cA" name="source" type="_K7yiMI7_EeyggvAY1gH3cA"/>
              <ownedParameter xmi:id="_LCOhYo7_EeyggvAY1gH3cA" name="target" type="_K7yiMI7_EeyggvAY1gH3cA"/>
              <ownedParameter xmi:id="_LCOhY47_EeyggvAY1gH3cA" name="disp" type="_LAeN4I7_EeyggvAY1gH3cA"/>
              <ownedParameter xmi:id="_LCOhZI7_EeyggvAY1gH3cA" type="_K6L_sI7_EeyggvAY1gH3cA" direction="return"/>
            </ownedOperation>
