          <packagedElement xmi:type="uml:Class" xmi:id="_K7auwI7_EeyggvAY1gH3cA" name="BreathingStrategy">
            <ownedComment xmi:id="_YuKQdI8AEeyggvAY1gH3cA">
              <body>An update strategy that makes the ball grow and shrink in a cyclic pattern</body>
            </ownedComment>
            <ownedAttribute xmi:id="_LEZroI7_EeyggvAY1gH3cA" name="sineMaker" visibility="package" type="_LBQRAI7_EeyggvAY1gH3cA" association="_LGLNQ47_EeyggvAY1gH3cA">
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_LEZroY7_EeyggvAY1gH3cA" value="new SineMaker(5, 20, 0.2)"/>
            </ownedAttribute>
            <interfaceRealization xmi:id="_Yt6_4Y8AEeyggvAY1gH3cA" client="_K7auwI7_EeyggvAY1gH3cA" supplier="_YskVAI8AEeyggvAY1gH3cA" contract="_YskVAI8AEeyggvAY1gH3cA"/>
