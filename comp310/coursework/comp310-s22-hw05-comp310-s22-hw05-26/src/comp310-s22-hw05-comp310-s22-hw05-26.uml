                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_LFScfI7_EeyggvAY1gH3cA" value="*"/>
              </ownedParameter>
              <ownedParameter xmi:id="_LFScfY7_EeyggvAY1gH3cA" type="_K7SL4I7_EeyggvAY1gH3cA" direction="return"/>
              <language>java</language>
              <body>this.at = at;
		this.scaleFactor = scaleFactor;
		this.poly = new Polygon();
		for (Point pt : pts) {
			this.poly.addPoint(pt.x, pt.y);
		}
	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_LFScfo7_EeyggvAY1gH3cA" name="makeShape" specification="_K7TaAI7_EeyggvAY1gH3cA">
