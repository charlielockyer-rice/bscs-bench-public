          <packagedElement xmi:type="uml:Class" xmi:id="_K7njEI7_EeyggvAY1gH3cA" name="OverlapStrategy">
            <interfaceRealization xmi:id="_Yt81FY8AEeyggvAY1gH3cA" client="_K7njEI7_EeyggvAY1gH3cA" supplier="_YskVAI8AEeyggvAY1gH3cA" contract="_YskVAI8AEeyggvAY1gH3cA"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_LFU4t47_EeyggvAY1gH3cA" name="updateState" specification="_LDAkgI7_EeyggvAY1gH3cA">
              <ownedParameter xmi:id="_LFU4uI7_EeyggvAY1gH3cA" name="source" type="_K7yiMI7_EeyggvAY1gH3cA">
                <eAnnotations xmi:id="_LFU4uY7_EeyggvAY1gH3cA" source="http://www.eclipse.org/uml2/2.0.0/UML">
                  <details xmi:id="_LFU4uo7_EeyggvAY1gH3cA" key="final"/>
                </eAnnotations>
              </ownedParameter>
              <ownedParameter xmi:id="_LFU4u47_EeyggvAY1gH3cA" name="disp" type="_LAeN4I7_EeyggvAY1gH3cA"/>
              <language>java</language>
              <body>disp.updateAll(new IBallCmd() {

			@Override
			public void apply(IBall target, IDispatcher&lt;IBallCmd> disp) {
				if (source != target) {
					if ((source.getRadius() + target.getRadius()) > (source.getLocation().distance(target.getLocation()))) {
						IBallCmd sourceCmd = source.interactWithThen(target, disp);
						IBallCmd targetCmd = target.interactWithThen(source, disp);
						source.update(disp, sourceCmd);
						target.update(disp, targetCmd);

					}
				}
				
			}
			
		});
		
	</body>
            </ownedBehavior>
