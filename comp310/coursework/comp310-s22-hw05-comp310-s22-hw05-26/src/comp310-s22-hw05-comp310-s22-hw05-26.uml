            <interfaceRealization xmi:id="_Yt8OAI8AEeyggvAY1gH3cA" client="_K7iDgI7_EeyggvAY1gH3cA" supplier="_YskVAI8AEeyggvAY1gH3cA" contract="_YskVAI8AEeyggvAY1gH3cA"/>
