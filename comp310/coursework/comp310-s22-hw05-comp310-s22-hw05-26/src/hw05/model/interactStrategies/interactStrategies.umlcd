  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_1vFecI7_EeyggvAY1gH3cA" sourceConnectionVisual="_1vFecY7_EeyggvAY1gH3cA" text="A strategy in which balls that interact are attracted to one another in a way that appears magnetic&#xA;@author charlielockyer&#xA; *" item="_1vGFgI7_EeyggvAY1gH3cA">
