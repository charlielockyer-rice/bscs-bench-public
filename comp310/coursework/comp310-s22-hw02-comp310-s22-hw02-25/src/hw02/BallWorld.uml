        <packagedElement xmi:type="uml:Class" xmi:id="_EHzSgH0PEeyOAbB1Mx5Bgw" name="BallModel">
          <ownedComment xmi:id="_O1rKcH0PEeyOAbB1Mx5Bgw">
            <body>@author rlmse&#xD;
A model representing a collection of independently moving balls in a 2D plane</body>
          </ownedComment>
          <ownedAttribute xmi:id="_EJSgQH0PEeyOAbB1Mx5Bgw" name="timeSlice" visibility="private" isLeaf="true" isStatic="true" isReadOnly="true">
            <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
            <defaultValue xmi:type="uml:LiteralString" xmi:id="_EJTHUH0PEeyOAbB1Mx5Bgw" value="50"/>
          </ownedAttribute>
          <ownedAttribute xmi:id="_EJTHUX0PEeyOAbB1Mx5Bgw" name="model2ViewAdpt" visibility="private" type="_EH6nQH0PEeyOAbB1Mx5Bgw" association="_EJhJw30PEeyOAbB1Mx5Bgw">
            <defaultValue xmi:type="uml:LiteralString" xmi:id="_EJTHUn0PEeyOAbB1Mx5Bgw" value="IModel2ViewAdapter.NULL_OBJECT"/>
          </ownedAttribute>
          <ownedAttribute xmi:id="_EJTHVH0PEeyOAbB1Mx5Bgw" name="timer" visibility="private" type="_EI3pgX0PEeyOAbB1Mx5Bgw" association="_EJhw0X0PEeyOAbB1Mx5Bgw">
            <defaultValue xmi:type="uml:LiteralString" xmi:id="_EJTHVX0PEeyOAbB1Mx5Bgw" value="new Timer(timeSlice, (e) -> model2ViewAdpt.update())"/>
          </ownedAttribute>
          <ownedAttribute xmi:id="_EJTuYX0PEeyOAbB1Mx5Bgw" name="ballDispatcher" visibility="private" type="_EI0mMn0PEeyOAbB1Mx5Bgw" association="_EJhw1H0PEeyOAbB1Mx5Bgw">
            <defaultValue xmi:type="uml:LiteralString" xmi:id="_EJTuY30PEeyOAbB1Mx5Bgw" value="new SequentialDispatcher&lt;Graphics>()"/>
          </ownedAttribute>
          <ownedAttribute xmi:id="_EJTuZX0PEeyOAbB1Mx5Bgw" name="loader" visibility="private" isLeaf="true" type="_EI43on0PEeyOAbB1Mx5Bgw" isReadOnly="true" association="_EJiX4X0PEeyOAbB1Mx5Bgw">
            <defaultValue xmi:type="uml:LiteralString" xmi:id="_EJUVcX0PEeyOAbB1Mx5Bgw" value="new ObjectLoader&lt;IObserver&lt;Graphics>>(&#xD;&#xA;&#x9;&#x9;&#x9;args -> new ErrorBall(model2ViewAdpt.getDimension()))"/>
          </ownedAttribute>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_EJbDLH0PEeyOAbB1Mx5Bgw" name="BallModel" specification="_EI6s0H0PEeyOAbB1Mx5Bgw">
            <ownedParameter xmi:id="_EJbDLX0PEeyOAbB1Mx5Bgw" name="model2ViewAdpt" type="_EH6nQH0PEeyOAbB1Mx5Bgw"/>
            <ownedParameter xmi:id="_EJbDLn0PEeyOAbB1Mx5Bgw" type="_EHzSgH0PEeyOAbB1Mx5Bgw" direction="return">
              <name xsi:nil="true"/>
            </ownedParameter>
            <language>java</language>
            <body>this.model2ViewAdpt = model2ViewAdpt;&#xD;
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_EJbqMH0PEeyOAbB1Mx5Bgw" name="update" specification="_EJIvQH0PEeyOAbB1Mx5Bgw">
            <ownedParameter xmi:id="_EJbqMX0PEeyOAbB1Mx5Bgw" name="g" type="_EIz_IX0PEeyOAbB1Mx5Bgw"/>
            <language>java</language>
            <body>ballDispatcher.updateAll(g);&#xD;
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_EJbqMn0PEeyOAbB1Mx5Bgw" name="getTimeSlice" specification="_EHz5kH0PEeyOAbB1Mx5Bgw">
            <ownedParameter xmi:id="_EJbqM30PEeyOAbB1Mx5Bgw" direction="return">
              <name xsi:nil="true"/>
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
            </ownedParameter>
            <language>java</language>
            <body>return timeSlice;&#xD;
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_EJbqNH0PEeyOAbB1Mx5Bgw" name="makeBall" specification="_EHz5kn0PEeyOAbB1Mx5Bgw">
            <ownedParameter xmi:id="_EJbqNX0PEeyOAbB1Mx5Bgw" name="ballType">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
            </ownedParameter>
            <language>java</language>
            <body>IObserver&lt;Graphics> ball = this.loader.loadInstance(ballType, Randomizer.Singleton.randomColor(),&#xD;
				Randomizer.Singleton.randomLoc(new Rectangle(this.model2ViewAdpt.getDimension().getWidth(),&#xD;
						this.model2ViewAdpt.getDimension().getHeight())),&#xD;
				Randomizer.Singleton.randomVel(new Rectangle(20, 20)), Randomizer.Singleton.randomInt(10, 20),&#xD;
				this.model2ViewAdpt.getDimension());&#xD;
&#xD;
		this.ballDispatcher.addObserver(ball);&#xD;
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_EJbqNn0PEeyOAbB1Mx5Bgw" name="clearBalls" specification="_EH0goH0PEeyOAbB1Mx5Bgw">
            <language>java</language>
            <body>this.ballDispatcher.removeAllObservers();&#xD;
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_EJbqN30PEeyOAbB1Mx5Bgw" name="start" specification="_EH0goX0PEeyOAbB1Mx5Bgw">
            <language>java</language>
            <body>this.timer.start();&#xD;
	</body>
          </ownedBehavior>
          <ownedOperation xmi:id="_EHz5kH0PEeyOAbB1Mx5Bgw" name="getTimeSlice" isStatic="true" method="_EJbqMn0PEeyOAbB1Mx5Bgw">
            <ownedComment xmi:id="_O1rKc30PEeyOAbB1Mx5Bgw">
              <body>@return the period of the model refresh</body>
            </ownedComment>
            <ownedParameter xmi:id="_EHz5kX0PEeyOAbB1Mx5Bgw" direction="return">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
            </ownedParameter>
          </ownedOperation>
          <ownedOperation xmi:id="_EHz5kn0PEeyOAbB1Mx5Bgw" name="makeBall" method="_EJbqNH0PEeyOAbB1Mx5Bgw">
            <ownedComment xmi:id="_O1rKdH0PEeyOAbB1Mx5Bgw">
              <body>Generates an ABall&#xD;
	 * @param ballType - the type of ABall to be generated. Input from the view</body>
            </ownedComment>
            <ownedParameter xmi:id="_EHz5k30PEeyOAbB1Mx5Bgw" name="ballType">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
            </ownedParameter>
          </ownedOperation>
          <ownedOperation xmi:id="_EH0goH0PEeyOAbB1Mx5Bgw" name="clearBalls" method="_EJbqNn0PEeyOAbB1Mx5Bgw">
            <ownedComment xmi:id="_O1rKdX0PEeyOAbB1Mx5Bgw">
              <body>Unsubscribe all current balls from the dispatcher, thus removing them from the view</body>
            </ownedComment>
          </ownedOperation>
          <ownedOperation xmi:id="_EH0goX0PEeyOAbB1Mx5Bgw" name="start" method="_EJbqN30PEeyOAbB1Mx5Bgw">
            <ownedComment xmi:id="_O1rKdn0PEeyOAbB1Mx5Bgw">
              <body>Start the timer of the model, thus beginning to update the status of the balls in the model</body>
            </ownedComment>
          </ownedOperation>
          <ownedOperation xmi:id="_EI6s0H0PEeyOAbB1Mx5Bgw" name="BallModel" method="_EJbDLH0PEeyOAbB1Mx5Bgw">
