              <name xsi:nil="true"/>
            </ownedParameter>
            <language>java</language>
            <body>super(color, position, velocity, diameter, dimension);&#xD;
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_EJcRQH0PEeyOAbB1Mx5Bgw" name="bounce" specification="_EH2V0H0PEeyOAbB1Mx5Bgw">
            <ownedParameter xmi:id="_EJcRQX0PEeyOAbB1Mx5Bgw" direction="return">
              <name xsi:nil="true"/>
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#boolean"/>
            </ownedParameter>
            <language>java</language>
            <body>if (super.bounce()) {&#xD;
			this.color = Randomizer.Singleton.randomColor();&#xD;
			return true;&#xD;
		}&#xD;
		return false;&#xD;
	</body>
          </ownedBehavior>
          <ownedOperation xmi:id="_EH2V0H0PEeyOAbB1Mx5Bgw" name="bounce" method="_EJcRQH0PEeyOAbB1Mx5Bgw">
