              <details xmi:id="_EI6s030PEeyOAbB1Mx5Bgw" key="create"/>
            </eAnnotations>
            <ownedComment xmi:id="_O1rKcX0PEeyOAbB1Mx5Bgw">
              <body>Construct a new model&#xD;
	 * @param model2ViewAdpt - the adapter allowing the model to communicate with the view</body>
            </ownedComment>
