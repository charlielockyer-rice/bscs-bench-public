        <packagedElement xmi:type="uml:Class" xmi:id="_EH1uwH0PEeyOAbB1Mx5Bgw" name="DVDLogoBall">
          <ownedComment xmi:id="_O1rKeH0PEeyOAbB1Mx5Bgw">
            <body>@author rlmse&#xD;
A ball which changes color when it hits a boundary, like the logo in the DVD idle screen</body>
          </ownedComment>
