              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
            </ownedParameter>
            <ownedParameter xmi:id="_EJbDKH0PEeyOAbB1Mx5Bgw" name="dimension" type="_EI1NQX0PEeyOAbB1Mx5Bgw"/>
            <ownedParameter xmi:id="_EJbDKX0PEeyOAbB1Mx5Bgw" type="_EHxdUH0PEeyOAbB1Mx5Bgw" direction="return">
              <name xsi:nil="true"/>
            </ownedParameter>
            <language>java</language>
            <body>super(color, position, velocity, diameter, dimension);&#xD;
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_EJbDKn0PEeyOAbB1Mx5Bgw" name="updateState" specification="_EJHhKX0PEeyOAbB1Mx5Bgw">
            <ownedParameter xmi:id="_EJbDK30PEeyOAbB1Mx5Bgw" name="disp" type="_EI0mMn0PEeyOAbB1Mx5Bgw"/>
            <language>java</language>
            <body>this.diameter = this.position.x &lt; 50 ? 5 : this.position.x / 5;&#xD;
	</body>
          </ownedBehavior>
