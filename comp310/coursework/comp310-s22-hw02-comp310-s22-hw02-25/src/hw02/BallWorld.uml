        <packagedElement xmi:type="uml:Class" xmi:id="_EHxdUH0PEeyOAbB1Mx5Bgw" name="BounceUpBall">
          <ownedComment xmi:id="_O1rKd30PEeyOAbB1Mx5Bgw">
            <body>@author rlmse&#xD;
A ball that forces perspective, appearing as if it is bouncing out of the screen when moving&#xD;
right and as if it is bouncing away from the screen when moving left.</body>
          </ownedComment>
          <generalization xmi:id="_EI2bYH0PEeyOAbB1Mx5Bgw" general="_EH3j8H0PEeyOAbB1Mx5Bgw"/>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_EJbDI30PEeyOAbB1Mx5Bgw" name="BounceUpBall" specification="_EJHhIH0PEeyOAbB1Mx5Bgw">
            <ownedParameter xmi:id="_EJbDJH0PEeyOAbB1Mx5Bgw" name="color" type="_EIzYEH0PEeyOAbB1Mx5Bgw"/>
