              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_EJdfZ30PEeyOAbB1Mx5Bgw" value="*"/>
            </ownedParameter>
            <language>java</language>
            <body>BallController controller = new BallController();&#xD;
		controller.start();&#xD;
	</body>
          </ownedBehavior>
