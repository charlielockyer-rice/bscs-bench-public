            <defaultValue xmi:type="uml:LiteralString" xmi:id="_EJZN8n0PEeyOAbB1Mx5Bgw" value="new JPanel() {&#xD;&#xA;&#x9;&#x9;/**&#xD;&#xA;&#x9;&#x9; * Auto-generated ID&#xD;&#xA;&#x9;&#x9; */&#xD;&#xA;&#x9;&#x9;private static final long serialVersionUID = -3824415969248765824L;&#xD;&#xA;&#xD;&#xA;&#x9;&#x9;@Override&#xD;&#xA;&#x9;&#x9;public void paintComponent(Graphics g) {&#xD;&#xA;&#x9;&#x9;&#x9;super.paintComponent(g);&#xD;&#xA;&#x9;&#x9;&#x9;ViewGUI.this.view2ModelAdpt.paintBalls(g);&#xD;&#xA;&#x9;&#x9;}&#xD;&#xA;&#x9;}"/>
          </ownedAttribute>
          <ownedAttribute xmi:id="_EJZ1AX0PEeyOAbB1Mx5Bgw" name="view2ModelAdpt" visibility="private" isLeaf="true" type="_EH-4sH0PEeyOAbB1Mx5Bgw" isReadOnly="true" association="_EJmpUX0PEeyOAbB1Mx5Bgw"/>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_EJeGcn0PEeyOAbB1Mx5Bgw" name="ViewGUI" specification="_EJCooH0PEeyOAbB1Mx5Bgw">
