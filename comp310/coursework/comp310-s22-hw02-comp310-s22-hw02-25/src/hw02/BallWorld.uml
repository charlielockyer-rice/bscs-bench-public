          </ownedAttribute>
          <ownedAttribute xmi:id="_EJVjk30PEeyOAbB1Mx5Bgw" name="dimension" visibility="protected" type="_EI1NQX0PEeyOAbB1Mx5Bgw" association="_EJjmAX0PEeyOAbB1Mx5Bgw"/>
          <interfaceRealization xmi:id="_EJKkc30PEeyOAbB1Mx5Bgw" client="_EH3j8H0PEeyOAbB1Mx5Bgw" supplier="_EI4QkX0PEeyOAbB1Mx5Bgw" contract="_EI4QkX0PEeyOAbB1Mx5Bgw"/>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_EJcRQn0PEeyOAbB1Mx5Bgw" name="ABall" specification="_EJLykH0PEeyOAbB1Mx5Bgw">
            <ownedParameter xmi:id="_EJcRQ30PEeyOAbB1Mx5Bgw" name="color" type="_EIzYEH0PEeyOAbB1Mx5Bgw"/>
            <ownedParameter xmi:id="_EJcRRH0PEeyOAbB1Mx5Bgw" name="position" type="_EI0mMH0PEeyOAbB1Mx5Bgw"/>
            <ownedParameter xmi:id="_EJcRRX0PEeyOAbB1Mx5Bgw" name="velocity" type="_EI0mMH0PEeyOAbB1Mx5Bgw"/>
            <ownedParameter xmi:id="_EJcRRn0PEeyOAbB1Mx5Bgw" name="diameter">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
            </ownedParameter>
            <ownedParameter xmi:id="_EJcRR30PEeyOAbB1Mx5Bgw" name="dimension" type="_EI1NQX0PEeyOAbB1Mx5Bgw"/>
            <ownedParameter xmi:id="_EJcRSH0PEeyOAbB1Mx5Bgw" type="_EH3j8H0PEeyOAbB1Mx5Bgw" direction="return">
              <name xsi:nil="true"/>
            </ownedParameter>
            <language>java</language>
            <body>this.color = color;&#xD;
		this.position = position;&#xD;
		this.velocity = velocity;&#xD;
		this.diameter = diameter;&#xD;
		this.dimension = dimension;&#xD;
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_EJcRSX0PEeyOAbB1Mx5Bgw" name="paint" specification="_EJMZoH0PEeyOAbB1Mx5Bgw">
            <ownedParameter xmi:id="_EJcRSn0PEeyOAbB1Mx5Bgw" name="g" type="_EIz_IX0PEeyOAbB1Mx5Bgw"/>
            <language>java</language>
            <body>g.setColor(this.color);&#xD;
		g.fillOval(this.position.x, this.position.y, diameter, diameter);&#xD;
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_EJc4UH0PEeyOAbB1Mx5Bgw" name="move" specification="_EH4LAH0PEeyOAbB1Mx5Bgw">
            <language>java</language>
            <body>this.position.x += this.velocity.x;&#xD;
		this.position.y += this.velocity.y;&#xD;
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_EJc4UX0PEeyOAbB1Mx5Bgw" name="bounce" specification="_EH4yEH0PEeyOAbB1Mx5Bgw">
            <ownedParameter xmi:id="_EJc4Un0PEeyOAbB1Mx5Bgw" direction="return">
              <name xsi:nil="true"/>
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#boolean"/>
            </ownedParameter>
            <language>java</language>
            <body>if (this.position.x &lt; 0 || this.position.x > this.dimension.getWidth() - this.diameter) {&#xD;
			this.velocity.x = -this.velocity.x;&#xD;
			if (this.position.x &lt; 0) {&#xD;
				this.position.x = -this.position.x;&#xD;
			} else {&#xD;
				this.position.x = 2 * this.dimension.getWidth() - this.position.x - this.diameter * 2;&#xD;
			}&#xD;
			return true;&#xD;
		}&#xD;
&#xD;
		if (this.position.y &lt; 0 || this.position.y > this.dimension.getHeight() - this.diameter) {&#xD;
			this.velocity.y = -this.velocity.y;&#xD;
			if (this.position.y &lt; 0) {&#xD;
				this.position.y = -this.position.y;&#xD;
			} else {&#xD;
				this.position.y = 2 * this.dimension.getHeight() - this.position.y - this.diameter * 2;&#xD;
			}&#xD;
			return true;&#xD;
		}&#xD;
		return false;&#xD;
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_EJc4U30PEeyOAbB1Mx5Bgw" name="update" specification="_EJNAsX0PEeyOAbB1Mx5Bgw">
            <ownedParameter xmi:id="_EJc4VH0PEeyOAbB1Mx5Bgw" name="disp" type="_EI0mMn0PEeyOAbB1Mx5Bgw"/>
            <ownedParameter xmi:id="_EJc4VX0PEeyOAbB1Mx5Bgw" name="g" type="_EIz_IX0PEeyOAbB1Mx5Bgw"/>
            <language>java</language>
            <body>this.updateState(disp);&#xD;
		this.move();&#xD;
		this.bounce();&#xD;
		this.paint(g);&#xD;
	</body>
          </ownedBehavior>
