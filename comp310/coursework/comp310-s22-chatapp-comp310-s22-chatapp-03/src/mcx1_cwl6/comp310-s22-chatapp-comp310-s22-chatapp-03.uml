              <ownedParameter xmi:id="_qhE41ayWEeyB76_OUW-bXg" type="_qf_TsKyWEeyB76_OUW-bXg" direction="return"/>
              <language>java</language>
              <body>view = new ChatRoomView(new IMiniView2ModelAdapter() {

			@Override
			public void sendText(String textMsg) {
				model.sendText(textMsg);
				
			}

			@Override
			public void sendUnknown() {
				model.sendUnknown();
				
			}

			
			
		});

		model = new ChatRoomModel(chatroom, config, userConnector, m2MAdpt, new IMiniModel2ViewAdapter() {

			@Override
			public void displayText(String str) {
				view.displayText(str);
			}

			@Override
			public void displayComponent(String label, Supplier&lt;JComponent> fac) {
				view.displayComponent(label, fac);
			}
		});
	</body>
            </ownedBehavior>
