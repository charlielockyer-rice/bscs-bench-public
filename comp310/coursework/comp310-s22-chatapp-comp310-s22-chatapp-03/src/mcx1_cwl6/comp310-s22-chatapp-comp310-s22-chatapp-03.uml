            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_th7auayWEeyB76_OUW-bXg" name="ChatRoomView" specification="_thPeMKyWEeyB76_OUW-bXg">
              <ownedParameter xmi:id="_th7auqyWEeyB76_OUW-bXg" name="v2mAdpt" type="_qgtscKyWEeyB76_OUW-bXg"/>
              <ownedParameter xmi:id="_th7au6yWEeyB76_OUW-bXg" type="_qgx94ayWEeyB76_OUW-bXg" direction="return"/>
              <language>java</language>
              <body>this.v2mAdpt = v2mAdpt;
		initGUI();
	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_th8BwKyWEeyB76_OUW-bXg" name="start" specification="_tez1QKyWEeyB76_OUW-bXg">
              <language>java</language>
              <body>setVisible(true);		
	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_th8BwayWEeyB76_OUW-bXg" name="initGUI" specification="_te0cUKyWEeyB76_OUW-bXg">
              <language>java</language>
              <body>setLayout(new BorderLayout(0, 0));
		add(mainPanel);
		mainPanel.setLayout(new BorderLayout(0, 0));
		mainPanel.add(messagePanel, BorderLayout.SOUTH);
		
		textingPanel.setBorder(new TitledBorder(new EtchedBorder(EtchedBorder.LOWERED, new Color(255, 255, 255), new Color(160, 160, 160)), &quot;Send Message&quot;, TitledBorder.LEADING, TitledBorder.TOP, null, new Color(0, 0, 0)));
		messagePanel.add(textingPanel);
		messageTextField.setToolTipText(&quot;Message to send&quot;);
		
		textingPanel.add(messageTextField);
		messageTextField.setColumns(10);
		sendMessageBtn.setToolTipText(&quot;Send a message&quot;);
		sendMessageBtn.addActionListener(new ActionListener() {
			public void actionPerformed(ActionEvent e) {
				v2mAdpt.sendText(messageTextField.getText());
			}
		});
		
		textingPanel.add(sendMessageBtn);
		sendUnknownButton.addActionListener(new ActionListener() {
			public void actionPerformed(ActionEvent e) {
				v2mAdpt.sendUnknown();
			}
		});
		
		textingPanel.add(sendUnknownButton);
		
		
		
		mainPanel.add(textArea, BorderLayout.CENTER);
		
		
		//frame.getContentPane().add(chatPanel, BorderLayout.CENTER);
		chatPanel.setLayout(new GridLayout(1, 0, 0, 0));
		textAreaChatRoom.setBackground(Color.WHITE);
		textAreaChatRoom.setToolTipText(&quot;Displays messages send&quot;);
		
		
		chatPanel.add(textAreaChatRoom);
	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_th8BwqyWEeyB76_OUW-bXg" name="displayText" specification="_te0cUayWEeyB76_OUW-bXg">
