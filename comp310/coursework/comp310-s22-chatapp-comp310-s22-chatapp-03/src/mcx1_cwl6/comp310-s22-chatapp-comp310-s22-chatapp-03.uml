            <ownedComment xmi:id="_ksoYhKyXEeyB76_OUW-bXg">
              <body>The ChatApp Controller</body>
            </ownedComment>
            <ownedAttribute xmi:id="_kskuIKyXEeyB76_OUW-bXg" name="sysLogger" visibility="private" type="_tg4R0ayWEeyB76_OUW-bXg" association="_kspmoKyXEeyB76_OUW-bXg">
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_kskuIayXEeyB76_OUW-bXg" value="ILoggerControl.getSharedLogger()"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_kskuI6yXEeyB76_OUW-bXg" name="model" visibility="private" type="_kseAcKyXEeyB76_OUW-bXg" association="_kspmo6yXEeyB76_OUW-bXg"/>
