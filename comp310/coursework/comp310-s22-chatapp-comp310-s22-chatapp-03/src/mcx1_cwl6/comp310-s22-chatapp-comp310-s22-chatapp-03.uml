            <ownedAttribute xmi:id="_lxoRsKyXEeyB76_OUW-bXg" name="rMIUtils" isReadOnly="true"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_lxr8EKyXEeyB76_OUW-bXg" name="ChatAppModel" specification="_lxZBIKyXEeyB76_OUW-bXg">
              <ownedParameter xmi:id="_lxr8EayXEeyB76_OUW-bXg" name="logger" type="_tg4R0ayWEeyB76_OUW-bXg"/>
              <ownedParameter xmi:id="_lxr8EqyXEeyB76_OUW-bXg" name="config" type="_qgzMAKyWEeyB76_OUW-bXg"/>
              <ownedParameter xmi:id="_lxr8E6yXEeyB76_OUW-bXg" name="m2vAdpt" type="_ksengayXEeyB76_OUW-bXg"/>
              <ownedParameter xmi:id="_lxr8FKyXEeyB76_OUW-bXg" type="_kseAcKyXEeyB76_OUW-bXg" direction="return"/>
              <language>java</language>
              <body>this.sysLogger = logger;
		this.config = config;
		this.m2vAdpt = m2vAdpt;

		this.visitor = new ConnectionDataPacketAlgo((AConnectionDataPacketAlgoCmd&lt;? extends IConnectionMsg>)new AConnectionDataPacketAlgoCmd&lt;IConnectionMsg>() {


			/**
			 * For serialization
			 */
			private static final long serialVersionUID = 6873454406406891063L;

			@Override
			public Void apply(IDataPacketID index, ConnectionDataPacket&lt;IConnectionMsg> host, Void... params) {
				return null;
			}

		});

		viewLogger = ILoggerControl.makeLogger(new ILogEntryProcessor() {
			ILogEntryFormatter formatter = ILogEntryFormatter.MakeFormatter(&quot;[%1s] %2s&quot;); // custom log entry formatting
																							// &quot;[level] msg&quot;

			@Override
			public void accept(ILogEntry logEntry) {
				ChatAppModel.this.m2vAdpt.displayStatus(formatter.apply(logEntry));
			}

		}, LogLevel.INFO);
		viewLogger.append(sysLogger);
	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_lxr8F6yXEeyB76_OUW-bXg" name="start" specification="_lwXtcKyXEeyB76_OUW-bXg">
              <language>java</language>
              <body>try {
			// Initialize RMIUtils
			rmiUtils = new RMIUtils(sysLogger);

			// Start RMI system
			rmiUtils.startRMI(this.config.classServerPort);

			this.pubSubManager = IPubSubSyncConnection.getPubSubSyncManager(sysLogger, rmiUtils,
			 this.config.stubPort);

			// Instantiate user RMI IConnector
			localRemote = new IConnection() {

				@Override
				public void receiveMessage(ConnectionDataPacket&lt;?> packet) throws RemoteException {
					packet.execute(ChatAppModel.this.visitor);
				}


			};

			try {
				this.localStub = (IConnection) UnicastRemoteObject.exportObject(localRemote, this.config.stubPort);
			} catch (Exception e) {
				e.printStackTrace();
			}

			// Instantiate the user RMI INamedConnector
			user = new NamedConnection(ChatAppModel.this.config.name, localStub);

			// Get local registry with IRMIUtils
			registry = rmiUtils.getLocalRegistry();

			// Bing localUserStub to registry
			registry.rebind(this.config.boundName, localStub);
			viewLogger.log(LogLevel.INFO, &quot;ChatAppModel successfully started!&quot;);

		} catch (Exception e) {
			// Send error message
			viewLogger.log(LogLevel.ERROR, &quot;ChatAppModel Error Starting: &quot; + e.toString());
			e.printStackTrace();
		}

		this.visitor.setCmd(IClientSendKnownConnectionsMsg.GetID(), (AConnectionDataPacketAlgoCmd&lt;? extends IConnectionMsg>) new AConnectionDataPacketAlgoCmd&lt;IConnectionMsg>() {

			/**
			 * For serialization
			 */
			private static final long serialVersionUID = 8580911409196305413L;

			@Override
			public Void apply(IDataPacketID index, ConnectionDataPacket&lt;IConnectionMsg> host, Void... params) {
				ChatAppModel.this.connectedRemoteStubs.addAll(((IClientSendKnownConnectionsMsg) host.getData()).getClientConnections());

				ChatAppModel.this.m2vAdpt.addPeers(((IClientSendKnownConnectionsMsg) host.getData()).getClientConnections());
				
				return null;
			}

		});

		this.visitor.setCmd(IHostSendKnownConnectionsMsg.GetID(), new AConnectionDataPacketAlgoCmd&lt;IConnectionMsg>() {

			/**
			 * For serialization
			 */
			private static final long serialVersionUID = 6746376800405769245L;

			@Override
			public Void apply(IDataPacketID index, ConnectionDataPacket&lt;IConnectionMsg> host, Void... params) {
				Set&lt;INamedConnection> otherPeers = ((IHostSendKnownConnectionsMsg) host.getData()).getHostConnections();

				System.out.println(&quot;other peers: &quot; + otherPeers);
				
				HashSet&lt;INamedConnection> peersAndMyself = new HashSet&lt;INamedConnection>(
						ChatAppModel.this.connectedRemoteStubs);
				peersAndMyself.add(ChatAppModel.this.user);

				for (INamedConnection myPeer : ChatAppModel.this.connectedRemoteStubs) {
					try {
						myPeer.getConnectionStub().receiveMessage(new ConnectionDataPacket&lt;IClientSendKnownConnectionsMsg>(
								new ClientSendKnownConnectionsMsg(otherPeers), ChatAppModel.this.user));
					} catch (RemoteException e) {
						e.printStackTrace();
					}
				}

				for (INamedConnection otherPeer : otherPeers) {
					try {
						otherPeer.getConnectionStub().receiveMessage(new ConnectionDataPacket&lt;IClientSendKnownConnectionsMsg>(
								new ClientSendKnownConnectionsMsg(peersAndMyself), ChatAppModel.this.user));
					} catch (RemoteException e) {
						e.printStackTrace();
					}
				}
				ChatAppModel.this.connectedRemoteStubs.addAll(otherPeers);
				ChatAppModel.this.m2vAdpt.addPeers(otherPeers);

				return null;
			}

		});

		this.visitor.setCmd(IInviteMsg.GetID(), new AConnectionDataPacketAlgoCmd&lt;IConnectionMsg>() {

			/**
			 * For serialization
			 */
			private static final long serialVersionUID = 8211663781539296203L;

			@Override
			public Void apply(IDataPacketID index, ConnectionDataPacket&lt;IConnectionMsg> host, Void... params) {
				ChatRoom room = new ChatRoom(((IInviteMsg) host.getData()).getRoomName());
				room.setUUID(((IInviteMsg) host.getData()).getUUID());
				IMain2MiniAdapter m2mAdpt = m2vAdpt.makeMiniMVC(room, ChatAppModel.this.user);
				m2mAdpt.joinChannel(ChatAppModel.this.pubSubManager);
				ChatAppModel.this.mapRooms.put(room.getUUID(), m2mAdpt);
				ChatAppModel.this.m2vAdpt.addChatRoom(room);
				return null;
			}

		});

		this.visitor.setCmd(IQuitMsg.GetID(), new AConnectionDataPacketAlgoCmd&lt;IConnectionMsg>() {

			/**
			 * For serialization
			 */
			private static final long serialVersionUID = -106161080968934126L;

			@Override
			public Void apply(IDataPacketID index, ConnectionDataPacket&lt;IConnectionMsg> host, Void... params) {
				ChatAppModel.this.connectedRemoteStubs.remove(host.getSender());
				return null;
			}

		});

		this.visitor.setCmd(IConnectionErrorMsg.GetID(), new AConnectionDataPacketAlgoCmd&lt;IConnectionMsg>() {

			/**
			 * For serialization
			 */
			private static final long serialVersionUID = 670337733106212059L;

			@Override
			public Void apply(IDataPacketID index, ConnectionDataPacket&lt;IConnectionMsg> host, Void... params) {
				ChatAppModel.this.viewLogger.log(LogLevel.ERROR, ((IConnectionErrorMsg) host.getData()).getErrorMsg());
				return null;
			}

		});


	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_lxr8GKyXEeyB76_OUW-bXg" name="quit" specification="_lwXtcayXEeyB76_OUW-bXg">
              <language>java</language>
              <body>// Leave all chat rooms

		// Stop RMI system and quit app
		try {
			registry.unbind(this.config.name);
			rmiUtils.stopRMI();
		} catch (Exception e) {
			viewLogger.log(LogLevel.ERROR, &quot;ChatAppModel Stopping Error: &quot; + e.toString());
			e.printStackTrace();
		}
		System.exit(0);
	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_lxr8GayXEeyB76_OUW-bXg" name="connectTo" specification="_lwYUgKyXEeyB76_OUW-bXg">
              <ownedParameter xmi:id="_lxr8GqyXEeyB76_OUW-bXg" name="remoteHost">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
              </ownedParameter>
              <ownedParameter xmi:id="_lxr8G6yXEeyB76_OUW-bXg" direction="return">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
              </ownedParameter>
              <language>java</language>
              <body>try {
			// Locate registry
			sysLogger.log(LogLevel.INFO, &quot;Locating registry at &quot; + remoteHost + &quot;...&quot;);
			Registry registry = rmiUtils.getRemoteRegistry(remoteHost);

			// Get IConnector from remote user and make INamedConnector
			sysLogger.log(LogLevel.INFO, &quot;Found registry: &quot; + registry);
			remoteStub = (IConnection) registry.lookup(this.config.boundName);
			connector = user;

			// Update set of connected users
			sysLogger.log(LogLevel.INFO, &quot;Found remote stub: &quot; + remoteStub);
			connectedRemoteStubs.add(connector);
			sysLogger.log(LogLevel.INFO, &quot;Successfully connected to &quot; + remoteHost);

			// Sync peer msgs
			remoteStub.receiveMessage(new ConnectionDataPacket&lt;IHostSendKnownConnectionsMsg>(
					new HostSendKnownConnectionsMsg(connectedRemoteStubs), connector));

		} catch (Exception e) {
			sysLogger.log(LogLevel.ERROR, &quot;Exception connecting to &quot; + remoteHost + &quot;: &quot; + e);
			e.printStackTrace();
			return &quot;No connection established!&quot;;
		}
		return &quot;Connection to &quot; + remoteHost + &quot; established!&quot;;
	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_lxr8HKyXEeyB76_OUW-bXg" name="connectToStub" specification="_lxZoM6yXEeyB76_OUW-bXg">
              <ownedParameter xmi:id="_lxr8HayXEeyB76_OUW-bXg" name="newStub" type="_ksdZYKyXEeyB76_OUW-bXg"/>
              <language>java</language>
              <body>// Replace &quot;IRemoteStubType&quot; with the appropriate for the
													// application, i.e. the Remote type of stub in Registry)
		this.remoteStub = newStub;

		try {
			connector = user;

			// Update set of connected users
			sysLogger.log(LogLevel.INFO, &quot;Found remote stub: &quot; + remoteStub);
			
			sysLogger.log(LogLevel.INFO, &quot;Successfully connected to &quot; + connector.getName());

			// Sync peer msgs
			HashSet&lt;INamedConnection> peersAndMyself = new HashSet&lt;INamedConnection>(connectedRemoteStubs);
			peersAndMyself.add(ChatAppModel.this.user);
			remoteStub.receiveMessage(new ConnectionDataPacket&lt;IHostSendKnownConnectionsMsg>(
					new HostSendKnownConnectionsMsg(peersAndMyself), user));
			
			connectedRemoteStubs.add(connector);
		} catch (RemoteException e) {
			e.printStackTrace();
		}

		this.viewLogger.log(LogLevel.INFO, &quot;Connected to engine via discovery server!&quot;);
	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_lxsjIKyXEeyB76_OUW-bXg" name="createChatRoom" specification="_lwYUg6yXEeyB76_OUW-bXg">
              <ownedParameter xmi:id="_lxsjIayXEeyB76_OUW-bXg" name="roomName">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
              </ownedParameter>
              <ownedParameter xmi:id="_lxsjIqyXEeyB76_OUW-bXg" type="_qgr3QKyWEeyB76_OUW-bXg" direction="return"/>
              <language>java</language>
              <body>ChatRoom room = new ChatRoom(roomName);
		IMain2MiniAdapter m2mAdpt = m2vAdpt.makeMiniMVC(room, this.user);
		
		Thread t = new Thread(() -> { 
			m2mAdpt.createChannel(this.pubSubManager, room);
		});
		t.start();
		this.mapRooms.put(room.getUUID(), m2mAdpt);
		return room;
	</body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_lxsjI6yXEeyB76_OUW-bXg" name="inviteUser" specification="_lxaPQayXEeyB76_OUW-bXg">
              <ownedParameter xmi:id="_lxsjJKyXEeyB76_OUW-bXg" name="userInviting" type="_qgqCEayWEeyB76_OUW-bXg"/>
              <ownedParameter xmi:id="_lxsjJayXEeyB76_OUW-bXg" name="room" type="_qgr3QKyWEeyB76_OUW-bXg"/>
              <language>java</language>
              <body>try {
			userInviting.getConnectionStub().receiveMessage(new ConnectionDataPacket&lt;IInviteMsg>(new InviteMsg(room.getUUID(), room.getName()), user));
		} catch (RemoteException e) {
			e.printStackTrace();
		}
	</body>
