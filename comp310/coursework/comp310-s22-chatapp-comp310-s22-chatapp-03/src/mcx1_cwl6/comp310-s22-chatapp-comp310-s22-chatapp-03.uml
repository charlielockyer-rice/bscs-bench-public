            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_qhE40KyWEeyB76_OUW-bXg" name="ChatRoomController" specification="_qg55sKyWEeyB76_OUW-bXg">
              <ownedParameter xmi:id="_qhE40ayWEeyB76_OUW-bXg" name="chatroom" type="_qgr3QKyWEeyB76_OUW-bXg"/>
