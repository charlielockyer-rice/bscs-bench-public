  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_q-XcUayXEeyB76_OUW-bXg" sourceConnectionVisual="_q-XcUqyXEeyB76_OUW-bXg" text="One of the two message types used to achieve the auto-connect back feature.&#xA;&#xA;A message type sent from a &quot;client&quot; to a &quot;host&quot; and a message of this type contains a set of &#xA;INamedConnections that the client knows. &#xA;&#xA;The &quot;client&quot; is defined as the entity whose &quot;Get Selected Endpoint&quot; button is clicked on discovery server, &#xA;and the &quot;host&quot; is entity that the &quot;client&quot; tries to connect to.&#xA;&#xA;When receiving this message, its command will add the additional set of peers &#xA;received to its existing set of peers, and send this new set to all peers in this new set.">
    <modelElement href="../comp310-s22-chatapp-comp310-s22-chatapp-03.uml#_qqZ-iKyXEeyB76_OUW-bXg"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_q-YDYKyXEeyB76_OUW-bXg" sourceConnectionVisual="_q-YDYayXEeyB76_OUW-bXg" text="Constructor for AddPeersMsg&#xA;&#x9; * @param connections The connections to add">
    <modelElement href="../comp310-s22-chatapp-comp310-s22-chatapp-03.uml#_qqZ-iayXEeyB76_OUW-bXg"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_q-Z4kayXEeyB76_OUW-bXg" sourceConnectionVisual="_q-Z4kqyXEeyB76_OUW-bXg" text="One of the two message types used to achieve the auto-connect back feature.&#xA;&#xA;A message type sent from a &quot;host&quot;. This message contains a set of INamedConnections&#xA;that the host knows. The &quot;host&quot; is defined as the entity that receives IClientSendKnownConnectionsMsg.&#xA;&#xA;When receiving this message, its command will update its set of peers.">
    <modelElement href="../comp310-s22-chatapp-comp310-s22-chatapp-03.uml#_qqZ-iqyXEeyB76_OUW-bXg"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_q-afpKyXEeyB76_OUW-bXg" sourceConnectionVisual="_q-afpayXEeyB76_OUW-bXg" text="Constructor for HostSendKnownConnectionMessage&#xA;&#x9; * @param peers The peers to send">
    <modelElement href="../comp310-s22-chatapp-comp310-s22-chatapp-03.uml#_qqZ-i6yXEeyB76_OUW-bXg"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_q-cU0KyXEeyB76_OUW-bXg" sourceConnectionVisual="_q-cU0ayXEeyB76_OUW-bXg" text="An invite message type that enables one ChatApp to invite another ChatApp to &#xA;one of its chat rooms.">
    <modelElement href="../comp310-s22-chatapp-comp310-s22-chatapp-03.uml#_qqZ-jKyXEeyB76_OUW-bXg"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_q-cU0qyXEeyB76_OUW-bXg" sourceConnectionVisual="_q-cU06yXEeyB76_OUW-bXg" text="Constructor&#xA;&#x9; * @param id the uuid&#xA;&#x9; * @param roomName the name of the chatroom">
    <modelElement href="../comp310-s22-chatapp-comp310-s22-chatapp-03.uml#_qqalkKyXEeyB76_OUW-bXg"/>
  </nodes>
</com.yattasolutions.uml.diagrams.classifier:ClassDiagram>
