  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_tWps4KyYEeyB76_OUW-bXg" sourceConnectionVisual="_tWps4ayYEeyB76_OUW-bXg" text="One of the two message types used to achieve the auto-connect back feature.&#xA;&#xA;A message type sent from a &quot;client&quot; to a &quot;host&quot; and a message of this type contains a set of &#xA;INamedConnections that the client knows. &#xA;&#xA;The &quot;client&quot; is defined as the entity whose &quot;Get Selected Endpoint&quot; button is clicked on discovery server, &#xA;and the &quot;host&quot; is entity that the &quot;client&quot; tries to connect to.&#xA;&#xA;When receiving this message, its command will add the additional set of peers &#xA;received to its existing set of peers, and send this new set to all peers in this new set." item="_tWqT-ayYEeyB76_OUW-bXg">
    <modelElement href="mcx1_cwl6/comp310-s22-chatapp-comp310-s22-chatapp-03.uml#_qqZ-iKyXEeyB76_OUW-bXg"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_tWps4qyYEeyB76_OUW-bXg" sourceConnectionVisual="_tWps46yYEeyB76_OUW-bXg" text="Constructor for AddPeersMsg&#xA;&#x9; * @param connections The connections to add" item="_tWqUC6yYEeyB76_OUW-bXg">
    <modelElement href="mcx1_cwl6/comp310-s22-chatapp-comp310-s22-chatapp-03.uml#_qqZ-iayXEeyB76_OUW-bXg"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_tWriEKyYEeyB76_OUW-bXg" sourceConnectionVisual="_tWriEayYEeyB76_OUW-bXg" text="One of the two message types used to achieve the auto-connect back feature.&#xA;&#xA;A message type sent from a &quot;host&quot;. This message contains a set of INamedConnections&#xA;that the host knows. The &quot;host&quot; is defined as the entity that receives IClientSendKnownConnectionsMsg.&#xA;&#xA;When receiving this message, its command will update its set of peers." item="_tWsJIKyYEeyB76_OUW-bXg">
    <modelElement href="mcx1_cwl6/comp310-s22-chatapp-comp310-s22-chatapp-03.uml#_qqZ-iqyXEeyB76_OUW-bXg"/>
  </nodes>
