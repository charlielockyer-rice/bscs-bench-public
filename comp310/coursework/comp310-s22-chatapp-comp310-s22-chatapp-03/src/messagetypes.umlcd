  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_rrPT8KyYEeyB76_OUW-bXg" sourceConnectionVisual="_rrPT8ayYEeyB76_OUW-bXg" text="The super type of all messages within a chat room. Defining ICommunicationMsg&#xA;enhances type safety because one can make IMessageReceiver only receive messages&#xA;of the ICommunicationMsg type. Usually not directly used. &#xA;&#xA;@author Group B&#xA; *" item="_rrP7AayYEeyB76_OUW-bXg">
    <modelElement href="mcx1_cwl6/comp310-s22-chatapp-comp310-s22-chatapp-03.uml#_Gv77SqyXEeyB76_OUW-bXg"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_rrRJIayYEeyB76_OUW-bXg" sourceConnectionVisual="_rrRJIqyYEeyB76_OUW-bXg" text="The message type used for requesting a command from sender. Usually sent because &#xA;an unknown type of message is received. &#xA;&#xA;@author Group B&#xA; *" item="_rrRwOKyYEeyB76_OUW-bXg">
    <modelElement href="mcx1_cwl6/comp310-s22-chatapp-comp310-s22-chatapp-03.uml#_Gv77S6yXEeyB76_OUW-bXg"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_rrS-UayYEeyB76_OUW-bXg" sourceConnectionVisual="_rrS-UqyYEeyB76_OUW-bXg" text="The message type that contains an algo cmd. The message type is usually used upon receiving &#xA;IRequestCmdMsg from another ChatApp so that the other ChatApp can process unknown type of message&#xA;it initially received.&#xA;&#xA;@author Group B&#xA; *" item="_rrTla6yYEeyB76_OUW-bXg">
    <modelElement href="mcx1_cwl6/comp310-s22-chatapp-comp310-s22-chatapp-03.uml#_Gv8iUKyXEeyB76_OUW-bXg"/>
  </nodes>
