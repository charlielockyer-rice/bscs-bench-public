  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_rrNewKyYEeyB76_OUW-bXg" sourceConnectionVisual="_rrNewayYEeyB76_OUW-bXg" text="Get the error message.&#xA;&#x9; * &#xA;&#x9; * @return error message." item="_rrOF7ayYEeyB76_OUW-bXg">
