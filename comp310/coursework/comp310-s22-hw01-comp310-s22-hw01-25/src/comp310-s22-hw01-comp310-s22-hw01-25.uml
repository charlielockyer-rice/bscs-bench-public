        <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_EXsLEHoOEeyyJ_eBMrUodA" name="main" specification="_EUSRwHoOEeyyJ_eBMrUodA">
          <ownedParameter xmi:id="_EXsLEXoOEeyyJ_eBMrUodA" name="args">
