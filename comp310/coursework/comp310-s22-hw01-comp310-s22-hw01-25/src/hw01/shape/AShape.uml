            <ownedParameter xmi:id="_tXowBXyjEeyqPtdb1vr-DA" type="_tW0QoHyjEeyqPtdb1vr-DA" direction="return"/>
          </ownedOperation>
          <ownedOperation xmi:id="_tXzIEHyjEeyqPtdb1vr-DA" name="setColor" method="_tYMwsHyjEeyqPtdb1vr-DA">
            <ownedComment xmi:id="_i-agInyoEeyqPtdb1vr-DA">
              <body>Sets the color of the shape to an input color defined by the Color class by delegating&#xD;
	 * to the component shapes&#xD;
	 * @param color the color of the shape</body>
            </ownedComment>
            <ownedParameter xmi:id="_tXzIEXyjEeyqPtdb1vr-DA" name="color" type="_tXhbQHyjEeyqPtdb1vr-DA"/>
          </ownedOperation>
          <ownedOperation xmi:id="_tXzvIHyjEeyqPtdb1vr-DA" name="paint" method="_tYMwsnyjEeyqPtdb1vr-DA">
            <ownedComment xmi:id="_i-agI3yoEeyqPtdb1vr-DA">
              <body>Paints the shape on the screen, abstract because each different shape is painted differently&#xD;
	 * @param g the graphics object on which the shape will be painted</body>
            </ownedComment>
            <ownedParameter xmi:id="_tXzvIXyjEeyqPtdb1vr-DA" name="g" type="_tXjQcHyjEeyqPtdb1vr-DA"/>
          </ownedOperation>
        </packagedElement>
        <packagedElement xmi:type="uml:Class" xmi:id="_tW5wMHyjEeyqPtdb1vr-DA" name="Ellipse">
          <ownedComment xmi:id="_tYPM-HyjEeyqPtdb1vr-DA">
            <body>&#xD;
@author charlielockyer&#xD;
A concrete class representing an ellipse that can be painted on a graphics object</body>
          </ownedComment>
          <generalization xmi:id="_tXqlMHyjEeyqPtdb1vr-DA" general="_tWvYIHyjEeyqPtdb1vr-DA"/>
          <ownedAttribute xmi:id="_tX7q8XyjEeyqPtdb1vr-DA" name="width" visibility="private">
            <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
          </ownedAttribute>
          <ownedAttribute xmi:id="_tX8SAXyjEeyqPtdb1vr-DA" name="height" visibility="private">
            <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
          </ownedAttribute>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_tYNXwHyjEeyqPtdb1vr-DA" name="Ellipse" specification="_tX0WMHyjEeyqPtdb1vr-DA">
            <ownedParameter xmi:id="_tYNXwXyjEeyqPtdb1vr-DA" name="xPos">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
            </ownedParameter>
            <ownedParameter xmi:id="_tYNXwnyjEeyqPtdb1vr-DA" name="yPos">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
            </ownedParameter>
            <ownedParameter xmi:id="_tYNXw3yjEeyqPtdb1vr-DA" name="width">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
            </ownedParameter>
            <ownedParameter xmi:id="_tYNXxHyjEeyqPtdb1vr-DA" name="height">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
            </ownedParameter>
            <ownedParameter xmi:id="_tYNXxXyjEeyqPtdb1vr-DA" name="color" type="_tXhbQHyjEeyqPtdb1vr-DA"/>
            <ownedParameter xmi:id="_tYNXxnyjEeyqPtdb1vr-DA" type="_tW5wMHyjEeyqPtdb1vr-DA" direction="return"/>
            <language>java</language>
            <body>this.setXPos(xPos);&#xD;
		this.setYPos(yPos);&#xD;
		this.width = width;&#xD;
		this.height = height;&#xD;
		this.setColor(color);&#xD;
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_tYNXx3yjEeyqPtdb1vr-DA" name="paint" specification="_tX09RHyjEeyqPtdb1vr-DA">
            <ownedParameter xmi:id="_tYNXyHyjEeyqPtdb1vr-DA" name="g" type="_tXjQcHyjEeyqPtdb1vr-DA"/>
            <language>java</language>
            <body>g.setColor(this.color); // Set the color to use when drawing&#xD;
		g.fillOval(this.getXPos(), this.getYPos(), this.width, this.height);&#xD;
	</body>
          </ownedBehavior>
          <ownedOperation xmi:id="_tX0WMHyjEeyqPtdb1vr-DA" name="Ellipse" method="_tYNXwHyjEeyqPtdb1vr-DA">
            <eAnnotations xmi:id="_tX09QXyjEeyqPtdb1vr-DA" source="http://www.eclipse.org/uml2/2.0.0/UML">
              <details xmi:id="_tX09QnyjEeyqPtdb1vr-DA" key="create"/>
            </eAnnotations>
            <ownedComment xmi:id="_tYPM-XyjEeyqPtdb1vr-DA">
              <body>Constructs an ellipse object&#xD;
	 * @param xPos the x position (top left corner of bounding rectangle)&#xD;
	 * @param yPos the y position (top left corner of bounding rectangle)&#xD;
	 * @param width the width of the ellipse (horizontal)&#xD;
	 * @param height the height of the ellipse (vertical)&#xD;
	 * @param color the color of the ellipse (Color class)</body>
            </ownedComment>
            <ownedParameter xmi:id="_tX0WMXyjEeyqPtdb1vr-DA" name="xPos">
