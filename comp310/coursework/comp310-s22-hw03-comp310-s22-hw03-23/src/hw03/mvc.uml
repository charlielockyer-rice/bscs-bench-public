            <ownedComment xmi:id="_O9yKR4BUEeytY4-2QCegDA">
              <body>@author Christina
Ball expands and contracts</body>
            </ownedComment>
            <ownedAttribute xmi:id="_L69A83_cEeyw2PeLuYg3dQ" name="expand" visibility="package">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#boolean"/>
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_L69A9H_cEeyw2PeLuYg3dQ" value="true"/>
            </ownedAttribute>
            <interfaceRealization xmi:id="_L6XLEX_cEeyw2PeLuYg3dQ" client="_L4sXIH_cEeyw2PeLuYg3dQ" supplier="_L4oFsH_cEeyw2PeLuYg3dQ" contract="_L4oFsH_cEeyw2PeLuYg3dQ"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_L7KcWn_cEeyw2PeLuYg3dQ" name="updateState" specification="_L6vlkH_cEeyw2PeLuYg3dQ">
              <ownedParameter xmi:id="_L7KcW3_cEeyw2PeLuYg3dQ" name="disp" type="_L6UHwX_cEeyw2PeLuYg3dQ"/>
              <ownedParameter xmi:id="_L7KcXH_cEeyw2PeLuYg3dQ" name="ball" type="_L4810H_cEeyw2PeLuYg3dQ"/>
              <language>java</language>
              <body>if(ball.getRadius() &lt; 60 &amp;&amp; expand)
			ball.setRadius(ball.getRadius() + 2);
		else if(ball.getRadius() &lt; 5)
			expand = true;
		else {
			ball.setRadius(ball.getRadius() - 2);
			expand = false;
		}
	</body>
            </ownedBehavior>
