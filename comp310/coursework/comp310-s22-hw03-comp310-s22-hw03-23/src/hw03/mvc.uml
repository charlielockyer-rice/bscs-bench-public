            <ownedParameter xmi:id="_L7M4kX_cEeyw2PeLuYg3dQ" name="location" type="_L6V88H_cEeyw2PeLuYg3dQ"/>
            <ownedParameter xmi:id="_L7M4kn_cEeyw2PeLuYg3dQ" name="velocity" type="_L6V88H_cEeyw2PeLuYg3dQ"/>
            <ownedParameter xmi:id="_L7M4k3_cEeyw2PeLuYg3dQ" name="color" type="_L6VV4H_cEeyw2PeLuYg3dQ"/>
            <ownedParameter xmi:id="_L7M4lH_cEeyw2PeLuYg3dQ" name="radius">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
            </ownedParameter>
            <ownedParameter xmi:id="_L7M4lX_cEeyw2PeLuYg3dQ" name="dimension" type="_L6S5on_cEeyw2PeLuYg3dQ"/>
            <ownedParameter xmi:id="_L7M4ln_cEeyw2PeLuYg3dQ" name="strategy" type="_L4oFsH_cEeyw2PeLuYg3dQ"/>
            <ownedParameter xmi:id="_L7M4l3_cEeyw2PeLuYg3dQ" type="_L4810H_cEeyw2PeLuYg3dQ" direction="return">
              <name xsi:nil="true"/>
            </ownedParameter>
            <language>java</language>
            <body>this.location = location;
		this.velocity = velocity;
		this.color = color;
		this.radius = radius;
		this.dimension = dimension;
		this.strategy = strategy;
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_L7M4mH_cEeyw2PeLuYg3dQ" name="move" specification="_L49c4H_cEeyw2PeLuYg3dQ">
            <language>java</language>
            <body>this.location.translate(velocity.x, velocity.y);
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_L7NfoH_cEeyw2PeLuYg3dQ" name="bounce" specification="_L49c4X_cEeyw2PeLuYg3dQ">
            <language>java</language>
            <body>// make concrete if most balls share the bounce behavior 
		if (this.location.x+this.radius >= this.dimension.getWidth() || this.location.x-this.radius &lt;= 0) {
			this.velocity.x = -this.velocity.x;
		}
		
		if (this.location.y+this.radius >= this.dimension.getHeight() || this.location.y-this.radius &lt;= 0) {
			this.velocity.y = -this.velocity.y;
		}
		// set the new location
		location.setLocation(this.location);
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_L7NfoX_cEeyw2PeLuYg3dQ" name="update" specification="_L64viX_cEeyw2PeLuYg3dQ">
            <ownedParameter xmi:id="_L7Nfon_cEeyw2PeLuYg3dQ" name="disp" type="_L6UHwX_cEeyw2PeLuYg3dQ"/>
            <ownedParameter xmi:id="_L7Nfo3_cEeyw2PeLuYg3dQ" name="g" type="_L6S5oH_cEeyw2PeLuYg3dQ"/>
            <language>java</language>
            <body>updateState(disp);
 	strategy.updateState(disp, this);
 	move();
 	bounce();
 	paint(g);
 </body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_L7NfpH_cEeyw2PeLuYg3dQ" name="paint" specification="_L659oX_cEeyw2PeLuYg3dQ">
            <ownedParameter xmi:id="_L7NfpX_cEeyw2PeLuYg3dQ" name="g" type="_L6S5oH_cEeyw2PeLuYg3dQ"/>
            <language>java</language>
            <body>g.setColor(this.color);
		g.fillOval(this.location.x-this.radius, this.location.y-this.radius, radius, radius);
	</body>
          </ownedBehavior>
