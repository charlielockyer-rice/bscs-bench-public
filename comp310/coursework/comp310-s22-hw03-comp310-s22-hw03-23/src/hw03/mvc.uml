          <ownedAttribute xmi:id="_L7DuoX_cEeyw2PeLuYg3dQ" name="btnS" visibility="private" isLeaf="true" type="_L6cDk3_cEeyw2PeLuYg3dQ" isReadOnly="true" association="_L7dXQX_cEeyw2PeLuYg3dQ">
            <defaultValue xmi:type="uml:LiteralString" xmi:id="_L7Duon_cEeyw2PeLuYg3dQ" value="new JButton(&quot;Switch&quot;)"/>
