          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_L7MRgH_cEeyw2PeLuYg3dQ" name="loadBall" specification="_L6lNhn_cEeyw2PeLuYg3dQ">
            <ownedParameter xmi:id="_L7MRgX_cEeyw2PeLuYg3dQ" name="strategy" type="_L4oFsH_cEeyw2PeLuYg3dQ"/>
            <language>java</language>
            <body>//TODO: Move all the GUI-related code to the view
		IRandomizer rand = Randomizer.Singleton;
		int radius = rand.randomInt(5, 30);
		Color color = rand.randomColor();
		int xLoc = rand.randomInt(0, _controlAdpt.getCanvasDim().getWidth()); // subtract 30 so doesn't get stuck
		int yLoc = rand.randomInt(0, _controlAdpt.getCanvasDim().getHeight());
		int xVelocity = rand.randomInt(-10, 10);
		int yVelocity = rand.randomInt(-10, 10);
		
		Ball newBall = new Ball(new Point(xLoc, yLoc), new Point(xVelocity, yVelocity), color, radius, _controlAdpt.getCanvasDim(), strategy);
		myDispatcher.addObserver(newBall);
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_L7MRgn_cEeyw2PeLuYg3dQ" name="makeStrategyFac" specification="_L45ygH_cEeyw2PeLuYg3dQ">
            <ownedParameter xmi:id="_L7MRg3_cEeyw2PeLuYg3dQ" name="classname">
              <eAnnotations xmi:id="_L7MRhH_cEeyw2PeLuYg3dQ" source="http://www.eclipse.org/uml2/2.0.0/UML">
                <details xmi:id="_L7MRhX_cEeyw2PeLuYg3dQ" key="final"/>
              </eAnnotations>
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
            </ownedParameter>
            <ownedParameter xmi:id="_L7MRhn_cEeyw2PeLuYg3dQ" type="_L4m3kH_cEeyw2PeLuYg3dQ" direction="return">
              <name xsi:nil="true"/>
            </ownedParameter>
            <language>java</language>
            <body>if (null == classname) return IStrategyFac.errorStrategyFac;
	    return new IStrategyFac() {
	        /**
	         * Instantiate a strategy corresponding to the given class name.
	         * @return An IUpdateStrategy instance
	         */
	        public IUpdateStrategy make() {
	            return makeStrategy(&quot;hw03.model.strategy.&quot; + classname + &quot;Strategy&quot;);
	        }

	        /**
	         * Return the given class name string
	         */
	        public String toString() {
	            return classname;
	        }
	    };
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_L7MRh3_cEeyw2PeLuYg3dQ" name="makeStrategy" specification="_L45yhH_cEeyw2PeLuYg3dQ">
            <ownedParameter xmi:id="_L7MRiH_cEeyw2PeLuYg3dQ" name="strategy">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
            </ownedParameter>
            <ownedParameter xmi:id="_L7MRiX_cEeyw2PeLuYg3dQ" type="_L4oFsH_cEeyw2PeLuYg3dQ" direction="return">
              <name xsi:nil="true"/>
            </ownedParameter>
            <language>java</language>
            <body>IObjectLoader&lt;IUpdateStrategy> loader = new ObjectLoader&lt;IUpdateStrategy>(arg -> IUpdateStrategy.errorStrategy);
		IUpdateStrategy newStrategy = loader.loadInstance(strategy);
		return newStrategy;
		
	</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_L7MRin_cEeyw2PeLuYg3dQ" name="combineStrategyFacs" specification="_L6l0k3_cEeyw2PeLuYg3dQ">
            <ownedParameter xmi:id="_L7MRi3_cEeyw2PeLuYg3dQ" name="stratFac1" type="_L4m3kH_cEeyw2PeLuYg3dQ">
              <eAnnotations xmi:id="_L7MRjH_cEeyw2PeLuYg3dQ" source="http://www.eclipse.org/uml2/2.0.0/UML">
                <details xmi:id="_L7MRjX_cEeyw2PeLuYg3dQ" key="final"/>
              </eAnnotations>
            </ownedParameter>
            <ownedParameter xmi:id="_L7MRjn_cEeyw2PeLuYg3dQ" name="stratFac2" type="_L4m3kH_cEeyw2PeLuYg3dQ">
              <eAnnotations xmi:id="_L7MRj3_cEeyw2PeLuYg3dQ" source="http://www.eclipse.org/uml2/2.0.0/UML">
                <details xmi:id="_L7MRkH_cEeyw2PeLuYg3dQ" key="final"/>
              </eAnnotations>
            </ownedParameter>
            <ownedParameter xmi:id="_L7MRkX_cEeyw2PeLuYg3dQ" type="_L4m3kH_cEeyw2PeLuYg3dQ" direction="return">
              <name xsi:nil="true"/>
            </ownedParameter>
            <language>java</language>
            <body>if (null == stratFac1 || null == stratFac2) return IStrategyFac.errorStrategyFac;
	    return new IStrategyFac() {
			@Override
			public IUpdateStrategy make() {
				
				return new IUpdateStrategy() {
				
		    	IUpdateStrategy strategy1 = stratFac1.make();
		    	IUpdateStrategy strategy2 = stratFac2.make();
				// TODO Auto-generated method stub
		    	
		    	@Override
				public void updateState(IDispatcher&lt;Graphics> disp, Ball ball) {
		    		strategy1.updateState(disp, ball);
		    		strategy2.updateState(disp, ball);
		    	}};
		    	}
			
			public String toString() {
				return stratFac1.toString() + &quot;-&quot; + stratFac2.toString();
			}
	    };</body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_L7MRkn_cEeyw2PeLuYg3dQ" name="update" specification="_L626UH_cEeyw2PeLuYg3dQ">
            <ownedParameter xmi:id="_L7MRk3_cEeyw2PeLuYg3dQ" name="g" type="_L6S5oH_cEeyw2PeLuYg3dQ"/>
            <language>java</language>
            <body>myDispatcher.updateAll(g);  // The Graphics object is being given to all the balls (Observers) - used to update painted positions of balls
 </body>
          </ownedBehavior>
          <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_L7MRlH_cEeyw2PeLuYg3dQ" name="clearBalls" specification="_L46ZkX_cEeyw2PeLuYg3dQ">
            <language>java</language>
            <body>myDispatcher.removeAllObservers();
 </body>
          </ownedBehavior>
