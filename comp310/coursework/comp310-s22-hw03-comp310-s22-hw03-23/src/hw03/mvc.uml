              <ownedParameter xmi:id="_L6uXcn_cEeyw2PeLuYg3dQ" name="ball" type="_L4810H_cEeyw2PeLuYg3dQ"/>
            </ownedOperation>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_L4rwEH_cEeyw2PeLuYg3dQ" name="ColorStrategy">
            <ownedComment xmi:id="_O9yKRoBUEeytY4-2QCegDA">
              <body>@author Christina
Color strategy chooses a random color to switch between</body>
            </ownedComment>
            <interfaceRealization xmi:id="_L6XLEH_cEeyw2PeLuYg3dQ" client="_L4rwEH_cEeyw2PeLuYg3dQ" supplier="_L4oFsH_cEeyw2PeLuYg3dQ" contract="_L4oFsH_cEeyw2PeLuYg3dQ"/>
