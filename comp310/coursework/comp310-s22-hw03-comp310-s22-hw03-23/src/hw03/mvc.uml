          <packagedElement xmi:type="uml:Class" xmi:id="_L4rJAH_cEeyw2PeLuYg3dQ" name="ChangingVelocityStrategy">
            <ownedComment xmi:id="_O9yKRYBUEeytY4-2QCegDA">
              <body>@author Christina
Strategy that randomly changes the velocity of the ball</body>
            </ownedComment>
            <interfaceRealization xmi:id="_L6WkAX_cEeyw2PeLuYg3dQ" client="_L4rJAH_cEeyw2PeLuYg3dQ" supplier="_L4oFsH_cEeyw2PeLuYg3dQ" contract="_L4oFsH_cEeyw2PeLuYg3dQ"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_L7KcVH_cEeyw2PeLuYg3dQ" name="updateState" specification="_L6uXcH_cEeyw2PeLuYg3dQ">
              <ownedParameter xmi:id="_L7KcVX_cEeyw2PeLuYg3dQ" name="disp" type="_L6UHwX_cEeyw2PeLuYg3dQ"/>
              <ownedParameter xmi:id="_L7KcVn_cEeyw2PeLuYg3dQ" name="ball" type="_L4810H_cEeyw2PeLuYg3dQ"/>
              <language>java</language>
              <body>Random r = new Random();
		double randomX = r.nextDouble();
		double randomY = r.nextDouble();
		Point newVel =  ball.getVelocity();
		
		if(randomX>0.5)
			newVel.x += 1;
		else
			newVel.x -= 1;
		if(randomY > 0.5)
			newVel.y += 1;
		else
			newVel.y -= 1;
		ball.setVelocity(newVel);
	</body>
            </ownedBehavior>
            <ownedOperation xmi:id="_L6uXcH_cEeyw2PeLuYg3dQ" name="updateState" method="_L7KcVH_cEeyw2PeLuYg3dQ">
