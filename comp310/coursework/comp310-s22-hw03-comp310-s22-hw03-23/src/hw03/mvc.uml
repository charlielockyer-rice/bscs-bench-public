          <ownedAttribute xmi:id="_L7DHk3_cEeyw2PeLuYg3dQ" name="switchPanel" visibility="private" isLeaf="true" type="_L6bcg3_cEeyw2PeLuYg3dQ" isReadOnly="true" association="_L7cwMX_cEeyw2PeLuYg3dQ">
            <defaultValue xmi:type="uml:LiteralString" xmi:id="_L7DHlH_cEeyw2PeLuYg3dQ" value="new JPanel()"/>
          </ownedAttribute>
          <ownedAttribute xmi:id="_L7DHln_cEeyw2PeLuYg3dQ" name="btnMakeSwitch" visibility="private" isLeaf="true" type="_L6cDk3_cEeyw2PeLuYg3dQ" isReadOnly="true" association="_L7cwNH_cEeyw2PeLuYg3dQ">
            <defaultValue xmi:type="uml:LiteralString" xmi:id="_L7DHl3_cEeyw2PeLuYg3dQ" value="new JButton(&quot;Make Switcher&quot;)"/>
