Ball class represented to create a ball</body>
          </ownedComment>
          <ownedAttribute xmi:id="_L7Gx8H_cEeyw2PeLuYg3dQ" name="location" visibility="protected" type="_L6V88H_cEeyw2PeLuYg3dQ" association="_L7fMcX_cEeyw2PeLuYg3dQ"/>
          <ownedAttribute xmi:id="_L7Gx8n_cEeyw2PeLuYg3dQ" name="velocity" visibility="public" type="_L6V88H_cEeyw2PeLuYg3dQ" isReadOnly="true" association="_L7fMdH_cEeyw2PeLuYg3dQ"/>
          <ownedAttribute xmi:id="_L7Gx9H_cEeyw2PeLuYg3dQ" name="color" visibility="public" type="_L6VV4H_cEeyw2PeLuYg3dQ" isReadOnly="true" association="_L7fzgX_cEeyw2PeLuYg3dQ"/>
          <ownedAttribute xmi:id="_L7HZAX_cEeyw2PeLuYg3dQ" name="radius" visibility="public" isReadOnly="true">
            <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
          </ownedAttribute>
          <ownedAttribute xmi:id="_L7HZA3_cEeyw2PeLuYg3dQ" name="dimension" visibility="protected" type="_L6S5on_cEeyw2PeLuYg3dQ" association="_L7fzhH_cEeyw2PeLuYg3dQ"/>
          <ownedAttribute xmi:id="_L7HZBX_cEeyw2PeLuYg3dQ" name="strategy" visibility="protected" type="_L4oFsH_cEeyw2PeLuYg3dQ" association="_L7gakX_cEeyw2PeLuYg3dQ"/>
