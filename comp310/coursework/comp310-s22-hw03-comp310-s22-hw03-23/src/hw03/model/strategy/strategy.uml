          <packagedElement xmi:type="uml:Class" xmi:id="_mPCNwIBVEeytY4-2QCegDA" name="RandomWalkStrategy">
            <ownedComment xmi:id="_mPDb5IBVEeytY4-2QCegDA">
              <body>@author Christina
Strategy that randomly changes the velocity of the ball</body>
            </ownedComment>
            <interfaceRealization xmi:id="_mPC00IBVEeytY4-2QCegDA" client="_mPCNwIBVEeytY4-2QCegDA" supplier="_WB6fUX_bEeyw2PeLuYg3dQ" contract="_WB6fUX_bEeyw2PeLuYg3dQ"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_mPDb4YBVEeytY4-2QCegDA" name="updateState" specification="_mPC00YBVEeytY4-2QCegDA">
              <ownedParameter xmi:id="_mPDb4oBVEeytY4-2QCegDA" name="disp" type="_WB7tcX_bEeyw2PeLuYg3dQ"/>
              <ownedParameter xmi:id="_mPDb44BVEeytY4-2QCegDA" name="ball" type="_WB4qIX_bEeyw2PeLuYg3dQ"/>
              <language>java</language>
              <body>Random r = new Random();
		double randomX = r.nextDouble();
		double randomY = r.nextDouble();
		Point newVel =  ball.getVelocity();
		
		if(randomX>0.5)
			newVel.x += 1;
		else
			newVel.x -= 1;
		if(randomY > 0.5)
			newVel.y += 1;
		else
			newVel.y -= 1;
		ball.setVelocity(newVel);
	</body>
            </ownedBehavior>
            <ownedOperation xmi:id="_mPC00YBVEeytY4-2QCegDA" name="updateState" method="_mPDb4YBVEeytY4-2QCegDA">
              <ownedParameter xmi:id="_mPC00oBVEeytY4-2QCegDA" name="disp" type="_WB7tcX_bEeyw2PeLuYg3dQ"/>
              <ownedParameter xmi:id="_mPC004BVEeytY4-2QCegDA" name="ball" type="_WB4qIX_bEeyw2PeLuYg3dQ"/>
            </ownedOperation>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_wYjLsIBmEeytY4-2QCegDA" name="TeleportingStrategy">
            <ownedComment xmi:id="_wYorQIBmEeytY4-2QCegDA">
              <body>@author Christina
Teleporting strategy for the ball class</body>
            </ownedComment>
            <ownedAttribute xmi:id="_wYoEMYBmEeytY4-2QCegDA" name="ticks" visibility="private">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_wYoEMoBmEeytY4-2QCegDA" value="0"/>
            </ownedAttribute>
            <interfaceRealization xmi:id="_wYm2EIBmEeytY4-2QCegDA" client="_wYjLsIBmEeytY4-2QCegDA" supplier="_WB6fUX_bEeyw2PeLuYg3dQ" contract="_WB6fUX_bEeyw2PeLuYg3dQ"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_wYoENIBmEeytY4-2QCegDA" name="updateState" specification="_wYndIIBmEeytY4-2QCegDA">
              <ownedParameter xmi:id="_wYoENYBmEeytY4-2QCegDA" name="disp" type="_WB7tcX_bEeyw2PeLuYg3dQ"/>
              <ownedParameter xmi:id="_wYoENoBmEeytY4-2QCegDA" name="ball" type="_WB4qIX_bEeyw2PeLuYg3dQ"/>
              <language>java</language>
              <body>if(ticks > 19) {
			Random r = new Random();
			int newX = (int) (ball.getDimension().getWidth() * r.nextDouble());
			int newY = (int) (ball.getDimension().getHeight() * r.nextDouble());
			ball.setLocation(new Point(newX, newY));
			int newXVel= (int) ((r.nextDouble() - 0.5) * 10);
			int newYVel = (int) ((r.nextDouble()- 0.5) * 10);
			ball.setVelocity(new Point(newXVel, newYVel));
			ticks = 0;
		}
		ticks++;
	</body>
            </ownedBehavior>
            <ownedOperation xmi:id="_wYndIIBmEeytY4-2QCegDA" name="updateState" method="_wYoENIBmEeytY4-2QCegDA">
              <ownedParameter xmi:id="_wYndIYBmEeytY4-2QCegDA" name="disp" type="_WB7tcX_bEeyw2PeLuYg3dQ"/>
              <ownedParameter xmi:id="_wYndIoBmEeytY4-2QCegDA" name="ball" type="_WB4qIX_bEeyw2PeLuYg3dQ"/>
            </ownedOperation>
          </packagedElement>
