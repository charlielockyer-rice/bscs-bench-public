              <body>
@author charlielockyer
A strategy in which a ball splits into two when it hits a wall</body>
            </ownedComment>
            <interfaceRealization xmi:id="_wqt5wIBmEeytY4-2QCegDA" client="_wqrdgIBmEeytY4-2QCegDA" supplier="_WB6fUX_bEeyw2PeLuYg3dQ" contract="_WB6fUX_bEeyw2PeLuYg3dQ"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_wqug1IBmEeytY4-2QCegDA" name="updateState" specification="_wqug0IBmEeytY4-2QCegDA">
              <ownedParameter xmi:id="_wqug1YBmEeytY4-2QCegDA" name="disp" type="_WB7tcX_bEeyw2PeLuYg3dQ"/>
              <ownedParameter xmi:id="_wqug1oBmEeytY4-2QCegDA" name="ball" type="_WB4qIX_bEeyw2PeLuYg3dQ"/>
              <language>java</language>
              <body>if(ball.hasBounced()[0]) {
			disp.removeObserver(ball);
			if(ball.getRadius() > 0)
				disp.addObserver(new Ball(ball.getLocation(), ball.getVelocity(), 
						ball.getColor(), ball.getRadius() / 2, ball.getDimension(), ball.getStrategy()));
				disp.addObserver(new Ball(ball.getLocation(), new Point(ball.getVelocity().x, ball.getVelocity().y * -1), 
						ball.getColor(), ball.getRadius() / 2, ball.getDimension(), ball.getStrategy()));
		}
		else if(ball.hasBounced()[1]) {
			disp.removeObserver(ball);
			if(ball.getRadius() > 0)
				disp.addObserver(new Ball(ball.getLocation(), ball.getVelocity(), 
						ball.getColor(), ball.getRadius() / 2, ball.getDimension(), ball.getStrategy()));
				disp.addObserver(new Ball(ball.getLocation(), new Point(ball.getVelocity().x * -1, ball.getVelocity().y), 
						ball.getColor(), ball.getRadius() / 2, ball.getDimension(), ball.getStrategy()));
		}
	</body>
            </ownedBehavior>
            <ownedOperation xmi:id="_wqug0IBmEeytY4-2QCegDA" name="updateState" method="_wqug1IBmEeytY4-2QCegDA">
              <ownedParameter xmi:id="_wqug0YBmEeytY4-2QCegDA" name="disp" type="_WB7tcX_bEeyw2PeLuYg3dQ"/>
              <ownedParameter xmi:id="_wqug0oBmEeytY4-2QCegDA" name="ball" type="_WB4qIX_bEeyw2PeLuYg3dQ"/>
            </ownedOperation>
          </packagedElement>
        </packagedElement>
