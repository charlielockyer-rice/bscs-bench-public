          <packagedElement xmi:type="uml:Class" xmi:id="_WA6ZwH_bEeyw2PeLuYg3dQ" name="ColorStrategy">
            <ownedComment xmi:id="_YlFbsIBUEeytY4-2QCegDA">
              <body>@author Christina
Color strategy chooses a random color to switch between</body>
            </ownedComment>
            <interfaceRealization xmi:id="_WCMzMH_bEeyw2PeLuYg3dQ" client="_WA6ZwH_bEeyw2PeLuYg3dQ" supplier="_WB6fUX_bEeyw2PeLuYg3dQ" contract="_WB6fUX_bEeyw2PeLuYg3dQ"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_WCnC4H_bEeyw2PeLuYg3dQ" name="updateState" specification="_WCMzMX_bEeyw2PeLuYg3dQ">
              <ownedParameter xmi:id="_WCnC4X_bEeyw2PeLuYg3dQ" name="disp" type="_WB7tcX_bEeyw2PeLuYg3dQ"/>
              <ownedParameter xmi:id="_WCnC4n_bEeyw2PeLuYg3dQ" name="ball" type="_WB4qIX_bEeyw2PeLuYg3dQ"/>
              <language>java</language>
              <body>Random random = new Random();
		float hue = random.nextFloat();
		// Saturation between 0.1 and 0.3
		float saturation = (random.nextInt(2000) + 1000) / 10000f;
		float luminance = 0.9f;
		Color color = Color.getHSBColor(hue, saturation, luminance);
		ball.setColor(color);
	</body>
            </ownedBehavior>
            <ownedOperation xmi:id="_WCMzMX_bEeyw2PeLuYg3dQ" name="updateState" method="_WCnC4H_bEeyw2PeLuYg3dQ">
              <ownedParameter xmi:id="_WCNaQH_bEeyw2PeLuYg3dQ" name="disp" type="_WB7tcX_bEeyw2PeLuYg3dQ"/>
              <ownedParameter xmi:id="_WCNaQX_bEeyw2PeLuYg3dQ" name="ball" type="_WB4qIX_bEeyw2PeLuYg3dQ"/>
            </ownedOperation>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_WA8O8H_bEeyw2PeLuYg3dQ" name="ExpandingStrategy">
            <ownedComment xmi:id="_YlFbsYBUEeytY4-2QCegDA">
              <body>@author Christina
Ball expands and contracts</body>
            </ownedComment>
            <ownedAttribute xmi:id="_WCaOkH_bEeyw2PeLuYg3dQ" name="expand" visibility="package">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#boolean"/>
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_WCaOkX_bEeyw2PeLuYg3dQ" value="true"/>
            </ownedAttribute>
            <interfaceRealization xmi:id="_WCOBUX_bEeyw2PeLuYg3dQ" client="_WA8O8H_bEeyw2PeLuYg3dQ" supplier="_WB6fUX_bEeyw2PeLuYg3dQ" contract="_WB6fUX_bEeyw2PeLuYg3dQ"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_WCnp8H_bEeyw2PeLuYg3dQ" name="updateState" specification="_WCOoYH_bEeyw2PeLuYg3dQ">
              <ownedParameter xmi:id="_WCnp8X_bEeyw2PeLuYg3dQ" name="disp" type="_WB7tcX_bEeyw2PeLuYg3dQ"/>
              <ownedParameter xmi:id="_WCnp8n_bEeyw2PeLuYg3dQ" name="ball" type="_WB4qIX_bEeyw2PeLuYg3dQ"/>
              <language>java</language>
              <body>if(ball.getRadius() &lt; 60 &amp;&amp; expand)
			ball.setRadius(ball.getRadius() + 2);
		else if(ball.getRadius() &lt; 5)
			expand = true;
		else {
			ball.setRadius(ball.getRadius() - 2);
			expand = false;
		}
	</body>
            </ownedBehavior>
            <ownedOperation xmi:id="_WCOoYH_bEeyw2PeLuYg3dQ" name="updateState" method="_WCnp8H_bEeyw2PeLuYg3dQ">
              <ownedParameter xmi:id="_WCOoYX_bEeyw2PeLuYg3dQ" name="disp" type="_WB7tcX_bEeyw2PeLuYg3dQ"/>
              <ownedParameter xmi:id="_WCOoYn_bEeyw2PeLuYg3dQ" name="ball" type="_WB4qIX_bEeyw2PeLuYg3dQ"/>
            </ownedOperation>
