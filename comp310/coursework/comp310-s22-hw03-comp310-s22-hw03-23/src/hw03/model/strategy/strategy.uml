          <packagedElement xmi:type="uml:Class" xmi:id="_WBBHcH_bEeyw2PeLuYg3dQ" name="ReverseStrategy">
            <ownedComment xmi:id="_WlrTQIBVEeytY4-2QCegDA">
              <body>@author Christina
Strategy that reverse the ball every 10 ticks</body>
            </ownedComment>
            <ownedAttribute xmi:id="_MbkPsIBVEeytY4-2QCegDA" name="ticks" visibility="private">
              <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_MbkPsYBVEeytY4-2QCegDA" value="0"/>
            </ownedAttribute>
            <interfaceRealization xmi:id="_WCRrsH_bEeyw2PeLuYg3dQ" client="_WBBHcH_bEeyw2PeLuYg3dQ" supplier="_WB6fUX_bEeyw2PeLuYg3dQ" contract="_WB6fUX_bEeyw2PeLuYg3dQ"/>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_Mbk2wIBVEeytY4-2QCegDA" name="updateState" specification="_WCRrsX_bEeyw2PeLuYg3dQ">
              <ownedParameter xmi:id="_Mbk2wYBVEeytY4-2QCegDA" name="disp" type="_WB7tcX_bEeyw2PeLuYg3dQ"/>
              <ownedParameter xmi:id="_Mbk2woBVEeytY4-2QCegDA" name="ball" type="_WB4qIX_bEeyw2PeLuYg3dQ"/>
              <language>java</language>
              <body>if(ticks > 9) {
			ticks = 0;
			ball.setVelocity(new Point(ball.getVelocity().x * -1, ball.getVelocity().y * -1));
		}
		ticks++;
	</body>
            </ownedBehavior>
            <ownedOperation xmi:id="_WCRrsX_bEeyw2PeLuYg3dQ" name="updateState" method="_Mbk2wIBVEeytY4-2QCegDA">
              <ownedComment xmi:id="_WlrTQYBVEeytY4-2QCegDA">
                <body>@param disp the dispatcher to communicate
	 * @param ball the ball class</body>
              </ownedComment>
              <ownedParameter xmi:id="_WCRrsn_bEeyw2PeLuYg3dQ" name="disp" type="_WB7tcX_bEeyw2PeLuYg3dQ"/>
              <ownedParameter xmi:id="_WCRrs3_bEeyw2PeLuYg3dQ" name="ball" type="_WB4qIX_bEeyw2PeLuYg3dQ"/>
