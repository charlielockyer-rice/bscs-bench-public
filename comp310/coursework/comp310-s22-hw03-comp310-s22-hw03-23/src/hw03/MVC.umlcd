    <modelElement href="mvc.uml#_ETzapX_iEeytY4-2QCegDA"/>
  </nodes>
  <nodes xsi:type="com.yattasolutions.diagrams:CommentVisual" xmi:id="_HwNQEH_iEeytY4-2QCegDA" sourceConnectionVisual="_Hynq4H_iEeytY4-2QCegDA" text="Use the dispatcher to clear all the balls from the field. view to model" item="_NPkqnn_cEeyw2PeLuYg3dQ">
    <modelElement href="mvc.uml#_ETzaqH_iEeytY4-2QCegDA"/>
